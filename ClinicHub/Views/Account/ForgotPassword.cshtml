@{
    ViewData["Title"] = "نسيت كلمة المرور / تغيير كلمة المرور";
}

<div class="auth-wrapper">
    <div class="auth-card">
        <!-- Logo -->
        <div class="auth-logo-section">
            <svg width="48" height="48" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="32" height="32" rx="8" fill="#2F9CCA"/>
                <path d="M9 16C9 12.134 12.134 9 16 9C19.866 9 23 12.134 23 16C23 19.866 19.866 23 16 23V16H9Z" fill="white"/>
                <circle cx="12.5" cy="12.5" r="2.5" fill="#F2F5F9"/>
            </svg>
            <span style="font-size: 16px; font-weight: 700; color: var(--text-dark);">مجموعة فقيه الطبية</span>
        </div>

        <h3 class="auth-title">تغيير كلمة المرور</h3>

        <form asp-controller="Account" asp-action="ForgotPassword" method="post">
            <div class="text-danger" asp-validation-summary="ModelOnly" style="font-size: 14px; margin-bottom: 15px; text-align: center;"></div>
            
            <!-- Current Password -->
            <div class="auth-input-group">
                <label class="auth-form-label" for="currentPassword">كلمة المرور الحالية</label>
                <input class="auth-form-control" type="password" id="currentPassword" name="currentPassword" placeholder="أدخل كلمة المرور الحالية" required />
            </div>

            <!-- New Password -->
            <div class="auth-input-group">
                <label class="auth-form-label" for="newPassword">كلمة المرور الجديدة</label>
                <input class="auth-form-control" type="password" id="newPassword" name="newPassword" placeholder="أدخل كلمة المرور الجديدة" required />
            </div>

            <!-- Re-enter again -->
            <div class="auth-input-group">
                <label class="auth-form-label" for="confirmPassword">إعادة إدخال كلمة المرور</label>
                <input class="auth-form-control" type="password" id="confirmPassword" name="confirmPassword" placeholder="أعد إدخال كلمة المرور الجديدة للتأكيد" required />
            </div>

            <button type="submit" class="auth-btn-primary">تحديث كلمة المرور</button>
        </form>

        <div class="auth-footer-links">
            <a asp-controller="Account" asp-action="Login" class="auth-link">العودة لتسجيل الدخول</a>
        </div>
    </div>
</div>
