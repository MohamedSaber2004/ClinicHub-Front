@{
    ViewData["Title"] = "إعادة تعيين كلمة المرور - Doctory";
    var email = TempData["Email"]?.ToString();
    TempData.Keep("Email");
}

<div class="auth-wrapper">
    <div class="auth-card">
        <!-- Logo -->
        <div class="auth-logo-section">
            <svg width="48" height="48" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="32" height="32" rx="8" fill="var(--primary-color)"/>
                <path d="M9 16C9 12.134 12.134 9 16 9C19.866 9 23 12.134 23 16C23 19.866 19.866 23 16 23V16H9Z" fill="white"/>
                <circle cx="12.5" cy="12.5" r="2.5" fill="#F2F5F9"/>
            </svg>
            <span style="font-size: 16px; font-weight: 700; color: var(--text-dark);">Doctory</span>
        </div>

        <h3 class="auth-title">تعيين كلمة مرور جديدة</h3>
        
        <p style="font-size: 14px; color: var(--text-muted); text-align: center; margin-bottom: 24px; line-height: 1.6;">
            يرجى إدخال كلمة المرور الجديدة وتأكيدها لحسابك: <br />
            <strong style="color: var(--text-dark);">@email</strong>
        </p>

        <form action="@HomeRoutes.Account.ResetPassword()" method="post" data-ajax="true">
            <div class="text-danger" asp-validation-summary="ModelOnly" style="font-size: 14px; margin-bottom: 15px; text-align: center;"></div>
            
            <!-- Hidden email -->
            <input type="hidden" name="email" value="@email" />

            <!-- New Password -->
            <div class="auth-input-group">
                <label class="auth-form-label" for="newPassword">كلمة المرور الجديدة</label>
                <input class="auth-form-control" type="password" id="newPassword" name="newPassword" placeholder="أدخل كلمة المرور الجديدة" required autocomplete="new-password" />
            </div>

            <!-- Confirm Password -->
            <div class="auth-input-group">
                <label class="auth-form-label" for="confirmPassword">تأكيد كلمة المرور الجديدة</label>
                <input class="auth-form-control" type="password" id="confirmPassword" name="confirmPassword" placeholder="أعد إدخال كلمة المرور للتأكيد" required autocomplete="new-password" />
            </div>

            <button type="submit" class="auth-btn-primary">حفظ وتحديث كلمة المرور</button>
        </form>

        <div class="auth-footer-links">
            <a href="@HomeRoutes.Account.Login()" class="auth-link">العودة لتسجيل الدخول</a>
        </div>
    </div>
</div>
