@{
    ViewData["Title"] = "بوابة الدفع - Doctory";
    var paymentUrl = ViewBag.PaymentUrl as string ?? "";
}

<section class="payment-frame-section" style="padding: var(--space-6) 0; min-height: 80vh;">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="text-h2 mb-0">صفحة الدفع الإلكتروني</h2>
            <a href="/" class="btn btn-secondary">العودة للرئيسية</a>
        </div>
        
        <div class="card shadow-sm border-0 overflow-hidden" style="border-radius: var(--radius-lg); min-height: 650px;">
            <iframe id="paymentFrame" src="@paymentUrl" style="width: 100%; height: 650px; border: none; display: block;"></iframe>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        (function() {
            var iframe = document.getElementById('paymentFrame');
            if (!iframe) return;

            var checkTimer = setInterval(function() {
                try {
                    var frameUrl = iframe.contentWindow.location.href;
                    if (frameUrl && frameUrl.indexOf('result.html') !== -1) {
                        clearInterval(checkTimer);
                        var isSuccess = frameUrl.indexOf('success=True') !== -1 || frameUrl.indexOf('success=true') !== -1;
                        setTimeout(function() {
                            window.location.href = '/Home/PaymentResult?success=' + (isSuccess ? 'true' : 'false');
                        }, 2500);
                    }
                } catch (e) {
                    // Cross-origin iframe navigation check fallback
                }
            }, 500);

            iframe.addEventListener('load', function() {
                try {
                    var frameUrl = iframe.contentWindow.location.href;
                    if (frameUrl && frameUrl.indexOf('result.html') !== -1) {
                        clearInterval(checkTimer);
                        var isSuccess = frameUrl.indexOf('success=True') !== -1 || frameUrl.indexOf('success=true') !== -1;
                        setTimeout(function() {
                            window.location.href = '/Home/PaymentResult?success=' + (isSuccess ? 'true' : 'false');
                        }, 2500);
                    }
                } catch (e) {
                    // Ignored cross-origin security error when on third-party domain
                }
            });
        })();
    </script>
}
