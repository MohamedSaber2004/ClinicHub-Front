@using ClinicHub.Services.ReponseModels
@{
    Layout = "_ClinicLayout";
    ViewData["Title"] = "اشتراكي - Doctory";
    var subscription = ViewBag.Subscription as SubscriptionDto;
    var plans = ViewBag.Plans as List<PlanDto> ?? new();
}

<div class="page-header">
    <h2 class="page-title">
        <span class="page-title-icon">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M19 3h-4.18C14.4 1.84 13.3 1 12 1c-1.3 0-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm-2 14l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z" fill="currentColor"/>
            </svg>
        </span>
        اشتراكي
    </h2>
</div>

@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-warning">
        <p>@ViewBag.ErrorMessage</p>
        <a href="@HomeRoutes.Pages.Subscriptions()" class="btn btn-primary">عرض الباقات والاشتراك</a>
    </div>
}
else if (subscription == null)
{
    <div class="subscription-empty-state">
        <div class="empty-state-icon">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" fill="var(--clr-success)"/>
            </svg>
        </div>
        <h3>ليس لديك اشتراك نشط</h3>
        <p>اشترك الآن للاستفادة من جميع ميزات المنصة لإدارة عيادتك بكفاءة.</p>
        <a href="@HomeRoutes.Pages.Subscriptions()" class="btn btn-primary btn-lg">عرض الباقات والاشتراك</a>
    </div>
}
else
{
    var statusText = subscription.Status switch { 0 => "نشط", 1 => "ملغي", 2 => "منتهي", 3 => "ملغي من الإدارة", _ => "غير معروف" };
    var statusClass = subscription.Status switch { 0 => "badge-success", 1 => "badge-warning", 2 => "badge-danger", 3 => "badge-danger", _ => "badge-info" };
    var periodText = subscription.Period == 0 ? "شهري" : "سنوي";

    <div class="subscription-status-card">
        <div class="row g-4">
            <div class="col-md-6">
                <div class="subs-detail-card">
                    <div class="subs-detail-header">
                        <span class="badge @statusClass" style="font-size: 14px; padding: 6px 16px;">@statusText</span>
                    </div>
                    <div class="subs-detail-body">
                        <div class="subs-detail-row">
                            <span class="subs-detail-label">الباقة</span>
                            <span class="subs-detail-value">@subscription.PlanName</span>
                        </div>
                        <div class="subs-detail-row">
                            <span class="subs-detail-label">المدة</span>
                            <span class="subs-detail-value">@periodText</span>
                        </div>
                        <div class="subs-detail-row">
                            <span class="subs-detail-label">المبلغ</span>
                            <span class="subs-detail-value">@subscription.Amount.ToString("N0") ج.م</span>
                        </div>
                        <div class="subs-detail-row">
                            <span class="subs-detail-label">تاريخ البداية</span>
                            <span class="subs-detail-value">@subscription.StartDate.ToString("yyyy-MM-dd")</span>
                        </div>
                        <div class="subs-detail-row">
                            <span class="subs-detail-label">تاريخ النهاية</span>
                            <span class="subs-detail-value">@subscription.EndDate.ToString("yyyy-MM-dd")</span>
                        </div>
                        @if (subscription.PaidAt.HasValue)
                        {
                            <div class="subs-detail-row">
                                <span class="subs-detail-label">تاريخ الدفع</span>
                                <span class="subs-detail-value">@subscription.PaidAt.Value.ToString("yyyy-MM-dd")</span>
                            </div>
                        }
                    </div>
                    @if (subscription.IsActive)
                    {
                        <div class="subs-detail-footer">
                            <button class="btn btn-danger" onclick="cancelSubscription()">إلغاء الاشتراك</button>
                        </div>
                    }
                </div>
            </div>
            <div class="col-md-6">
                <div class="subs-plans-preview">
                    <h4>الباقات المتاحة</h4>
                    <div class="subscription-plans">
                        @foreach (var plan in plans.Where(p => p.IsActive).OrderBy(p => p.SortOrder))
                        {
                            var maxSort = plans.Where(p => p.IsActive).Max(p => p.SortOrder);
                            var isTop = plan.SortOrder >= maxSort;
                            var planClass = isTop ? "plan-premium" : "plan-free";
                            <div class="plan-card @planClass" style="margin-bottom: 0;">
                                <div class="plan-header">
                                    <h3 class="plan-name">@plan.NameAr</h3>
                                    <p class="plan-price">@plan.PriceMonthly.ToString("N0") <span class="plan-currency">ج.م</span></p>
                                </div>
                                <div class="plan-footer">
                                    <span class="plan-current">@(plan.Id.ToString() == subscription.PlanId.ToString() ? "الباقة الحالية" : "")</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .subscription-empty-state {
        text-align: center;
        padding: var(--space-10) var(--space-5);
    }
    .empty-state-icon {
        margin-bottom: var(--space-5);
    }
    .subscription-empty-state h3 {
        font-size: var(--fs-xl);
        font-weight: var(--fw-semibold);
        margin-bottom: var(--space-3);
    }
    .subscription-empty-state p {
        color: var(--clr-text-secondary);
        margin-bottom: var(--space-6);
        max-width: 400px;
        margin-left: auto;
        margin-right: auto;
    }
    .subscription-status-card {
        padding: var(--space-5) 0;
    }
    .subs-detail-card {
        background: var(--clr-surface);
        border: 1px solid var(--clr-border);
        border-radius: var(--radius-lg);
        overflow: hidden;
    }
    .subs-detail-header {
        padding: var(--space-4) var(--space-5);
        border-bottom: 1px solid var(--clr-border);
    }
    .subs-detail-body {
        padding: var(--space-4) var(--space-5);
    }
    .subs-detail-row {
        display: flex;
        justify-content: space-between;
        padding: var(--space-2) 0;
        border-bottom: 1px solid var(--clr-bg);
    }
    .subs-detail-row:last-child {
        border-bottom: none;
    }
    .subs-detail-label {
        font-size: var(--fs-sm);
        color: var(--clr-text-secondary);
    }
    .subs-detail-value {
        font-size: var(--fs-sm);
        font-weight: var(--fw-semibold);
        color: var(--clr-text);
    }
    .subs-detail-footer {
        padding: var(--space-4) var(--space-5);
        border-top: 1px solid var(--clr-border);
    }
    .subs-plans-preview h4 {
        font-size: var(--fs-lg);
        font-weight: var(--fw-semibold);
        margin-bottom: var(--space-4);
    }
    .subs-plans-preview .subscription-plans {
        display: flex;
        flex-direction: column;
        gap: var(--space-3);
    }
    .subs-plans-preview .plan-card {
        padding: var(--space-3) var(--space-4);
    }
</style>

@section Scripts {
    <script>
        function cancelSubscription() {
            showConfirmModal('هل أنت متأكد من إلغاء الاشتراك؟ لن يتم استرداد المبلغ المدفوع.', function(confirmed) {
                if (!confirmed) return;
                fetch('@ClinicRoutes.Pages.CancelSubscription()', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                }).then(function(r) { return r.json(); })
                  .then(function(data) {
                      if (data.success) {
                          localStorage.removeItem('accessToken');
                          localStorage.removeItem('refreshToken');
                          localStorage.removeItem('userId');
                          localStorage.removeItem('role');
                          localStorage.removeItem('clinicId');
                          window.location.href = '@HomeRoutes.Pages.SubscriptionRequired()';
                      } else {
                          showBackendErrors(JSON.stringify(data));
                      }
                  }).catch(function() {
                      showBackendErrors(null);
                  });
            });
        }
    </script>
}
