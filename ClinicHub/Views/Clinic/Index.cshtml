@{
    ViewData["Title"] = "إدارة العيادات - Doctory";
    Layout = "_DashboardLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="page-title mb-0">لوحة إدارة وتشغيل العيادات اليومي</h2>
    <div class="text-muted" style="font-size: 14px; font-weight: 500;">
        <i class="bi bi-clock-history me-1"></i> آخر تحديث: اليوم، 05:48 م
    </div>
</div>

<!-- Statistics Grid -->
<div class="stats-grid">
    <!-- Today's Visits -->
    <div class="stat-card">
        <div class="stat-info">
            <span class="stat-value">45</span>
            <span class="stat-label">زيارات اليوم</span>
        </div>
        <div class="stat-icon-wrapper icon-wrapper icon-wrapper--blue">
            <!-- Calendar SVG -->
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <rect x="3" y="4" width="18" height="16" rx="2" stroke="currentColor" stroke-width="2" fill="none"/>
                <line x1="16" y1="2" x2="16" y2="6" stroke="currentColor" stroke-width="2"/>
                <line x1="8" y1="2" x2="8" y2="6" stroke="currentColor" stroke-width="2"/>
                <line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="2"/>
            </svg>
        </div>
    </div>

    <!-- Active Clinics -->
    <div class="stat-card">
        <div class="stat-info">
            <span class="stat-value">6</span>
            <span class="stat-label">العيادات النشطة</span>
        </div>
        <div class="stat-icon-wrapper icon-wrapper icon-wrapper--primary">
            <!-- Clinic SVG -->
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M19 3H5C3.9 3 3 3.9 3 5V19C3 20.1 3.9 21 5 21H19C20.1 21 21 20.1 21 19V5C21 3.9 20.1 3 19 3ZM17 13H13V17H11V13H7V11H11V7H13V11H17V13Z" fill="currentColor"/>
            </svg>
        </div>
    </div>

    <!-- Patients in Queue -->
    <div class="stat-card">
        <div class="stat-info">
            <span class="stat-value">14</span>
            <span class="stat-label">مرضى في الانتظار</span>
        </div>
        <div class="stat-icon-wrapper icon-wrapper icon-wrapper--amber">
            <!-- Clock/Hourglass SVG -->
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" fill="none"/>
                <path d="M12 6v6l4 2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
        </div>
    </div>

    <!-- Completed Appointments -->
    <div class="stat-card">
        <div class="stat-info">
            <span class="stat-value">28</span>
            <span class="stat-label">حالات تم علاجها</span>
        </div>
        <div class="stat-icon-wrapper icon-wrapper icon-wrapper--green">
            <!-- Check Circle SVG -->
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/>
                <path d="M22 4L12 14.01l-3-3" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/>
            </svg>
        </div>
    </div>
</div>

<!-- Dashboard grid: Tables and Quick actions -->
<div class="dashboard-tables-grid">
    <!-- Today's Appointments -->
    <div class="table-card">
        <div class="table-card-header d-flex justify-content-between align-items-center">
            <h3 class="table-card-title mb-0">مواعيد العيادات اليوم</h3>
            <a href="@ClinicRoutes.Pages.Appointments()" class="btn btn-sm btn-link" style="color: var(--primary-color); text-decoration: none; font-size: 13px; font-weight: 600;">عرض الكل <i class="bi bi-arrow-left"></i></a>
        </div>
        <div class="table-responsive">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>المريض</th>
                        <th>العيادة</th>
                        <th>الوقت</th>
                        <th>الحالة</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><strong>عزير بن محمد</strong></td>
                        <td>عيادة القلب</td>
                        <td>10:00 ص</td>
                        <td><span class="badge badge-success">تم الكشف</span></td>
                    </tr>
                    <tr>
                        <td><strong>حارس عبد الكريم</strong></td>
                        <td>عيادة الأعصاب</td>
                        <td>11:30 ص</td>
                        <td><span class="badge badge-warning">قيد الانتظار</span></td>
                    </tr>
                    <tr>
                        <td><strong>حمزة الرفاعي</strong></td>
                        <td>عيادة النساء والولادة</td>
                        <td>12:15 م</td>
                        <td><span class="badge badge-info">قيد الكشف</span></td>
                    </tr>
                    <tr>
                        <td><strong>سارة أحمد</strong></td>
                        <td>عيادة الجلدية</td>
                        <td>01:00 م</td>
                        <td><span class="badge badge-warning">قيد الانتظار</span></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Active Clinics Status -->
    <div class="table-card">
        <div class="table-card-header">
            <h3 class="table-card-title mb-0">حالة العيادات والتشغيل الفعلي</h3>
        </div>
        <div class="table-responsive">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>العيادة</th>
                        <th>الطبيب المتواجد</th>
                        <th>رقم الغرفة</th>
                        <th>الحالة التشغيلية</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>عيادة القلب</td>
                        <td><strong>د. سمير المنشاوي</strong></td>
                        <td>غرفة 101</td>
                        <td><span class="badge badge-success">مفتوح</span></td>
                    </tr>
                    <tr>
                        <td>عيادة الجلدية</td>
                        <td><strong>د. عمار السليمان</strong></td>
                        <td>غرفة 102</td>
                        <td><span class="badge badge-success">مفتوح</span></td>
                    </tr>
                    <tr>
                        <td>عيادة الأعصاب</td>
                        <td><strong>د. عبد الله الرويلي</strong></td>
                        <td>غرفة 103</td>
                        <td><span class="badge badge-warning">في استراحة</span></td>
                    </tr>
                    <tr>
                        <td>عيادة العظام</td>
                        <td><strong>د. خالد العتيبي</strong></td>
                        <td>غرفة 104</td>
                        <td><span class="badge badge-success">مفتوح</span></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
