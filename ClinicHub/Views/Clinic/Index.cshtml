@{
    ViewData["Title"] = "إدارة العيادات - Doctory";
    Layout = "_DashboardLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="page-title mb-0">لوحة إدارة وتشغيل العيادات اليومي</h2>
    <div class="text-muted" style="font-size: 14px; font-weight: 500;">
        <i class="bi bi-clock-history me-1"></i> آخر تحديث: اليوم، 05:48 م
    </div>
</div>

<!-- Statistics Grid -->
<div class="stats-grid">
    <!-- Today's Visits -->
    <div class="stat-card">
        <div class="stat-info">
            <span class="stat-value">45</span>
            <span class="stat-label">زيارات اليوم</span>
        </div>
        <div class="stat-icon-wrapper" style="background-color: rgba(74, 144, 226, 0.1); color: var(--primary-color);">
            <i class="bi bi-calendar-check fs-3"></i>
        </div>
    </div>

    <!-- Active Clinics -->
    <div class="stat-card">
        <div class="stat-info">
            <span class="stat-value">6</span>
            <span class="stat-label">العيادات النشطة</span>
        </div>
        <div class="stat-icon-wrapper" style="background-color: rgba(74, 144, 226, 0.1); color: var(--primary-color);">
            <i class="bi bi-hospital fs-3"></i>
        </div>
    </div>

    <!-- Patients in Queue -->
    <div class="stat-card">
        <div class="stat-info">
            <span class="stat-value">14</span>
            <span class="stat-label">مرضى في الانتظار</span>
        </div>
        <div class="stat-icon-wrapper" style="background-color: rgba(251, 191, 36, 0.1); color: #fbbf24;">
            <i class="bi bi-hourglass-split fs-3"></i>
        </div>
    </div>

    <!-- Completed Appointments -->
    <div class="stat-card">
        <div class="stat-info">
            <span class="stat-value">28</span>
            <span class="stat-label">حالات تم علاجها</span>
        </div>
        <div class="stat-icon-wrapper" style="background-color: rgba(52, 211, 153, 0.1); color: #34d399;">
            <i class="bi bi-check-circle-fill fs-3"></i>
        </div>
    </div>
</div>

<!-- Dashboard grid: Tables and Quick actions -->
<div class="dashboard-tables-grid">
    <!-- Today's Appointments -->
    <div class="table-card">
        <div class="table-card-header d-flex justify-content-between align-items-center">
            <h3 class="table-card-title mb-0">مواعيد العيادات اليوم</h3>
            <a href="@ClinicRoutes.Pages.Appointments()" class="btn btn-sm btn-link" style="color: var(--primary-color); text-decoration: none; font-size: 13px; font-weight: 600;">عرض الكل <i class="bi bi-arrow-left"></i></a>
        </div>
        <div class="table-responsive">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>المريض</th>
                        <th>العيادة</th>
                        <th>الوقت</th>
                        <th>الحالة</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><strong>عزير بن محمد</strong></td>
                        <td>عيادة القلب</td>
                        <td>10:00 ص</td>
                        <td><span style="color: #10b981; font-weight: 600;"><i class="bi bi-check-circle me-1"></i> تم الكشف</span></td>
                    </tr>
                    <tr>
                        <td><strong>حارس عبد الكريم</strong></td>
                        <td>عيادة الأعصاب</td>
                        <td>11:30 ص</td>
                        <td><span style="color: #f59e0b; font-weight: 600;"><i class="bi bi-hourglass me-1"></i> قيد الانتظار</span></td>
                    </tr>
                    <tr>
                        <td><strong>حمزة الرفاعي</strong></td>
                        <td>عيادة النساء والولادة</td>
                        <td>12:15 م</td>
                        <td><span style="color: var(--primary-color); font-weight: 600;"><i class="bi bi-activity me-1"></i> قيد الكشف</span></td>
                    </tr>
                    <tr>
                        <td><strong>سارة أحمد</strong></td>
                        <td>عيادة الجلدية</td>
                        <td>01:00 م</td>
                        <td><span style="color: #f59e0b; font-weight: 600;"><i class="bi bi-hourglass me-1"></i> قيد الانتظار</span></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Active Clinics Status -->
    <div class="table-card">
        <div class="table-card-header">
            <h3 class="table-card-title mb-0">حالة العيادات والتشغيل الفعلي</h3>
        </div>
        <div class="table-responsive">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>العيادة</th>
                        <th>الطبيب المتواجد</th>
                        <th>رقم الغرفة</th>
                        <th>الحالة التشغيلية</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>عيادة القلب</td>
                        <td><strong>د. سمير المنشاوي</strong></td>
                        <td>غرفة 101</td>
                        <td><span style="background-color: #e6f4ea; color: #137333; padding: 2px 8px; border-radius: 12px; font-size: 12px; font-weight: 600;"><i class="bi bi-door-open me-1"></i> مفتوح</span></td>
                    </tr>
                    <tr>
                        <td>عيادة الجلدية</td>
                        <td><strong>د. عمار السليمان</strong></td>
                        <td>غرفة 102</td>
                        <td><span style="background-color: #e6f4ea; color: #137333; padding: 2px 8px; border-radius: 12px; font-size: 12px; font-weight: 600;"><i class="bi bi-door-open me-1"></i> مفتوح</span></td>
                    </tr>
                    <tr>
                        <td>عيادة الأعصاب</td>
                        <td><strong>د. عبد الله الرويلي</strong></td>
                        <td>غرفة 103</td>
                        <td><span style="background-color: #fef7e0; color: #b06000; padding: 2px 8px; border-radius: 12px; font-size: 12px; font-weight: 600;"><i class="bi bi-cup-hot me-1"></i> في استراحة</span></td>
                    </tr>
                    <tr>
                        <td>عيادة العظام</td>
                        <td><strong>د. خالد العتيبي</strong></td>
                        <td>غرفة 104</td>
                        <td><span style="background-color: #e6f4ea; color: #137333; padding: 2px 8px; border-radius: 12px; font-size: 12px; font-weight: 600;"><i class="bi bi-door-open me-1"></i> مفتوح</span></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
