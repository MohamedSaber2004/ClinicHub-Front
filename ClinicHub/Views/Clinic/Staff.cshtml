@{
    ViewData["Title"] = "إدارة الموظفين والدوام - Doctory";
    Layout = "_ClinicLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="page-title mb-0">إدارة الموظفين والكادر الطبي (Staff & HR Management)</h2>
    <button class="btn" style="background-color: var(--primary-color); color: white; font-weight: 600; padding: 10px 20px; border-radius: 5px;">
        <i class="bi bi-person-plus me-1"></i> تسجيل موظف جديد
    </button>
</div>

<!-- Roster Roster List -->
<div class="table-card" style="padding: 24px;">
    <h4 style="font-weight: 700; margin-bottom: 20px;">كادر العيادة والدوام اليومي</h4>
    
    <div class="table-responsive">
        <table class="custom-table">
            <thead>
                <tr>
                    <th style="width: 60px;">النوع</th>
                    <th>الموظف</th>
                    <th>الدور الوظيفي</th>
                    <th>العيادة المسندة</th>
                    <th>مواعيد العمل (الوردية)</th>
                    <th>حالة الحضور اليوم</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="text-center"><i class="bi bi-person-fill text-primary fs-4"></i></td>
                    <td><strong>د. سمير المنشاوي</strong></td>
                    <td>طبيب استشاري</td>
                    <td>عيادة القلب</td>
                    <td>09:00 ص - 05:00 م</td>
                    <td><span style="background-color: #e6f4ea; color: #137333; padding: 2px 8px; border-radius: 12px; font-size: 11px; font-weight: 600;"><i class="bi bi-check-circle me-1"></i> متواجد بالعيادة</span></td>
                    <td>
                        <button class="btn btn-sm btn-outline-secondary" style="font-size: 11px; border: 1px solid var(--border-color);">
                            <i class="bi bi-pencil me-1"></i> تعديل الدوام
                        </button>
                    </td>
                </tr>
                <tr>
                    <td class="text-center"><i class="bi bi-person-fill text-primary fs-4"></i></td>
                    <td><strong>د. عبد الله الرويلي</strong></td>
                    <td>طبيب استشاري</td>
                    <td>عيادة الأعصاب</td>
                    <td>09:00 ص - 05:00 م</td>
                    <td><span style="background-color: #fef7e0; color: #b06000; padding: 2px 8px; border-radius: 12px; font-size: 11px; font-weight: 600;"><i class="bi bi-cup-hot me-1"></i> في استراحة كشف</span></td>
                    <td>
                        <button class="btn btn-sm btn-outline-secondary" style="font-size: 11px; border: 1px solid var(--border-color);">
                            <i class="bi bi-pencil me-1"></i> تعديل الدوام
                        </button>
                    </td>
                </tr>
                <tr>
                    <td class="text-center"><i class="bi bi-person-fill text-success fs-4"></i></td>
                    <td><strong>أ. مريم السالم</strong></td>
                    <td>رئيسة ممرضين</td>
                    <td>عام (فرز الطوارئ)</td>
                    <td>08:00 ص - 04:00 م</td>
                    <td><span style="background-color: #e6f4ea; color: #137333; padding: 2px 8px; border-radius: 12px; font-size: 11px; font-weight: 600;"><i class="bi bi-check-circle me-1"></i> متواجد</span></td>
                    <td>
                        <button class="btn btn-sm btn-outline-secondary" style="font-size: 11px; border: 1px solid var(--border-color);">
                            <i class="bi bi-pencil me-1"></i> تعديل الدوام
                        </button>
                    </td>
                </tr>
                <tr>
                    <td class="text-center"><i class="bi bi-person-fill text-secondary fs-4"></i></td>
                    <td><strong>أ. روان اليوسف</strong></td>
                    <td>موظفة استقبال</td>
                    <td>خدمة العملاء</td>
                    <td>02:00 م - 10:00 م</td>
                    <td><span style="background-color: #f1f3f4; color: #5f6368; padding: 2px 8px; border-radius: 12px; font-size: 11px; font-weight: 600;"><i class="bi bi-clock me-1"></i> لم يبدأ الوردية</span></td>
                    <td>
                        <button class="btn btn-sm btn-outline-secondary" style="font-size: 11px; border: 1px solid var(--border-color);">
                            <i class="bi bi-pencil me-1"></i> تعديل الدوام
                        </button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
