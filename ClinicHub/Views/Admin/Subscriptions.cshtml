@{
    ViewData["Title"] = "الباقات والاشتراكات";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <h2 class="page-title">
        <span class="page-title-icon">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M19 3h-4.18C14.4 1.84 13.3 1 12 1c-1.3 0-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm-2 14l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z" fill="currentColor"/>
            </svg>
        </span>
        الباقات والاشتراكات
    </h2>
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addPlanModal">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
        </svg>
        إضافة باقة جديدة
    </button>
</div>

<!-- Plan Cards -->
<div class="subscription-plans">
    <div class="plan-card plan-free">
        <div class="plan-header">
            <h3 class="plan-name">الباقة المجانية</h3>
            <p class="plan-price">0 <span class="plan-currency">ريال/شهر</span></p>
        </div>
        <div class="plan-body">
            <ul class="plan-features">
                <li><svg width="16" height="16" viewBox="0 0 24 24" fill="var(--clr-success)"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg> طبيب واحد</li>
                <li><svg width="16" height="16" viewBox="0 0 24 24" fill="var(--clr-success)"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg> عيادة واحدة</li>
                <li><svg width="16" height="16" viewBox="0 0 24 24" fill="var(--clr-success)"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg> تقارير أساسية</li>
                <li class="plan-feature-disabled"><svg width="16" height="16" viewBox="0 0 24 24" fill="var(--clr-text-light)"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg> دعم فني متقدم</li>
                <li class="plan-feature-disabled"><svg width="16" height="16" viewBox="0 0 24 24" fill="var(--clr-text-light)"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg> تحليلات متقدمة</li>
            </ul>
        </div>
        <div class="plan-footer">
            <span class="plan-current">الباقة الحالية</span>
        </div>
    </div>
    <div class="plan-card plan-standard">
        <div class="plan-badge">الأكثر طلباً</div>
        <div class="plan-header">
            <h3 class="plan-name">الباقة الاحترافية</h3>
            <p class="plan-price">299 <span class="plan-currency">ريال/شهر</span></p>
        </div>
        <div class="plan-body">
            <ul class="plan-features">
                <li><svg width="16" height="16" viewBox="0 0 24 24" fill="var(--clr-success)"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg> حتى 5 أطباء</li>
                <li><svg width="16" height="16" viewBox="0 0 24 24" fill="var(--clr-success)"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg> حتى 3 عيادات</li>
                <li><svg width="16" height="16" viewBox="0 0 24 24" fill="var(--clr-success)"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg> دعم فني أولوية</li>
                <li><svg width="16" height="16" viewBox="0 0 24 24" fill="var(--clr-success)"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg> تقارير متقدمة</li>
                <li class="plan-feature-disabled"><svg width="16" height="16" viewBox="0 0 24 24" fill="var(--clr-text-light)"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg> تحليلات ذكاء اصطناعي</li>
            </ul>
        </div>
        <div class="plan-footer">
            <button class="btn btn-primary" disabled>الباقة الحالية</button>
        </div>
    </div>
    <div class="plan-card plan-premium">
        <div class="plan-header">
            <h3 class="plan-name">الباقة المميزة</h3>
            <p class="plan-price">599 <span class="plan-currency">ريال/شهر</span></p>
        </div>
        <div class="plan-body">
            <ul class="plan-features">
                <li><svg width="16" height="16" viewBox="0 0 24 24" fill="var(--clr-success)"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg> أطباء غير محدود</li>
                <li><svg width="16" height="16" viewBox="0 0 24 24" fill="var(--clr-success)"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg> عيادات غير محدودة</li>
                <li><svg width="16" height="16" viewBox="0 0 24 24" fill="var(--clr-success)"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg> دعم فني VIP</li>
                <li><svg width="16" height="16" viewBox="0 0 24 24" fill="var(--clr-success)"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg> تحليلات ذكاء اصطناعي</li>
                <li><svg width="16" height="16" viewBox="0 0 24 24" fill="var(--clr-success)"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg> أولوية في الإعلانات</li>
            </ul>
        </div>
        <div class="plan-footer">
            <button class="btn btn-outline-primary">الترقية الآن</button>
        </div>
    </div>
</div>

<!-- Feature Comparison Table -->
<div class="table-card mt-4">
    <div class="table-card-header">
        <h4>مقارنة الباقات</h4>
    </div>
    <div class="table-responsive">
        <table class="custom-table comparison-table">
            <thead>
                <tr>
                    <th>الميزة</th>
                    <th>المجانية</th>
                    <th>الاحترافية</th>
                    <th>المميزة</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>عدد الأطباء</td>
                    <td>1</td>
                    <td>5</td>
                    <td>غير محدود</td>
                </tr>
                <tr>
                    <td>عدد العيادات</td>
                    <td>1</td>
                    <td>3</td>
                    <td>غير محدود</td>
                </tr>
                <tr>
                    <td>تقارير وإحصائيات</td>
                    <td>أساسية</td>
                    <td>متقدمة</td>
                    <td>شاملة</td>
                </tr>
                <tr>
                    <td>الدعم الفني</td>
                    <td>بريد إلكتروني</td>
                    <td>أولوية</td>
                    <td>VIP</td>
                </tr>
                <tr>
                    <td>تحليلات ذكاء اصطناعي</td>
                    <td><span class="text-muted">—</span></td>
                    <td><span class="text-muted">—</span></td>
                    <td><svg width="16" height="16" viewBox="0 0 24 24" fill="var(--clr-success)"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg></td>
                </tr>
                <tr>
                    <td>الإعلانات</td>
                    <td>قياسية</td>
                    <td>مفضلة</td>
                    <td>أولوية قصوى</td>
                </tr>
                <tr>
                    <td>التكلفة الشهرية</td>
                    <td>مجاناً</td>
                    <td>299 ريال</td>
                    <td>599 ريال</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Add Plan Modal -->
<div class="modal fade" id="addPlanModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-content-custom">
            <div class="modal-header-custom">
                <h5 class="modal-title">إضافة باقة جديدة</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="إغلاق"></button>
            </div>
            <div class="modal-body-custom">
                <div class="form-group">
                    <label class="form-label" for="planName">اسم الباقة</label>
                    <input type="text" id="planName" class="form-input" placeholder="اسم الباقة" />
                </div>
                <div class="form-group">
                    <label class="form-label" for="planPrice">السعر الشهري (ريال)</label>
                    <input type="number" id="planPrice" class="form-input" placeholder="0" />
                </div>
                <div class="form-group">
                    <label class="form-label" for="planDoctors">عدد الأطباء</label>
                    <input type="text" id="planDoctors" class="form-input" placeholder="مثال: 10 أو غير محدود" />
                </div>
                <div class="form-group">
                    <label class="form-label" for="planClinics">عدد العيادات</label>
                    <input type="text" id="planClinics" class="form-input" placeholder="مثال: 5 أو غير محدود" />
                </div>
                <div class="form-group">
                    <label class="form-label" for="planFeatures">المميزات (كل ميزة في سطر)</label>
                    <textarea id="planFeatures" class="form-input" rows="4" placeholder="دعم فني VIP&#10;تحليلات متقدمة&#10;..."></textarea>
                </div>
            </div>
            <div class="modal-footer-custom">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">إضافة الباقة</button>
            </div>
        </div>
    </div>
</div>
