@using ClinicHub.Data
@{
    ViewData["Title"] = "نظرة عامة على المستخدم";
    Layout = "_AdminLayout";
    ViewBag.SubSidebarSection = "overview";
    var u = ViewBag.User as MockUserOverview ?? new();
    ViewBag.UserId = u.Id;
}

<div class="user-detail-layout">
    <partial name="_UserSubSidebar" />

    <div class="user-detail-content">
        <!-- Profile Header -->
        <div class="user-profile-header">
            <div class="user-profile-avatar-lg">
                <span>@u.Initials</span>
            </div>
            <div class="user-profile-info">
                <h2 class="user-profile-name">@u.Name</h2>
                <p class="user-profile-contact">@u.Email &middot; @u.Phone</p>
                <span class="badge @u.StatusClass">@u.Status</span>
            </div>
        </div>

        <!-- Stats Row -->
        <div class="user-stats-row">
            <div class="user-stat-card">
                <span class="user-stat-value">@u.TotalVisits</span>
                <span class="user-stat-label">إجمالي الزيارات</span>
            </div>
            <div class="user-stat-card">
                <span class="user-stat-value">@u.AvgRating.ToString("F1")</span>
                <span class="user-stat-label">متوسط التقييم</span>
            </div>
            <div class="user-stat-card">
                <span class="user-stat-value">@u.TotalSpent</span>
                <span class="user-stat-label">إجمالي الإنفاق</span>
            </div>
        </div>

        <!-- Information Card -->
        <div class="detail-card">
            <h3 class="detail-card-title">معلومات المستخدم</h3>
            <div class="detail-info-list">
                <div class="detail-info-row">
                    <span class="detail-info-label">الاسم الكامل</span>
                    <span class="detail-info-value">@u.Name</span>
                </div>
                <div class="detail-info-row">
                    <span class="detail-info-label">البريد الإلكتروني</span>
                    <span class="detail-info-value">@u.Email</span>
                </div>
                <div class="detail-info-row">
                    <span class="detail-info-label">رقم الهاتف</span>
                    <span class="detail-info-value">@u.Phone</span>
                </div>
                <div class="detail-info-row">
                    <span class="detail-info-label">تاريخ التسجيل</span>
                    <span class="detail-info-value">@u.RegistrationDate</span>
                </div>
                <div class="detail-info-row">
                    <span class="detail-info-label">الحالة</span>
                    <span class="detail-info-value"><span class="badge @u.StatusClass">@u.Status</span></span>
                </div>
            </div>
        </div>

        <!-- Change Password -->
        <div class="detail-card">
            <h3 class="detail-card-title">تغيير كلمة المرور</h3>
            <form method="post" action="/Admin/Users/ChangePassword" style="max-width: 400px;">
                <input type="hidden" name="id" value="@u.Id" />
                <div class="form-group" style="margin-bottom: var(--space-4);">
                    <label class="form-label" for="overviewNewPassword">كلمة المرور الجديدة</label>
                    <input type="password" id="overviewNewPassword" name="newPassword" class="form-input" placeholder="********" required minlength="6" />
                </div>
                <div class="form-group" style="margin-bottom: var(--space-4);">
                    <label class="form-label" for="overviewConfirmPassword">تأكيد كلمة المرور</label>
                    <input type="password" id="overviewConfirmPassword" name="confirmPassword" class="form-input" placeholder="********" required minlength="6" />
                </div>
                <button type="submit" class="btn btn-primary" style="padding: 10px 24px; border-radius: var(--radius-sm); font-size: var(--fs-md); font-weight: 600;">تحديث كلمة المرور</button>
            </form>
        </div>

        <!-- Community Activity Feed -->
        <div class="detail-card">
            <h3 class="detail-card-title">نشاط المستخدم في المنصة</h3>
            <div class="activity-feed">
                @foreach (var activity in u.Activity)
                {
                    <div class="activity-item">
                        <div class="activity-icon">
                            @switch (activity.Icon)
                            {
                                case "star":
                                    <svg viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                                    </svg>
                                    break;
                                case "comment":
                                    <svg viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                                    </svg>
                                    break;
                                case "cancel":
                                    <svg viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M12 2C6.47 2 2 6.47 2 12s4.47 10 10 10 10-4.47 10-10S17.53 2 12 2zm5 13.59L15.59 17 12 13.41 8.41 17 7 15.59 10.59 12 7 8.41 8.41 7 12 10.59 15.59 7 17 8.41 13.41 12 17 15.59z"/>
                                    </svg>
                                    break;
                                case "edit":
                                    <svg viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/>
                                    </svg>
                                    break;
                                case "payment":
                                    <svg viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M20 4H4c-1.11 0-1.99.89-1.99 2L2 18c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V6c0-1.11-.89-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z"/>
                                    </svg>
                                    break;
                                default:
                                    <svg viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M19 3h-4.18C14.4 1.84 13.3 1 12 1c-1.3 0-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm-2 14l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/>
                                    </svg>
                                    break;
                            }
                        </div>
                        <div class="activity-content">
                            <span class="activity-text">@activity.Text</span>
                            <span class="activity-date">@activity.Date</span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var successMsg = '@(TempData["SuccessMessage"] ?? "")';
        if (successMsg) { showSuccessModal(successMsg); }
        var errorMsg = '@(TempData["ErrorMessage"] ?? "")';
        if (errorMsg) { showErrorModal(errorMsg); }
    </script>
}
