@using ClinicHub.Data
@{
    ViewData["Title"] = "المستخدمين";
    Layout = "_AdminLayout";
    var users = ViewBag.Users as List<MockUser> ?? new();
}

<div class="page-header">
    <h2 class="page-title">إدارة المستخدمين والمرضى</h2>
    <button type="button" class="btn btn-primary" id="addUserBtn" title="إضافة مستخدم">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
        </svg>
        إضافة مستخدم
    </button>
</div>

<!-- Filter Bar -->
<div class="filter-bar">
    <input type="text" id="filterSearch" class="form-input" placeholder="بحث عن مستخدم..." />
    <select id="filterStatus" class="form-select">
        <option value="">جميع الحالات</option>
        <option value="نشط">نشط</option>
        <option value="غير نشط">غير نشط</option>
    </select>
</div>

<!-- Users Table -->
<div class="table-card">
    <div class="table-responsive">
        <table class="custom-table">
            <thead>
                <tr>
                    <th>المستخدم</th>
                    <th>البريد الإلكتروني</th>
                    <th>الهاتف</th>
                    <th>تاريخ التسجيل</th>
                    <th>الحالة</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in users)
                {
                    <tr>
                        <td>
                            <div style="display: flex; align-items: center; gap: var(--space-3);">
                                <div class="sidebar-profile-avatar" style="width: 36px; height: 36px; background-color: var(--clr-primary);">
                                    <span style="color: #FFFFFF; font-size: var(--fs-md); font-weight: var(--fw-bold);">@u.Initials</span>
                                </div>
                                <span class="text-md-medium">@u.Name</span>
                            </div>
                        </td>
                        <td class="text-md">@u.Email</td>
                        <td class="text-md">@u.Phone</td>
                        <td class="text-md">@u.RegistrationDate</td>
                        <td><span class="badge @u.StatusClass">@u.Status</span></td>
                        <td>
                            <div class="table-actions">
                                <button class="btn-icon btn-delete-user" title="حذف"
                                        data-id="@u.Id"
                                        data-name="@u.Name">
                                    <svg viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/>
                                    </svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<partial name="_Pagination" />

<form id="createUserForm" method="post">
    <div class="modal fade" id="createUserModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content modal-content-custom">
                <div class="modal-header-custom">
                    <h5 class="modal-title">إضافة مستخدم جديد</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="إغلاق"></button>
                </div>
                <div class="modal-body-custom">
                    <div class="form-group">
                        <label class="form-label" for="createFullName">الاسم الكامل</label>
                        <input type="text" id="createFullName" name="FullName" class="form-input" placeholder="مثال: محمد عمر" required />
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="createEmail">البريد الإلكتروني</label>
                        <input type="email" id="createEmail" name="Email" class="form-input" placeholder="example@gmail.com" required />
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="createPhone">رقم الهاتف</label>
                        <input type="text" id="createPhone" name="Phone" class="form-input" placeholder="010 12345678" required />
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="createPassword">كلمة المرور</label>
                        <input type="password" id="createPassword" name="Password" class="form-input" placeholder="********" required />
                    </div>
                </div>
                <div class="modal-footer-custom">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-primary">حفظ</button>
                </div>
            </div>
        </div>
    </div>
</form>

<form id="deleteUserForm" method="post">
    <input type="hidden" id="deleteUserId" name="id" value="" />
</form>

<div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border: none; border-radius: var(--radius-md); box-shadow: var(--shadow-lg);">
            <div class="modal-body" style="padding: var(--space-6); text-align: center;">
                <div style="width: 56px; height: 56px; border-radius: 50%; background-color: rgba(239, 68, 68, 0.1); display: flex; align-items: center; justify-content: center; margin: 0 auto var(--space-4);">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" fill="#ef4444"/>
                    </svg>
                </div>
                <h3 style="font-family: var(--ff-primary); font-size: var(--fs-lg); font-weight: 700; color: var(--clr-text); margin: 0 0 var(--space-2);">تأكيد الحذف</h3>
                <p style="font-family: var(--ff-primary); font-size: var(--fs-md); color: var(--clr-text-secondary); margin: 0 0 var(--space-5);">
                    هل أنت متأكد من حذف المستخدم: <strong id="deleteUserName" style="color: var(--clr-text);"></strong>؟
                </p>
                <div style="display: flex; gap: var(--space-2); justify-content: center;">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" style="min-width: 90px; padding: 10px 24px; border-radius: var(--radius-sm); font-size: var(--fs-md); font-weight: 600;">إلغاء</button>
                    <button type="button" id="confirmDeleteBtn" class="btn" style="min-width: 90px; padding: 10px 24px; background-color: var(--clr-danger); color: #FFFFFF; border: none; border-radius: var(--radius-sm); font-size: var(--fs-md); font-weight: 600; cursor: pointer;">حذف</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function() {
            var createModal = new bootstrap.Modal(document.getElementById('createUserModal'));

            document.getElementById('addUserBtn').addEventListener('click', function() {
                document.getElementById('createUserForm').reset();
                createModal.show();
            });

            var deleteForm = document.getElementById('deleteUserForm');
            var deleteIdInput = document.getElementById('deleteUserId');
            var deleteNameEl = document.getElementById('deleteUserName');
            var deleteModal = new bootstrap.Modal(document.getElementById('deleteConfirmModal'));

            document.querySelectorAll('.btn-delete-user').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    deleteIdInput.value = btn.getAttribute('data-id');
                    deleteNameEl.textContent = btn.getAttribute('data-name');
                    deleteModal.show();
                });
            });

            document.getElementById('confirmDeleteBtn').addEventListener('click', function() {
                deleteForm.submit();
            });

            function filterTable() {
                var searchVal = document.getElementById('filterSearch').value.trim().toLowerCase();
                var statusVal = document.getElementById('filterStatus').value;
                var rows = document.querySelectorAll('.custom-table tbody tr');
                rows.forEach(function(row) {
                    var name = row.cells[0].textContent.trim().toLowerCase();
                    var email = row.cells[1].textContent.trim().toLowerCase();
                    var status = row.cells[4].textContent.trim();
                    var matchSearch = !searchVal || name.indexOf(searchVal) !== -1 || email.indexOf(searchVal) !== -1;
                    var matchStatus = !statusVal || status === statusVal;
                    row.style.display = matchSearch && matchStatus ? '' : 'none';
                });
            }

            document.getElementById('filterSearch').addEventListener('input', filterTable);
            document.getElementById('filterStatus').addEventListener('change', filterTable);
        })();
    </script>
}
