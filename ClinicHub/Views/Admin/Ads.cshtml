@{
    ViewData["Title"] = "الإعلانات";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <h2 class="page-title">
        <span class="page-title-icon">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M20 2.01L4 2v2h16V2.01zM4 22h16v-2H4v22zm-2-14h2v8H2V8zm18 0h2v8h-2V8zM9 6c-2.21 0-4 1.79-4 4 0 1.2.54 2.27 1.38 3H7v1c0 1.66 1.34 3 3 3s3-1.34 3-3v-1h.62c.84-.73 1.38-1.8 1.38-3 0-2.21-1.79-4-4-4z" fill="currentColor"/>
            </svg>
        </span>
        إدارة الإعلانات والباقات الدعائية
    </h2>
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#adModal">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
        </svg>
        إضافة إعلان
    </button>
</div>

<!-- Filter Bar -->
<div class="filter-bar">
    <input type="text" class="form-input" placeholder="بحث عن إعلان..." style="min-width: 200px;" />
    <select class="form-select">
        <option value="">جميع الأنواع</option>
        <option value="banner">بانر إعلاني</option>
        <option value="featured_doctor">طبيب مميز</option>
        <option value="featured_clinic">عيادة مميزة</option>
    </select>
    <select class="form-select">
        <option value="">جميع الحالات</option>
        <option value="active">نشط</option>
        <option value="inactive">غير نشط</option>
    </select>
</div>

