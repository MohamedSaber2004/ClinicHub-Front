@{
    ViewData["Title"] = "العيادات";
    Layout = "_DashboardLayout";
}

<div class="page-header">
    <h2 class="page-title">إدارة العيادات</h2>
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#clinicModal">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
        </svg>
        إضافة عيادة
    </button>
</div>

<!-- Filter Bar -->
<div class="filter-bar">
    <input type="text" class="form-input" placeholder="بحث عن عيادة..." style="min-width: 200px;" />
    <select class="form-select">
        <option value="">جميع التخصصات</option>
        <option value="cardio">القلب والأوعية الدموية</option>
        <option value="neuro">الأمراض العصبية</option>
        <option value="ortho">جراحة العظام</option>
    </select>
    <select class="form-select">
        <option value="">جميع الحالات</option>
        <option value="active">نشط</option>
        <option value="inactive">غير نشط</option>
    </select>
</div>

<!-- Clinics Table -->
<div class="table-card">
