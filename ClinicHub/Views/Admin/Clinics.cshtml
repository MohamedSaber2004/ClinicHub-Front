    </div>
</div>

<!-- Add/Edit Clinic Modal -->
<div class="modal fade" id="clinicModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-content-custom">
            <div class="modal-header-custom">
                <h5 class="modal-title">إضافة عيادة جديدة</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="إغلاق"></button>
            </div>
            <div class="modal-body-custom">
                <div class="form-group">
                    <label class="form-label">اسم العيادة</label>
                    <input type="text" class="form-input" placeholder="مثال: عيادة القلب" />
                </div>
                <div class="form-group">
                    <label class="form-label">التخصص</label>
                    <select class="form-select">
                        <option value="">اختر التخصص</option>
                        <option>القلب والأوعية الدموية</option>
                        <option>الأمراض العصبية</option>
                        <option>جراحة العظام</option>
                        <option>طب الأطفال</option>
                        <option>النساء والولادة</option>
                        <option>طب العيون</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">الطبيب المسؤول</label>
                    <select class="form-select">
                        <option value="">اختر الطبيب</option>
                        <option>د. عمار السيد</option>
                        <option>د. سارة أحمد</option>
                        <option>د. خالد الزهراني</option>
                        <option>د. عبد الله ناصر</option>
                    </select>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">الموقع / رقم الغرفة</label>
                            <input type="text" class="form-input" placeholder="مثال: الطابق الثاني - غرفة 201" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">رقم الهاتف</label>
                            <input type="text" class="form-input" placeholder="+966 11 XXX XXXX" />
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-toggle">
                        <input type="checkbox" checked />
                        <span class="toggle-track"></span>
                        <span class="toggle-label">العيادة نشطة</span>
                    </label>
                </div>
            </div>
            <div class="modal-footer-custom">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" class="btn btn-primary">حفظ</button>
            </div>
        </div>
    </div>
</div>
