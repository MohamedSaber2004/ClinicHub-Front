@{
    ViewData["Title"] = "العيادات";
    Layout = "_DashboardLayout";
}

<div class="page-header">
    <h2 class="page-title">
        <span class="page-title-icon">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zm-7-2h2v-4h4v-2h-4V7h-2v4H8v2h4z" fill="currentColor"/>
            </svg>
        </span>
        إدارة العيادات
    </h2>
    <button type="button" id="addClinicBtn" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#clinicModal">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
        </svg>
        إضافة عيادة
    </button>
</div>

<!-- Filter Bar -->
<div class="filter-bar">
    <input type="text" id="filterSearch" class="form-input" placeholder="بحث عن عيادة..." />
    <select id="filterSpecialty" class="form-select">
        <option value="">جميع التخصصات</option>
        <option value="القلب والأوعية الدموية">القلب والأوعية الدموية</option>
        <option value="الأمراض العصبية">الأمراض العصبية</option>
        <option value="جراحة العظام">جراحة العظام</option>
        <option value="الأمراض الجلدية">الأمراض الجلدية</option>
        <option value="طب الأطفال">طب الأطفال</option>
    </select>
    <select id="filterStatus" class="form-select">
        <option value="">جميع الحالات</option>
        <option value="active">نشط</option>
        <option value="inactive">غير نشط</option>
    </select>
</div>

<!-- Clinics Table -->
<div class="table-card">
    <div class="table-responsive">
        <table class="custom-table">
            <thead>
                <tr>
                    <th>اسم العيادة</th>
                    <th>التخصص</th>
                    <th>الطبيب المسؤول</th>
                    <th>الموقع</th>
                    <th>رقم الهاتف</th>
                    <th>الحالة</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var clinics = ViewBag.Clinics as List<MockClinic> ?? new();
                }
                @foreach (var c in clinics)
                {
                    <tr>
                        <td class="text-md-medium">
                            <span class="row-icon">
                                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zm-7-2h2v-4h4v-2h-4V7h-2v4H8v2h4z" fill="currentColor"/>
                                </svg>
                            </span>
                            @c.Name
                        </td>
                        <td class="text-md">@c.Specialty</td>
                        <td class="text-md">@c.ResponsibleDoctor</td>
                        <td class="text-md">@c.Location</td>
                        <td class="text-md">@c.Phone</td>
                        <td>
                            <label class="toggle-switch">
                                <input type="checkbox" class="clinic-toggle-input" @(c.IsActive ? "checked" : "") />
                                <span class="toggle-track-sm"></span>
                            </label>
                        </td>
                        <td>
                            <div class="table-actions">
                                <button class="btn-icon btn-edit-clinic" title="تعديل"
                                        data-id="@c.Id"
                                        data-name="@c.Name"
                                        data-specialty="@c.Specialty"
                                        data-doctor="@c.ResponsibleDoctor"
                                        data-location="@c.Location"
                                        data-phone="@c.Phone"
                                        data-active="@c.IsActive.ToString().ToLower()">
                                    <svg viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/>
                                    </svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Add/Edit Clinic Modal -->
<div class="modal fade" id="clinicModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-content-custom">
            <div class="modal-header-custom">
                <h5 class="modal-title" id="clinicModalTitle">إضافة عيادة جديدة</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="إغلاق"></button>
            </div>
            <div class="modal-body-custom">
                <input type="hidden" id="clinicId" value="" />
                <div class="form-group">
                    <label class="form-label" for="clinicName">اسم العيادة</label>
                    <input type="text" id="clinicName" name="Name" class="form-input" placeholder="مثال: عيادة القلب" />
                </div>
                <div class="form-group">
                    <label class="form-label" for="clinicSpecialty">التخصص</label>
                    <select id="clinicSpecialty" name="Specialty" class="form-select">
                        <option value="">اختر التخصص</option>
                        <option>القلب والأوعية الدموية</option>
                        <option>الأمراض العصبية</option>
                        <option>جراحة العظام</option>
                        <option>الأمراض الجلدية</option>
                        <option>طب الأطفال</option>
                        <option>النساء والولادة</option>
                        <option>طب العيون</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label" for="clinicDoctor">الطبيب المسؤول</label>
                    <select id="clinicDoctor" name="ResponsibleDoctor" class="form-select">
                        <option value="">اختر الطبيب</option>
                        <option>د. عمار السيد</option>
                        <option>د. سارة أحمد</option>
                        <option>د. خالد الزهراني</option>
                        <option>د. عبد الله ناصر</option>
                    </select>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label" for="clinicLocation">الموقع / رقم الغرفة</label>
                            <input type="text" id="clinicLocation" name="Location" class="form-input" placeholder="مثال: الطابق الثاني - غرفة 201" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label" for="clinicPhone">رقم الهاتف</label>
                            <input type="text" id="clinicPhone" name="Phone" class="form-input" placeholder="+966 11 XXX XXXX" />
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-toggle">
                        <input type="checkbox" id="clinicIsActive" name="IsActive" checked />
                        <span class="toggle-track"></span>
                        <span class="toggle-label">العيادة نشطة</span>
                    </label>
                </div>
            </div>
            <div class="modal-footer-custom">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" class="btn btn-primary" id="saveClinicBtn" data-bs-dismiss="modal">حفظ</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function() {
            var modalEl = document.getElementById('clinicModal');
            var titleEl = document.getElementById('clinicModalTitle');
            var idInput = document.getElementById('clinicId');
            var nameInput = document.getElementById('clinicName');
            var specialtyInput = document.getElementById('clinicSpecialty');
            var doctorInput = document.getElementById('clinicDoctor');
            var locationInput = document.getElementById('clinicLocation');
            var phoneInput = document.getElementById('clinicPhone');
            var activeCheck = document.getElementById('clinicIsActive');

            var clinicModal = new bootstrap.Modal(modalEl);

            document.querySelectorAll('.btn-edit-clinic').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    titleEl.textContent = 'تعديل العيادة';
                    idInput.value = btn.getAttribute('data-id');
                    nameInput.value = btn.getAttribute('data-name');
                    specialtyInput.value = btn.getAttribute('data-specialty');
                    doctorInput.value = btn.getAttribute('data-doctor');
                    locationInput.value = btn.getAttribute('data-location');
                    phoneInput.value = btn.getAttribute('data-phone');
                    activeCheck.checked = btn.getAttribute('data-active') === 'true';
                    clinicModal.show();
                });
            });

            document.getElementById('addClinicBtn').addEventListener('click', function() {
                titleEl.textContent = 'إضافة عيادة جديدة';
                idInput.value = '';
                nameInput.value = '';
                specialtyInput.value = '';
                doctorInput.value = '';
                locationInput.value = '';
                phoneInput.value = '';
                activeCheck.checked = true;
            });

            function filterTable() {
                var searchVal = document.getElementById('filterSearch').value.trim().toLowerCase();
                var specialtyVal = document.getElementById('filterSpecialty').value;
                var statusVal = document.getElementById('filterStatus').value;
                var rows = document.querySelectorAll('.custom-table tbody tr');
                rows.forEach(function(row) {
                    var name = row.querySelector('.text-md-medium').textContent.trim().toLowerCase();
                    var spec = row.cells[1].textContent.trim();
                    var isActive = row.querySelector('.clinic-toggle-input').checked;
                    var matchSearch = !searchVal || name.indexOf(searchVal) !== -1;
                    var matchSpecialty = !specialtyVal || spec === specialtyVal;
                    var matchStatus = !statusVal || (statusVal === 'active' && isActive) || (statusVal === 'inactive' && !isActive);
                    row.style.display = matchSearch && matchSpecialty && matchStatus ? '' : 'none';
                });
            }

            document.getElementById('filterSearch').addEventListener('input', filterTable);
            document.getElementById('filterSpecialty').addEventListener('change', filterTable);
            document.getElementById('filterStatus').addEventListener('change', filterTable);
        })();
    </script>
}
