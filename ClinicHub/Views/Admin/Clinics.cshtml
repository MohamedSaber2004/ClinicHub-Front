@{
    ViewData["Title"] = "العيادات";
    Layout = "_AdminLayout";
    var clinics = ViewBag.Clinics as List<MockClinic> ?? new();
}

<div class="page-header">
    <h2 class="page-title">
        <span class="page-title-icon">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zm-7-2h2v-4h4v-2h-4V7h-2v4H8v2h4z" fill="currentColor"/>
            </svg>
        </span>
        إدارة العيادات
    </h2>
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#clinicModal">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
        </svg>
        إضافة عيادة
    </button>
</div>

<!-- Filter Bar -->
<div class="filter-bar">
    <input type="text" id="filterSearch" class="form-input" placeholder="بحث عن عيادة..." />
    <select id="filterStatus" class="form-select">
        <option value="">جميع الحالات</option>
        <option value="active">نشط</option>
        <option value="inactive">غير نشط</option>
    </select>
</div>

<!-- Clinic Cards Grid -->
<div class="clinic-cards-grid" id="clinicCards">
    @foreach (var c in clinics)
    {
        var specs = c.Specializations.Any() ? c.Specializations : new() { c.Specialty };
        var visibleSpecs = specs.Take(3).ToList();
        var overflowCount = specs.Count - 3;
        var doctorCount = MockData.GetClinicDoctors(c.Id).Count;
        var staffCount = MockData.GetClinicStaff(c.Id).Count;
        var rating = MockData.GetClinicAvgRating(c.Id);
        var ratingCount = MockData.GetClinicRatings(c.Id).Count;
        var fullStars = (int)Math.Floor(rating);
        var hasHalf = rating - fullStars >= 0.5;
        var emptyStars = 5 - fullStars - (hasHalf ? 1 : 0);
        <a href="@AdminRoutes.Pages.ClinicDetails(c.Id)" class="clinic-card @(!c.IsActive ? "clinic-card-inactive" : "")">
            <div class="cc-image">
                @if (!string.IsNullOrEmpty(c.ImageUrl)) { <img src="@c.ImageUrl" alt="@c.Name" /> }
                else { <div class="cc-image-placeholder"><svg viewBox="0 0 24 24" fill="var(--clr-primary)"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zm-7-2h2v-4h4v-2h-4V7h-2v4H8v2h4z"/></svg></div> }
                <div class="cc-status-badge">
                    @if (c.IsActive) { <span class="badge badge-success">نشط</span> }
                    else { <span class="badge badge-danger">غير نشط</span> }
                </div>
            </div>
            <div class="cc-body">
                <h3 class="cc-name">@c.Name</h3>
                <p class="cc-desc">@c.Description</p>
                <div class="cc-specs">
                    @for (int i = 0; i < visibleSpecs.Count; i++) { <span class="spec-pill">@visibleSpecs[i]</span> }
                    @if (overflowCount > 0) { <span class="spec-pill spec-pill-overflow">+@overflowCount</span> }
                </div>
                <div class="cc-meta">
                    <div class="cc-meta-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="var(--clr-text-secondary)"><path d="M12 2C9.243 2 7 4.243 7 7v2c0 2.206 1.794 4 4 4v2.184c-2.804.418-4.994 2.617-4.994 5.316V22h2v-1.5c0-2.206 1.794-4 4-4s4 1.794 4 4V22h2v-1.5c0-2.699-2.19-4.898-4.994-5.316V13c2.206 0 4-1.794 4-4V7c0-2.757-2.243-5-5-5z"/></svg><span>@doctorCount طبيب</span></div>
                    <div class="cc-meta-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="var(--clr-text-secondary)"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5s-3 1.34-3 3 1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 2 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg><span>@staffCount موظف</span></div>
                    <div class="cc-meta-item cc-rating">
                        <div class="stars-inline">
                            @for (int i = 0; i < fullStars; i++) { <svg width="12" height="12" viewBox="0 0 24 24" fill="#F59E0B"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg> }
                            @if (hasHalf) { <text>★</text> } @* half star placeholder *@
                            @for (int i = 0; i < emptyStars; i++) { <svg width="12" height="12" viewBox="0 0 24 24" fill="#D2D5DB"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg> }
                        </div>
                        <span>@rating.ToString("F1") (@ratingCount)</span>
                    </div>
                </div>
            </div>
        </a>
    }
</div>

<!-- Add Clinic Modal -->
<div class="modal fade" id="clinicModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content modal-content-custom">
            <div class="modal-header-custom">
                <h5 class="modal-title">إضافة عيادة جديدة</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="إغلاق"></button>
            </div>
            <div class="modal-body-custom">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">اسم العيادة</label>
                            <input type="text" class="form-input" placeholder="مثال: مركز القلب التخصصي" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">التخصص الرئيسي</label>
                            <select class="form-select">
                                <option value="">اختر التخصص</option>
                                <option>القلب والأوعية الدموية</option>
                                <option>الأمراض العصبية</option>
                                <option>جراحة العظام</option>
                                <option>الأمراض الجلدية</option>
                                <option>طب الأطفال</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">وصف العيادة</label>
                    <textarea class="form-input form-textarea" rows="2" placeholder="وصف مختصر عن العيادة"></textarea>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">الموقع (الغرفة)</label>
                            <input type="text" class="form-input" id="clinicLocation" placeholder="الطابق - الغرفة" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">رقم الهاتف</label>
                            <input type="text" class="form-input" placeholder="+966 11 XXX XXXX" />
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">الموقع على الخريطة</label>
                    <input type="hidden" id="clinicLat" value="31.0409" />
                    <input type="hidden" id="clinicLng" value="31.3785" />
                    <div id="addClinicMap" style="height: 280px; border-radius: var(--radius-md); border: 1px solid var(--clr-border); margin-bottom: 8px;"></div>
                    <div style="display: flex; gap: 8px; align-items: center;">
                        <button type="button" class="btn btn-sm btn-outline-primary" id="myLocationBtn" style="display: inline-flex; align-items: center; gap: 4px;">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 8c-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4-1.79-4-4-4zm8.94 3A8.994 8.994 0 0 0 13 3.06V1h-2v2.06A8.994 8.994 0 0 0 3.06 11H1v2h2.06A8.994 8.994 0 0 0 11 20.94V23h2v-2.06A8.994 8.994 0 0 0 20.94 13H23v-2h-2.06zM12 19c-3.87 0-7-3.13-7-7s3.13-7 7-7 7 3.13 7 7-3.13 7-7 7z"/></svg>
                            موقعي الحالي
                        </button>
                        <span class="text-muted" style="font-size: var(--fs-sm);" id="coordsDisplay">31.0409, 31.3785</span>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">مدير العيادة</label>
                            <input type="text" class="form-input" placeholder="اسم المدير" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">صورة العيادة</label>
                            <input type="file" class="form-input" accept="image/*" />
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-toggle">
                        <input type="checkbox" checked />
                        <span class="toggle-track"></span>
                        <span class="toggle-label">العيادة نشطة</span>
                    </label>
                </div>
            </div>
            <div class="modal-footer-custom">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">حفظ</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function() {
            function filterCards() {
                var searchVal = document.getElementById('filterSearch').value.trim().toLowerCase();
                var statusVal = document.getElementById('filterStatus').value;
                var cards = document.querySelectorAll('.clinic-card');
                cards.forEach(function(card) {
                    var name = card.querySelector('.cc-name').textContent.trim().toLowerCase();
                    var isActive = !card.classList.contains('clinic-card-inactive');
                    var matchSearch = !searchVal || name.indexOf(searchVal) !== -1;
                    var matchStatus = !statusVal || (statusVal === 'active' && isActive) || (statusVal === 'inactive' && !isActive);
                    card.style.display = matchSearch && matchStatus ? '' : 'none';
                });
            }

            document.getElementById('filterSearch').addEventListener('input', filterCards);
            document.getElementById('filterStatus').addEventListener('change', filterCards);

            // Map for Add Clinic modal
            var addMap = L.map('addClinicMap').setView([31.0409, 31.3785], 13);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap',
                maxZoom: 18
            }).addTo(addMap);

            var addMarker = L.marker([31.0409, 31.3785], { draggable: false }).addTo(addMap);

            function updateAddCoords(lat, lng) {
                document.getElementById('clinicLat').value = lat.toFixed(6);
                document.getElementById('clinicLng').value = lng.toFixed(6);
                document.getElementById('coordsDisplay').textContent = lat.toFixed(4) + ', ' + lng.toFixed(4);
            }

            addMap.on('click', function(e) {
                addMarker.setLatLng(e.latlng);
                updateAddCoords(e.latlng.lat, e.latlng.lng);
            });

            document.getElementById('myLocationBtn').addEventListener('click', function() {
                if (!navigator.geolocation) {
                    alert('الموقع غير مدعوم في متصفحك.');
                    return;
                }
                navigator.geolocation.getCurrentPosition(function(pos) {
                    var lat = pos.coords.latitude;
                    var lng = pos.coords.longitude;
                    addMap.setView([lat, lng], 15);
                    addMarker.setLatLng([lat, lng]);
                    updateAddCoords(lat, lng);
                }, function() {
                    alert('لم نتمكن من الوصول إلى موقعك. يرجى التحقق من صلاحيات الموقع.');
                });
            });

            // Fix map rendering inside modal
            document.getElementById('clinicModal').addEventListener('shown.bs.modal', function() {
                addMap.invalidateSize();
            });
        })();
    </script>
}
