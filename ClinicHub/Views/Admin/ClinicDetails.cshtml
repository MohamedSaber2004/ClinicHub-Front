                        <input type="checkbox" @(clinic.IsActive ? "checked" : "") />
                        <span class="toggle-track"></span>
                        <span class="toggle-label">العيادة نشطة</span>
                    </label>
                </div>
                <button type="button" class="btn btn-primary">حفظ الإعدادات</button>
            </div>
        </div>
    </div>
</div>

