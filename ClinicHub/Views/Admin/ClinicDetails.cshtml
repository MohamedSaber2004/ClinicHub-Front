                            <option>طب الرياضة</option>
                            <option>الأمراض الجلدية</option>
                            <option>جراحة التجميل</option>
                            <option>الليزر والعناية بالبشرة</option>
                            <option>طب الأطفال</option>
                            <option>حديثي الولادة</option>
                        </select>
                    </div>
                </div>
                <div class="form-group">
