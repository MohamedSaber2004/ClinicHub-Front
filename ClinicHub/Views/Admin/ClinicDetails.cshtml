@section Scripts {
    <script>
        (function() {
            // Config data from server
            var configData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(doctors));

            // Toggle doctor config expansion
            window.toggleConfig = function(btn) {
                var body = btn.closest('.dcc-header').nextElementSibling;
                var isOpen = body.style.display !== 'none';
                body.style.display = isOpen ? 'none' : 'block';
                btn.querySelector('svg').style.transform = isOpen ? '' : 'rotate(180deg)';
            };

            // Open config modal
            window.openConfigModal = function(doctorId) {
                var doc = configData.find(function(d) { return d.DoctorId === doctorId; });
                if (!doc) return;
                document.getElementById('configDoctorId').value = doc.DoctorId;
                document.getElementById('configDoctorName').textContent = 'إعدادات: ' + doc.DoctorName;
                document.getElementById('cfgFeeExam').value = doc.ExaminationFee;
                document.getElementById('cfgFeeFollow').value = doc.FollowUpFee;
                document.getElementById('cfgCommPct').value = doc.CommissionPercent;
                document.getElementById('cfgCommFixed').value = doc.CommissionFixed;
                document.getElementById('cfgRoom').value = doc.RoomAssignment;
                document.getElementById('cfgContract').value = doc.ContractType;
                document.getElementById('cfgContractStart').value = doc.ContractStart;
                document.getElementById('cfgContractEnd').value = doc.ContractEnd || '';
                document.getElementById('cfgSessionLimit').value = doc.SessionLimitPerDay;

                var tbody = document.getElementById('configDaysBody');
                tbody.innerHTML = '';
                var days = doc.WorkingDays || [];
                var dayNames = { 'Sunday': 'الأحد','Monday': 'الإثنين','Tuesday': 'الثلاثاء','Wednesday': 'الأربعاء','Thursday': 'الخميس','Friday': 'الجمعة','Saturday': 'السبت' };
                days.forEach(function(wd, idx) {
                    var tr = document.createElement('tr');
                    tr.className = wd.IsAvailable ? '' : 'wh-unavailable';
                    tr.innerHTML = '<td>' + wd.DayAr + '</td>' +
                        '<td><input type="checkbox" class="cfg-day-chk" data-idx="' + idx + '" ' + (wd.IsAvailable ? 'checked' : '') + ' /></td>' +
                        '<td><input type="time" class="cfg-day-start form-input" data-idx="' + idx + '" value="' + wd.StartTime + '" style="width:100px" /></td>' +
                        '<td><input type="time" class="cfg-day-end form-input" data-idx="' + idx + '" value="' + wd.EndTime + '" style="width:100px" /></td>';
                    tbody.appendChild(tr);
                });

                var modal = new bootstrap.Modal(document.getElementById('doctorConfigModal'));
                modal.show();
            };

            // Staff modals
            var cstaffModal = new bootstrap.Modal(document.getElementById('clinicStaffModal'));
            var deleteCstaffModal = new bootstrap.Modal(document.getElementById('deleteCstaffModal'));

            document.querySelectorAll('.btn-edit-cstaff').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    document.getElementById('cstaffModalTitle').textContent = 'تعديل موظف';
                    document.getElementById('cstaffId').value = btn.getAttribute('data-id');
                    document.getElementById('cstaffName').value = btn.getAttribute('data-name');
                    document.getElementById('cstaffRole').value = btn.getAttribute('data-role');
                    document.getElementById('cstaffPhone').value = btn.getAttribute('data-phone');
                    document.getElementById('cstaffActive').checked = btn.getAttribute('data-active') === 'true';
                    cstaffModal.show();
                });
            });

            document.querySelectorAll('.btn-delete-cstaff').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    document.getElementById('deleteCstaffMsg').textContent = 'حذف "' + btn.getAttribute('data-name') + '"؟';
                    deleteCstaffModal.show();
                });
            });

            document.getElementById('saveCstaffBtn').addEventListener('click', function() { alert('تم حفظ الموظف.'); });
            document.getElementById('confirmDeleteCstaff').addEventListener('click', function() { alert('تم حذف الموظف.'); });
        })();
    </script>
}
