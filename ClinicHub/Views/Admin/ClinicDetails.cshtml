                        {
                            <span class="spec-pill">@s <button type="button" class="spec-pill-remove" onclick="this.parentElement.remove()">&times;</button></span>
                        }
                        <select class="form-select" style="width:auto;display:inline-block;min-width:140px" onchange="if(this.value){var p=document.createElement('span');p.className='spec-pill';p.innerHTML=this.value+' <button type=\\\"button\\\" class=\\\"spec-pill-remove\\\" onclick=\\\"this.parentElement.remove()\\\">&times;</button>';this.parentElement.insertBefore(p,this);this.value=''}">
                            <option value="">+ إضافة تخصص</option>
                            <option>القلب والأوعية الدموية</option>
                            <option>جراحة القلب</option>
                            <option>قسطرة القلب</option>
                            <option>الأمراض العصبية</option>
