@{
    ViewData["Title"] = "تفاصيل العيادة";
    Layout = "_AdminLayout";
    var clinic = ViewBag.Clinic as ClinicManagmentDto;
}

@if (clinic == null)
{
    <div class="empty-state">
        <h3>العيادة غير موجودة</h3>
        <a href="@AdminRoutes.Pages.Clinics()" class="btn btn-primary">العودة</a>
    </div>
    return;
}

@{
    var clinicName = clinic.NameAr ?? clinic.Name;
    var clinicSpec = clinic.SpecializationNameAr ?? clinic.SpecializationName;
    var clinicDesc = clinic.ArDescription ?? clinic.Description;
    var hasRating = clinic.Rating.HasValue;
    var avgRating = hasRating ? clinic.Rating!.Value : 0;
    var fullStars = (int)Math.Floor(avgRating);
    var hasHalf = hasRating && avgRating - fullStars >= 0.5;
    var emptyStars = 5 - fullStars - (hasHalf ? 1 : 0);
}

<!-- Clinic Header -->
<div class="clinic-detail-header">
    <div class="cdh-image">
        @if (!string.IsNullOrEmpty(clinic.Logo))
        {
            <img src="@clinic.Logo" alt="@clinicName" />
        }
        else
        {
            <div class="cdh-image-placeholder">
                <svg viewBox="0 0 24 24" fill="var(--clr-primary)">
                    <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zm-7-2h2v-4h4v-2h-4V7h-2v4H8v2h4z"/>
                </svg>
            </div>
        }
    </div>
    <div class="cdh-info">
        <h2 class="cdh-name">@clinicName</h2>
        @if (!string.IsNullOrEmpty(clinicSpec))
        {
            <div class="cdh-specs">
                <span class="spec-pill">@clinicSpec</span>
            </div>
        }
        <div class="cdh-meta">
            <div class="cdh-rating">
                <div class="stars-inline">
                    @for (int i = 0; i < fullStars; i++) { <svg width="14" height="14" viewBox="0 0 24 24" fill="#F59E0B"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg> }
                    @if (hasHalf) { <svg width="14" height="14" viewBox="0 0 24 24"><defs><clipPath id="h"><rect x="0" y="0" width="7" height="24"/></clipPath></defs><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" fill="#F59E0B" clip-path="url(#h)"/><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" fill="#D2D5DB" clip-path="url(#h)"/></svg> }
                    @for (int i = 0; i < emptyStars; i++) { <svg width="14" height="14" viewBox="0 0 24 24" fill="#D2D5DB"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg> }
                </div>
                <span>@avgRating.ToString("F1")</span>
            </div>
            <span class="cdh-status">
                @if (clinic.IsActive) { <span class="badge badge-success">نشط</span> }
                else { <span class="badge badge-danger">غير نشط</span> }
            </span>
        </div>
        @if (!string.IsNullOrEmpty(clinicDesc))
        {
            <p class="cdh-desc">@clinicDesc</p>
        }
        <div class="cdh-contact">
            <span>@(clinic.AddressAr ?? clinic.Address)</span>
            <span>@clinic.Phone</span>
            <span>@clinic.Email</span>
            <span>المدير: @clinic.OwnerName</span>
            <span>البريد: @clinic.OwnerEmail</span>
        </div>
    </div>
    <div class="cdh-actions">
        <a href="@AdminRoutes.Pages.Clinics()" class="btn btn-outline-secondary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
            العودة
        </a>
    </div>
</div>

<!-- Tabs -->
<div class="detail-tabs mt-3">
    <ul class="nav nav-tabs" id="clinicTabs" role="tablist">
        <li class="nav-item"><button class="nav-link active" id="ov-tab" data-bs-toggle="tab" data-bs-target="#ov" type="button" role="tab">نظرة عامة</button></li>
        <li class="nav-item"><button class="nav-link" id="docs-tab" data-bs-toggle="tab" data-bs-target="#docs" type="button" role="tab">الأطباء</button></li>
        <li class="nav-item"><button class="nav-link" id="stf-tab" data-bs-toggle="tab" data-bs-target="#stf" type="button" role="tab">الموظفين</button></li>
        <li class="nav-item"><button class="nav-link" id="ratings-tab" data-bs-toggle="tab" data-bs-target="#ratings" type="button" role="tab">التقييمات</button></li>
    </ul>
    <div class="tab-content" id="clinicTabContent">

        <!-- ======== OVERVIEW TAB ======== -->
        <div class="tab-pane fade show active" id="ov" role="tabpanel">
            <div class="clinic-stats-row">
                <div class="clinic-stat-card">
                    <span class="clinic-stat-value">@avgRating.ToString("F1")</span>
                    <span class="clinic-stat-label">متوسط التقييم</span>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(clinicDesc))
            {
                <div class="detail-card">
                    <div class="detail-section-header"><h5>الوصف</h5></div>
                    <p>@clinicDesc</p>
                </div>
            }
            <div class="detail-card">
                <div class="detail-section-header"><h5>الموقع</h5></div>
                <p class="text-muted" style="margin-bottom: var(--space-3);">
                    @(clinic.AddressAr ?? clinic.Address)
                </p>
                <input type="hidden" id="clinicDetailLat" value="@(clinic.Lat?.ToString("F6", System.Globalization.CultureInfo.InvariantCulture) ?? "31.0409")" />
                <input type="hidden" id="clinicDetailLng" value="@(clinic.Lng?.ToString("F6", System.Globalization.CultureInfo.InvariantCulture) ?? "31.3785")" />
                <div id="clinicDetailMap" style="height: 300px; border-radius: var(--radius-md); border: 1px solid var(--clr-border);"></div>
            </div>
            @if (clinic.WorkingDays != null && clinic.WorkingDays.Any())
            {
                <div class="detail-card">
                    <div class="detail-section-header"><h5>أيام ومواعيد العمل</h5></div>
                    <div class="wh-table">
                        <table>
                            <thead>
                                <tr>
                                    <th>اليوم</th>
                                    <th>بداية</th>
                                    <th>نهاية</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var wd in clinic.WorkingDays)
                                {
                                    <tr>
                                        <td>@wd.DayOfWeek</td>
                                        <td>@wd.StartTime.ToString("h:mm tt", new System.Globalization.CultureInfo("ar-SA"))</td>
                                        <td>@wd.EndTime.ToString("h:mm tt", new System.Globalization.CultureInfo("ar-SA"))</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
            <div class="detail-card">
                <div class="detail-section-header"><h5>معلومات العيادة</h5></div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">اسم العيادة</label>
                            <input type="text" class="form-input" value="@clinicName" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">التخصص الرئيسي</label>
                            <input type="text" class="form-input" value="@clinicSpec" readonly />
                        </div>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(clinicDesc))
                {
                    <div class="form-group">
                        <label class="form-label">الوصف</label>
                        <textarea class="form-input form-textarea" rows="2">@clinicDesc</textarea>
                    </div>
                }
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label">العنوان</label>
                            <input type="text" class="form-input" value="@(clinic.AddressAr ?? clinic.Address)" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label">رقم الهاتف</label>
                            <input type="text" class="form-input" value="@clinic.Phone" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label">مدير العيادة</label>
                            <input type="text" class="form-input" value="@clinic.OwnerName" />
                        </div>
                    </div>
                </div>
                
            </div>
        </div>

        <!-- ======== DOCTORS TAB ======== -->
        <div class="tab-pane fade" id="docs" role="tabpanel">
            <div class="empty-state"><p>لا يوجد أطباء في هذه العيادة بعد.</p></div>
        </div>

        <!-- ======== STAFF TAB ======== -->
        <div class="tab-pane fade" id="stf" role="tabpanel">
            <div class="empty-state"><p>لا يوجد موظفين.</p></div>
        </div>

        <!-- ======== RATINGS TAB ======== -->
        <div class="tab-pane fade" id="ratings" role="tabpanel">
            <div class="empty-state"><p>لا توجد تقييمات بعد.</p></div>
        </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="https://maps.googleapis.com/maps/api/js?key=@ViewBag.GoogleMapsApiKey&callback=initClinicMap" async defer></script>
    <script>
        function initClinicMap() {
            var lat = parseFloat(document.getElementById('clinicDetailLat').value) || 31.0409;
            var lng = parseFloat(document.getElementById('clinicDetailLng').value) || 31.3785;
            var pos = { lat: lat, lng: lng };
            var map = new google.maps.Map(document.getElementById('clinicDetailMap'), {
                center: pos,
                zoom: 15,
                mapTypeControl: false,
                streetViewControl: false,
                fullscreenControl: false
            });
            var marker = new google.maps.Marker({
                position: pos,
                map: map,
                title: '@Html.Raw(clinicName.Replace("'", "\\'"))'
            });
            var info = new google.maps.InfoWindow({
                content: '<strong>@Html.Raw(clinicName.Replace("'", "\\'"))</strong><br/>@Html.Raw((clinic.AddressAr ?? clinic.Address ?? "").Replace("'", "\\'"))'
            });
            marker.addListener('click', function() { info.open(map, marker); });
            info.open(map, marker);
        }
    </script>
}
