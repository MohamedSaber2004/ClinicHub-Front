@{
    ViewData["Title"] = "تفاصيل العيادة";
    Layout = "_AdminLayout";
    var clinic = ViewBag.Clinic as ClinicManagmentDto;
}

<style>
    .edit-field { display: none; }
    .edit-mode .edit-field { display: block; }
    .edit-mode .view-field { display: none; }
    .form-actions { margin-top: var(--space-4); display: flex; gap: var(--space-2); }
    .working-days-checkboxes { display: flex; flex-wrap: wrap; gap: var(--space-2); }
    .working-days-checkboxes .checkbox-inline { display: flex; align-items: center; gap: 4px; font-size: var(--fs-sm); cursor: pointer; }
    .working-days-checkboxes .checkbox-inline input { width: auto; }
</style>

@if (clinic == null)
{
    <div class="empty-state">
        <h3>العيادة غير موجودة</h3>
        <a href="@AdminRoutes.Pages.Clinics()" class="btn btn-primary">العودة</a>
    </div>
    return;
}

@{
    var clinicName = clinic.NameAr ?? clinic.Name;
    var clinicSpec = clinic.SpecializationNameAr ?? clinic.SpecializationName;
    var clinicDesc = clinic.ArDescription ?? clinic.Description;
    var hasRating = clinic.Rating.HasValue;
    var avgRating = hasRating ? clinic.Rating!.Value : 0;
    var fullStars = (int)Math.Floor(avgRating);
    var hasHalf = hasRating && avgRating - fullStars >= 0.5;
    var emptyStars = 5 - fullStars - (hasHalf ? 1 : 0);
}

<!-- Clinic Header -->
<div class="clinic-detail-header">
    <div class="cdh-image">
        @if (!string.IsNullOrEmpty(clinic.Logo))
        {
            <img src="@clinic.Logo" alt="@clinicName" />
        }
        else
        {
            <div class="cdh-image-placeholder">
                <svg viewBox="0 0 24 24" fill="var(--clr-primary)">
                    <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zm-7-2h2v-4h4v-2h-4V7h-2v4H8v2h4z"/>
                </svg>
            </div>
        }
    </div>
    <div class="cdh-info">
        <h2 class="cdh-name">@clinicName</h2>
        @if (!string.IsNullOrEmpty(clinicSpec))
        {
            <div class="cdh-specs">
                <span class="spec-pill">@clinicSpec</span>
            </div>
        }
        <div class="cdh-meta">
            <div class="cdh-rating">
                <div class="stars-inline">
                    @for (int i = 0; i < fullStars; i++) { <svg width="14" height="14" viewBox="0 0 24 24" fill="#F59E0B"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg> }
                    @if (hasHalf) { <svg width="14" height="14" viewBox="0 0 24 24"><defs><clipPath id="h"><rect x="0" y="0" width="7" height="24"/></clipPath></defs><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" fill="#F59E0B" clip-path="url(#h)"/><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" fill="#D2D5DB" clip-path="url(#h)"/></svg> }
                    @for (int i = 0; i < emptyStars; i++) { <svg width="14" height="14" viewBox="0 0 24 24" fill="#D2D5DB"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg> }
                </div>
                <span>@avgRating.ToString("F1")</span>
            </div>
            <span class="cdh-status">
                @if (clinic.IsActive) { <span class="badge badge-success">نشط</span> }
                else { <span class="badge badge-danger">غير نشط</span> }
            </span>
        </div>
        @if (!string.IsNullOrEmpty(clinicDesc))
        {
            <p class="cdh-desc">@clinicDesc</p>
        }
        <div class="cdh-contact">
            <span>@(clinic.AddressAr ?? clinic.Address)</span>
            <span>@clinic.Phone</span>
            <span>@clinic.Email</span>
            <span>المدير: @clinic.OwnerName</span>
            <span>البريد: @clinic.OwnerEmail</span>
        </div>
    </div>
    <div class="cdh-actions">
        <a href="@AdminRoutes.Pages.Clinics()" class="btn btn-outline-secondary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
            العودة
        </a>
        <button id="editClinicBtn" class="btn btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg>
            تعديل
        </button>
        <button id="cancelEditBtn" class="btn btn-outline-secondary" style="display:none">
            إلغاء
        </button>
        <button id="saveClinicBtn" class="btn btn-success" style="display:none">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            حفظ التغييرات
        </button>
        <button id="toggleClinicStatusBtn" class="btn @(clinic.IsActive ? "btn-outline-danger" : "btn-outline-success")" data-clinic-id="@clinic.Id" data-is-active="@clinic.IsActive.ToString().ToLower()">
            @if (clinic.IsActive)
            {
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
                <span>إلغاء التفعيل</span>
            }
            else
            {
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                <span>تفعيل</span>
            }
        </button>
    </div>
</div>

<!-- Tabs -->
<div class="detail-tabs mt-3">
    <ul class="nav nav-tabs" id="clinicTabs" role="tablist">
        <li class="nav-item"><button class="nav-link active" id="ov-tab" data-bs-toggle="tab" data-bs-target="#ov" type="button" role="tab">نظرة عامة</button></li>
        <li class="nav-item"><button class="nav-link" id="docs-tab" data-bs-toggle="tab" data-bs-target="#docs" type="button" role="tab">الأطباء</button></li>
        <li class="nav-item"><button class="nav-link" id="stf-tab" data-bs-toggle="tab" data-bs-target="#stf" type="button" role="tab">الموظفين</button></li>
        <li class="nav-item"><button class="nav-link" id="ratings-tab" data-bs-toggle="tab" data-bs-target="#ratings" type="button" role="tab">التقييمات</button></li>
    </ul>
    <div class="tab-content" id="clinicTabContent">

        <!-- ======== OVERVIEW TAB ======== -->
        <div class="tab-pane fade show active" id="ov" role="tabpanel">
            <div class="clinic-stats-row">
                <div class="clinic-stat-card">
                    <span class="clinic-stat-value">@avgRating.ToString("F1")</span>
                    <span class="clinic-stat-label">متوسط التقييم</span>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(clinicDesc))
            {
                <div class="detail-card">
                    <div class="detail-section-header"><h5>الوصف</h5></div>
                    <p>@clinicDesc</p>
                </div>
            }
            <div class="detail-card">
                <div class="detail-section-header"><h5>الموقع</h5></div>
                <p class="text-muted" style="margin-bottom: var(--space-3);">
                    @(clinic.AddressAr ?? clinic.Address)
                </p>
                <input type="hidden" id="clinicDetailLat" value="@(clinic.Lat?.ToString("F6", System.Globalization.CultureInfo.InvariantCulture) ?? "31.0409")" />
                <input type="hidden" id="clinicDetailLng" value="@(clinic.Lng?.ToString("F6", System.Globalization.CultureInfo.InvariantCulture) ?? "31.3785")" />
                <div id="clinicDetailMap" style="height: 300px; border-radius: var(--radius-md); border: 1px solid var(--clr-border);"></div>
            </div>
            @if (clinic.WorkingDays != null && clinic.WorkingDays.Any())
            {
                <div class="detail-card">
                    <div class="detail-section-header"><h5>أيام ومواعيد العمل</h5></div>
                    <div class="wh-table">
                        <table>
                            <thead>
                                <tr>
                                    <th>اليوم</th>
                                    <th>بداية</th>
                                    <th>نهاية</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var wd in clinic.WorkingDays)
                                {
                                    <tr>
                                        <td>@wd.DayOfWeek</td>
                                        <td>@wd.StartTime.ToString("h:mm tt", new System.Globalization.CultureInfo("ar-SA"))</td>
                                        <td>@wd.EndTime.ToString("h:mm tt", new System.Globalization.CultureInfo("ar-SA"))</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
            <form id="updateClinicForm">
            <div class="detail-card">
                <div class="detail-section-header"><h5>معلومات العيادة</h5></div>
                <div id="updateClinicErrors" class="validation-summary" style="display:none"></div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">اسم العيادة (عربي)</label>
                            <input type="text" name="nameAr" class="form-input" value="@clinic.NameAr" disabled />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">اسم العيادة (إنجليزي)</label>
                            <input type="text" name="name" class="form-input" value="@clinic.Name" disabled />
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">التخصص الرئيسي</label>
                            <select name="specializationId" class="form-select" disabled>
                                <option value="">اختر التخصص</option>
                                @if (ViewBag.Specializations != null)
                                {
                                    foreach (var s in ViewBag.Specializations)
                                    {
                                        <option value="@s.Id" selected="@(s.Id == clinic.SpecializationId ? true : null)">@(s.ArName ?? s.Name)</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">البريد الإلكتروني</label>
                            <input type="email" name="email" class="form-input" value="@clinic.Email" disabled />
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">الوصف (عربي)</label>
                            <textarea name="arDescription" class="form-input form-textarea" rows="2" disabled>@clinic.ArDescription</textarea>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">الوصف (إنجليزي)</label>
                            <textarea name="description" class="form-input form-textarea" rows="2" disabled>@clinic.Description</textarea>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label">العنوان (عربي)</label>
                            <input type="text" name="addressAr" class="form-input" value="@clinic.AddressAr" disabled />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label">العنوان (إنجليزي)</label>
                            <input type="text" name="address" class="form-input" value="@clinic.Address" disabled />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label">رقم الهاتف</label>
                            <input type="text" name="phone" class="form-input" value="@clinic.Phone" disabled />
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">الموقع الإلكتروني</label>
                            <input type="url" name="website" class="form-input" value="@clinic.Website" disabled />
                        </div>
                    </div>
                    <div class="col-md-6 edit-field">
                        <div class="form-group">
                            <label class="form-label">مواعيد العمل (نص)</label>
                            <input type="text" name="workingHours" class="form-input" value="@clinic.WorkingHours" placeholder="مثال: 9:00 ص - 5:00 م" disabled />
                        </div>
                    </div>
                </div>
                <div class="row edit-field">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label">وقت البدء</label>
                            <input type="time" name="workingHoursStart" class="form-input" value="@(clinic.WorkingDays?.FirstOrDefault()?.StartTime.ToString("HH:mm"))" disabled />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label">وقت الانتهاء</label>
                            <input type="time" name="workingHoursEnd" class="form-input" value="@(clinic.WorkingDays?.FirstOrDefault()?.EndTime.ToString("HH:mm"))" disabled />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label">أيام العمل</label>
                            <div class="working-days-checkboxes">
                                @{
                                    var workingDayNames = new Dictionary<DayOfWeek, string>
                                    {
                                        { DayOfWeek.Saturday, "السبت" },
                                        { DayOfWeek.Sunday, "الأحد" },
                                        { DayOfWeek.Monday, "الإثنين" },
                                        { DayOfWeek.Tuesday, "الثلاثاء" },
                                        { DayOfWeek.Wednesday, "الأربعاء" },
                                        { DayOfWeek.Thursday, "الخميس" },
                                        { DayOfWeek.Friday, "الجمعة" }
                                    };
                                    var existingDays = clinic.WorkingDays?.Select(d => d.DayOfWeek).ToList() ?? new List<string>();
                                }
                                @foreach (var day in workingDayNames)
                                {
                                    <label class="checkbox-inline">
                                        <input type="checkbox" name="workingDays" value="@((int)day.Key)" @(existingDays.Contains(day.Key.ToString()) ? "checked" : "") disabled />
                                        @day.Value
                                    </label>
                                }
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">شعار العيادة</label>
                            <div id="editClinicLogoPreview" class="upload-preview" style="margin-bottom:var(--space-2)">
                                @if (!string.IsNullOrEmpty(clinic.Logo))
                                {
                                    <img id="editClinicLogoImg" src="@clinic.Logo" alt="شعار العيادة" style="max-width:200px;max-height:120px;border-radius:var(--radius-md);border:1px solid var(--clr-border);" />
                                }
                                else
                                {
                                    <img id="editClinicLogoImg" src="" alt="شعار العيادة" style="max-width:200px;max-height:120px;border-radius:var(--radius-md);border:1px solid var(--clr-border);display:none;" />
                                }
                                <span id="editClinicLogoStatus" style="font-size:var(--fs-sm);color:var(--clr-text-secondary);display:block;margin-top:var(--space-1);"></span>
                            </div>
                            <input type="file" id="editClinicLogoInput" class="form-input edit-field" accept="image/*" disabled />
                            <input type="hidden" name="logo" value="@clinic.Logo" />
                        </div>
                    </div>
                </div>
            </div>
            </form>
        </div>

        <!-- ======== DOCTORS TAB ======== -->
        <div class="tab-pane fade" id="docs" role="tabpanel">
            <div class="empty-state"><p>لا يوجد أطباء في هذه العيادة بعد.</p></div>
        </div>

        <!-- ======== STAFF TAB ======== -->
        <div class="tab-pane fade" id="stf" role="tabpanel">
            <div class="empty-state"><p>لا يوجد موظفين.</p></div>
        </div>

        <!-- ======== RATINGS TAB ======== -->
        <div class="tab-pane fade" id="ratings" role="tabpanel">
            <div class="empty-state"><p>لا توجد تقييمات بعد.</p></div>
        </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="https://maps.googleapis.com/maps/api/js?key=@ViewBag.GoogleMapsApiKey&callback=initClinicMap" async defer></script>
    <script>
        function initClinicMap() {
            var lat = parseFloat(document.getElementById('clinicDetailLat').value) || 31.0409;
            var lng = parseFloat(document.getElementById('clinicDetailLng').value) || 31.3785;
            var pos = { lat: lat, lng: lng };
            var map = new google.maps.Map(document.getElementById('clinicDetailMap'), {
                center: pos,
                zoom: 15,
                mapTypeControl: false,
                streetViewControl: false,
                fullscreenControl: false
            });
            var marker = new google.maps.Marker({
                position: pos,
                map: map,
                title: '@Html.Raw(clinicName.Replace("'", "\\'"))'
            });
            var info = new google.maps.InfoWindow({
                content: '<strong>@Html.Raw(clinicName.Replace("'", "\\'"))</strong><br/>@Html.Raw((clinic.AddressAr ?? clinic.Address ?? "").Replace("'", "\\'"))'
            });
            marker.addListener('click', function() { info.open(map, marker); });
            info.open(map, marker);
        }

        (function() {
            var csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') || '';
            var editMode = false;
            var editBtn = document.getElementById('editClinicBtn');
            var cancelBtn = document.getElementById('cancelEditBtn');
            var saveBtn = document.getElementById('saveClinicBtn');
            var form = document.getElementById('updateClinicForm');
            var detailHeader = document.querySelector('.clinic-detail-header');
            var container = detailHeader ? detailHeader.parentNode : document.body;

            function toggleEditMode(enable) {
                editMode = enable;
                var inputs = form.querySelectorAll('input:not([type="hidden"]):not([name="email"]), select, textarea');
                if (enable) {
                    container.classList.add('edit-mode');
                    editBtn.style.display = 'none';
                    cancelBtn.style.display = 'inline-flex';
                    saveBtn.style.display = 'inline-flex';
                    inputs.forEach(function(el) { el.removeAttribute('disabled'); });
                } else {
                    container.classList.remove('edit-mode');
                    editBtn.style.display = 'inline-flex';
                    cancelBtn.style.display = 'none';
                    saveBtn.style.display = 'none';
                    inputs.forEach(function(el) { el.setAttribute('disabled', 'disabled'); });
                }
            }

            function clearErrors() {
                var summary = document.getElementById('updateClinicErrors');
                if (summary) { summary.style.display = 'none'; summary.innerHTML = ''; }
            }

            function showErrors(msg) {
                var summary = document.getElementById('updateClinicErrors');
                if (summary) { summary.innerHTML = msg; summary.style.display = 'block'; }
            }

            editBtn.addEventListener('click', function() { toggleEditMode(true); });

            function cancelEdit() {
                toggleEditMode(false);
                clearErrors();
                location.reload();
            }

            cancelBtn.addEventListener('click', cancelEdit);

            var logoInput = document.getElementById('editClinicLogoInput');
            logoInput.addEventListener('change', function() {
                var file = this.files && this.files[0];
                var preview = document.getElementById('editClinicLogoPreview');
                var img = document.getElementById('editClinicLogoImg');
                var status = document.getElementById('editClinicLogoStatus');
                if (file) {
                    var reader = new FileReader();
                    reader.onload = function(e) {
                        img.src = e.target.result;
                        img.style.display = 'block';
                        status.textContent = file.name + ' - جاري التحميل...';
                    };
                    reader.readAsDataURL(file);
                }
            });

            function formatTime(val) {
                if (!val) return null;
                return val.indexOf(':') >= 0 && val.split(':').length === 2 ? val + ':00' : val;
            }

            function buildPayload(logoUrl) {
                var specId = form.querySelector('[name="specializationId"]').value;
                var whStart = formatTime(form.querySelector('[name="workingHoursStart"]').value);
                var whEnd = formatTime(form.querySelector('[name="workingHoursEnd"]').value);
                var data = {
                    nameAr: form.querySelector('[name="nameAr"]').value,
                    name: form.querySelector('[name="name"]').value,
                    arDescription: form.querySelector('[name="arDescription"]').value,
                    description: form.querySelector('[name="description"]').value,
                    addressAr: form.querySelector('[name="addressAr"]').value,
                    address: form.querySelector('[name="address"]').value,
                    phone: form.querySelector('[name="phone"]').value,
                    email: form.querySelector('[name="email"]').value,
                    website: form.querySelector('[name="website"]').value,
                    specializationId: specId || '00000000-0000-0000-0000-000000000000',
                    workingHours: form.querySelector('[name="workingHours"]').value,
                    logo: logoUrl || '',
                    workingDays: []
                };
                if (whStart) data.workingHoursStart = whStart;
                if (whEnd) data.workingHoursEnd = whEnd;
                return data;
            }

            function sendUpdateRequest(data) {
                var clinicId = '@clinic.Id';
                fetch('@Url.Action("UpdateClinic", "Admin")/' + clinicId, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken },
                    body: JSON.stringify(data)
                })
                .then(function(r) { return r.json(); })
                .then(function(result) {
                    saveBtn.disabled = false;
                    saveBtn.textContent = 'حفظ التغييرات';
                    if (result.success) {
                        showSuccessModal(result.message);
                        setTimeout(function() { location.reload(); }, 1000);
                    } else {
                        showErrors(result.error || result.message || 'حدث خطأ');
                        showErrorModal(result.error || 'حدث خطأ');
                    }
                })
                .catch(function() {
                    saveBtn.disabled = false;
                    saveBtn.textContent = 'حفظ التغييرات';
                    showErrors('عذراً، حدث خطأ أثناء تحديث العيادة.');
                    showErrorModal('عذراً، حدث خطأ أثناء تحديث العيادة.');
                });
            }

            function submitUpdate() {
                clearErrors();

                var dayChecks = form.querySelectorAll('[name="workingDays"]:checked');
                var logoFile = logoInput.files && logoInput.files[0];

                saveBtn.disabled = true;
                saveBtn.textContent = 'جاري الحفظ...';

                if (logoFile) {
                    var fd = new FormData();
                    fd.append('file', logoFile);
                    fetch('@Url.Action("UploadClinicImage", "Admin")', {
                        method: 'POST',
                        headers: { 'RequestVerificationToken': csrfToken },
                        body: fd
                    })
                    .then(function(r) { return r.json(); })
                    .then(function(imgResult) {
                        if (imgResult.success) {
                            var data = buildPayload(imgResult.url);
                            data.workingDays = [];
                            dayChecks.forEach(function(c) { data.workingDays.push(parseInt(c.value)); });
                            if (data.workingDays.length === 0) delete data.workingDays;
                            sendUpdateRequest(data);
                        } else {
                            saveBtn.disabled = false;
                            saveBtn.textContent = 'حفظ التغييرات';
                            showErrors(imgResult.error || imgResult.message || 'فشل رفع الصورة');
                            showErrorModal(imgResult.error || 'فشل رفع الصورة');
                        }
                    })
                    .catch(function() {
                        saveBtn.disabled = false;
                        saveBtn.textContent = 'حفظ التغييرات';
                        showErrors('فشل رفع الصورة');
                        showErrorModal('فشل رفع الصورة');
                    });
                } else {
                    var data = buildPayload(form.querySelector('[name="logo"]').value);
                    data.workingDays = [];
                    dayChecks.forEach(function(c) { data.workingDays.push(parseInt(c.value)); });
                    if (data.workingDays.length === 0) delete data.workingDays;
                    sendUpdateRequest(data);
                }
            }

            saveBtn.addEventListener('click', submitUpdate);

            // Toggle clinic active status
            var toggleBtn = document.getElementById('toggleClinicStatusBtn');
            toggleBtn.addEventListener('click', function() {
                var clinicId = this.getAttribute('data-clinic-id');
                var isActive = this.getAttribute('data-is-active') === 'true';
                var action = isActive ? 'DeactivateClinic' : 'ActivateClinic';
                var confirmMsg = isActive ? 'هل أنت متأكد من إلغاء تفعيل هذه العيادة؟' : 'هل أنت متأكد من تفعيل هذه العيادة؟';

                showConfirmModal(confirmMsg, function(confirmed) {
                    if (!confirmed) return;

                    var btn = toggleBtn;
                    btn.disabled = true;
                    btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span>';

                    fetch('@Url.Action("ActivateClinic", "Admin")'.replace('ActivateClinic', action) + '/' + clinicId, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken }
                    })
                    .then(function(r) { return r.json(); })
                    .then(function(result) {
                        if (result.success) {
                            showSuccessModal(result.message);
                            setTimeout(function() { location.reload(); }, 1000);
                        } else {
                            btn.disabled = false;
                            showErrorModal(result.error || 'حدث خطأ');
                        }
                    })
                    .catch(function() {
                        btn.disabled = false;
                        showErrorModal('عذراً، حدث خطأ أثناء تحديث حالة العيادة.');
                    });
                });
            });
        })();
    </script>
}
