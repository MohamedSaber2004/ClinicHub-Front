@{
    ViewData["Title"] = "الدعم الفني";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <h2 class="page-title">
        <span class="page-title-icon">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M19 12v-2c0-3.866-3.134-7-7-7S5 6.134 5 10v2H3v7h3v-9c0-3.313 2.687-6 6-6s6 2.687 6 6v9h3v-7h-2zM7 15v2c0 1.103.897 2 2 2h2v-6H7v2zm8 0h-2v2h2c1.103 0 2-.897 2-2v-2h-2v2z" fill="currentColor"/>
            </svg>
        </span>
        تذاكر الدعم الفني
    </h2>
</div>

<!-- Filter Bar -->
<div class="filter-bar">
    <input type="text" id="filterSearch" class="form-input" placeholder="بحث عن تذكرة..." />
    <select id="filterStatus" class="form-select">
        <option value="">جميع الحالات</option>
        <option value="مفتوح">مفتوح</option>
        <option value="قيد المعالجة">قيد المعالجة</option>
        <option value="تم الحل">تم الحل</option>
    </select>
    <select id="filterPriority" class="form-select">
        <option value="">جميع الأولويات</option>
        <option value="عالية">عالية</option>
        <option value="متوسطة">متوسطة</option>
        <option value="منخفضة">منخفضة</option>
    </select>
</div>

<!-- Tickets Table -->
<div class="table-card">
    <div class="table-responsive">
        <table class="custom-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>الموضوع</th>
                    <th>المبلغ</th>
                    <th>الأولوية</th>
                    <th>الحالة</th>
                    <th>تاريخ الإبلاغ</th>
                    <th>المرفقات</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var tickets = ViewBag.Tickets as List<MockSupportTicket> ?? new();
                }
                @foreach (var t in tickets)
                {
                    <tr>
                        <td class="text-md">@t.Code</td>
                        <td class="text-md-medium">
                            <span class="row-icon" style="color: @(t.Priority == "عالية" ? "var(--clr-danger)" : "var(--clr-text-secondary)");">
                                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" fill="currentColor"/>
                                </svg>
                            </span>
                            @t.Subject
                        </td>
                        <td class="text-md">@t.Reporter</td>
                        <td><span class="badge @t.PriorityClass">@t.Priority</span></td>
                        <td><span class="badge @t.StatusClass">@t.Status</span></td>
                        <td class="text-md">@t.Date</td>
                        <td class="text-md">
                            @if (t.HasAttachment)
                            {
                                <button class="btn-icon" title="مرفق">
                                    <svg viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M16.5 6v11.5c0 2.21-1.79 4-4 4s-4-1.79-4-4V5c0-1.38 1.12-2.5 2.5-2.5s2.5 1.12 2.5 2.5v10.5c0 .55-.45 1-1 1s-1-.45-1-1V6H10v9.5c0 1.38 1.12 2.5 2.5 2.5s2.5-1.12 2.5-2.5V5c0-2.21-1.79-4-4-4S7 2.79 7 5v12.5c0 3.04 2.46 5.5 5.5 5.5s5.5-2.46 5.5-5.5V6h-1.5z"/>
                                    </svg>
                                </button>
                            }
                            else
                            {
                                <span class="text-md">—</span>
                            }
                        </td>
                        <td>
                            <div class="table-actions">
                                <button class="btn-icon btn-view-ticket" title="عرض التفاصيل"
                                        data-code="@t.Code"
                                        data-subject="@t.Subject"
                                        data-reporter="@t.Reporter"
                                        data-priority="@t.Priority"
                                        data-priority-class="@t.PriorityClass"
                                        data-status="@t.Status"
                                        data-status-class="@t.StatusClass"
                                        data-date="@t.Date"
                                        data-description="@t.Description"
                                        data-has-attachment="@t.HasAttachment.ToString().ToLower()"
                                        data-attachments="@string.Join(",", t.Attachments)">
                                    <svg viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>
                                    </svg>
                                </button>
                                <button class="btn-icon" title="تعيين إلى">
                                    <svg viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5s-3 1.34-3 3 1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 2 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
                                    </svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Ticket Detail Modal -->
<div class="modal fade" id="ticketDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content modal-content-custom">
            <div class="modal-header-custom">
                <h5 class="modal-title" id="ticketModalTitle">تفاصيل التذكرة</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="إغلاق"></button>
            </div>
            <div class="modal-body-custom" id="ticketModalBody">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <p class="form-label">المبلغ:</p>
                        <p class="text-md-medium" id="ticketReporter"></p>
                    </div>
                    <div class="col-md-3">
                        <p class="form-label">الأولوية:</p>
                        <span id="ticketPriority"></span>
                    </div>
                    <div class="col-md-3">
                        <p class="form-label">الحالة:</p>
                        <span id="ticketStatus"></span>
                    </div>
                </div>
                <div class="form-group">
                    <p class="form-label">الموضوع:</p>
                    <p class="text-md-medium" id="ticketSubject"></p>
                </div>
                <div class="form-group">
                    <p class="form-label">الوصف:</p>
                    <p class="text-md" id="ticketDescription"></p>
                </div>
                <div class="form-group" id="ticketAttachmentsGroup" style="display:none;">
                    <p class="form-label">المرفقات:</p>
                    <div id="ticketAttachments" style="display: flex; gap: 8px; align-items: center;"></div>
                </div>
                <div class="form-group">
                    <p class="form-label">تاريخ الإبلاغ:</p>
                    <p class="text-md" id="ticketDate"></p>
                </div>
                <hr />
                <div class="form-group">
                    <label class="form-label">إضافة رد</label>
                    <textarea class="form-textarea" placeholder="اكتب ردك هنا..." rows="3"></textarea>
                </div>
                <div class="form-group">
                    <label class="form-label">تغيير الحالة إلى</label>
                    <select class="form-select">
                        <option>قيد المعالجة</option>
                        <option>تم الحل</option>
                        <option>مغلق</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer-custom">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إغلاق</button>
                <button type="button" class="btn btn-primary">إرسال الرد</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function() {
            var ticketModal = new bootstrap.Modal(document.getElementById('ticketDetailModal'));

            document.querySelectorAll('.btn-view-ticket').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    document.getElementById('ticketModalTitle').textContent = 'تفاصيل التذكرة ' + btn.getAttribute('data-code');
                    document.getElementById('ticketReporter').textContent = btn.getAttribute('data-reporter');
                    document.getElementById('ticketSubject').textContent = btn.getAttribute('data-subject');
                    document.getElementById('ticketDescription').textContent = btn.getAttribute('data-description');
                    document.getElementById('ticketDate').textContent = btn.getAttribute('data-date');

                    var priorityEl = document.getElementById('ticketPriority');
                    priorityEl.innerHTML = '<span class="badge ' + btn.getAttribute('data-priority-class') + '">' + btn.getAttribute('data-priority') + '</span>';

                    var statusEl = document.getElementById('ticketStatus');
                    statusEl.innerHTML = '<span class="badge ' + btn.getAttribute('data-status-class') + '">' + btn.getAttribute('data-status') + '</span>';

                    var hasAttachment = btn.getAttribute('data-has-attachment') === 'true';
                    var attachmentsGroup = document.getElementById('ticketAttachmentsGroup');
                    var attachmentsContainer = document.getElementById('ticketAttachments');
                    if (hasAttachment) {
                        attachmentsGroup.style.display = '';
                        attachmentsContainer.innerHTML = '';
                        var atts = btn.getAttribute('data-attachments').split(',');
                        atts.forEach(function(a) {
                            var span = document.createElement('span');
                            span.className = 'badge badge-info';
                            span.textContent = a.trim();
                            attachmentsContainer.appendChild(span);
                        });
                    } else {
                        attachmentsGroup.style.display = 'none';
                    }

                    ticketModal.show();
                });
            });

            function filterTable() {
                var searchVal = document.getElementById('filterSearch').value.trim().toLowerCase();
                var statusVal = document.getElementById('filterStatus').value;
                var priorityVal = document.getElementById('filterPriority').value;
                var rows = document.querySelectorAll('.custom-table tbody tr');
                rows.forEach(function(row) {
                    var code = row.cells[0].textContent.trim().toLowerCase();
                    var subject = row.cells[1].textContent.trim().toLowerCase();
                    var reporter = row.cells[2].textContent.trim().toLowerCase();
                    var priority = row.cells[3].textContent.trim();
                    var status = row.cells[4].textContent.trim();
                    var matchSearch = !searchVal || code.indexOf(searchVal) !== -1 || subject.indexOf(searchVal) !== -1 || reporter.indexOf(searchVal) !== -1;
                    var matchStatus = !statusVal || status === statusVal;
                    var matchPriority = !priorityVal || priority === priorityVal;
                    row.style.display = matchSearch && matchStatus && matchPriority ? '' : 'none';
                });
            }

            document.getElementById('filterSearch').addEventListener('input', filterTable);
            document.getElementById('filterStatus').addEventListener('change', filterTable);
            document.getElementById('filterPriority').addEventListener('change', filterTable);
        })();
    </script>
}
