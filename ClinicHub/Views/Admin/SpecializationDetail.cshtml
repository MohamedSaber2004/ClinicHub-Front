@{
    ViewData["Title"] = "تفاصيل التخصص";
    Layout = "_AdminLayout";
}

@{
    var spec = ViewBag.Specialization as SpecializationDto;
}

<div class="page-header">
    <h2 class="page-title">
        <span class="page-title-icon">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M21.41 11.58l-9-9C12.05 2.22 11.55 2 11 2H4c-1.1 0-2 .9-2 2v7c0 .55.22 1.05.59 1.42l9 9c.36.36.86.58 1.41.58.55 0 1.05-.22 1.41-.59l7-7c.37-.36.59-.86.59-1.41 0-.55-.23-1.06-.59-1.42zM5.5 7C4.67 7 4 6.33 4 5.5S4.67 4 5.5 4 7 4.67 7 5.5 6.33 7 5.5 7z" fill="currentColor"/>
            </svg>
        </span>
        @(spec?.ArName ?? "التخصص")
    </h2>
    <a href="/Admin/Specializations" class="btn btn-secondary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/>
        </svg>
        العودة للتخصصات
    </a>
</div>

<div class="detail-card">
    @if (spec != null)
    {
        <div class="detail-card-header">
            @if (!string.IsNullOrEmpty(spec.IconUrl))
            {
                <img class="detail-icon" src="@spec.IconUrl" alt="@spec.ArName" />
            }
            <div class="detail-info">
                <h3>@spec.ArName</h3>
                <span class="badge @(spec.IsFamous ? "badge-success" : "badge-danger")">
                    @(spec.IsFamous ? "مميز" : "غير مميز")
                </span>
            </div>
        </div>
        <div class="detail-body">
            <div class="detail-row">
                <span class="detail-label">الاسم (إنجليزي)</span>
                <span class="detail-value">@spec.Name</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">الوصف</span>
                <span class="detail-value">@(spec.Description ?? "_")</span>
            </div>
        </div>
    }
</div>

@* Styles moved to site.css *@
