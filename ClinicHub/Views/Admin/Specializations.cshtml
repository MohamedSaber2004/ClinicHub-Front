            </tbody>
        </table>
    </div>
</div>

<!-- Add/Edit Modal -->
<div class="modal fade" id="specializationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-content-custom">
            <div class="modal-header-custom">
                <h5 class="modal-title">إضافة تخصص جديد</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="إغلاق"></button>
            </div>
            <div class="modal-body-custom">
                <div class="form-group">
                    <label class="form-label">اسم التخصص</label>
                    <input type="text" class="form-input" placeholder="مثال: أمراض القلب" />
                </div>
                <div class="form-group">
                    <label class="form-label">الوصف</label>
                    <textarea class="form-textarea" placeholder="وصف مختصر للتخصص..." rows="3"></textarea>
                </div>
                <div class="form-group">
                    <label class="form-label">الأيقونة</label>
                    <input type="text" class="form-input" placeholder="🫀 أو رمز إيموجي" />
                    <p class="form-hint">يمكنك استخدام إيموجي أو رمز تعبيري</p>
                </div>
                <div class="form-group">
                    <label class="form-toggle">
                        <input type="checkbox" checked />
                        <span class="toggle-track"></span>
                        <span class="toggle-label">التخصص نشط</span>
                    </label>
                </div>
            </div>
            <div class="modal-footer-custom">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" class="btn btn-primary">حفظ</button>
            </div>
        </div>
    </div>
</div>
