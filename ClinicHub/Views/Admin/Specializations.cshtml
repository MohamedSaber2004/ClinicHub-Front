@{
    ViewData["Title"] = "التخصصات";
    Layout = "_DashboardLayout";
}

<div class="page-header">
    <h2 class="page-title">
        <span class="page-title-icon">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M21.41 11.58l-9-9C12.05 2.22 11.55 2 11 2H4c-1.1 0-2 .9-2 2v7c0 .55.22 1.05.59 1.42l9 9c.36.36.86.58 1.41.58.55 0 1.05-.22 1.41-.59l7-7c.37-.36.59-.86.59-1.41 0-.55-.23-1.06-.59-1.42zM5.5 7C4.67 7 4 6.33 4 5.5S4.67 4 5.5 4 7 4.67 7 5.5 6.33 7 5.5 7z" fill="currentColor"/>
            </svg>
        </span>
        التخصصات الطبية
    </h2>
    <button type="button" id="addSpecializationBtn" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#specializationModal">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
        </svg>
        إضافة تخصص
    </button>
</div>

<!-- Filter Bar -->
<div class="filter-bar">
    <input type="text" id="filterSearch" class="form-input" placeholder="بحث عن تخصص..." />
    <select id="filterStatus" class="form-select">
        <option value="">جميع الحالات</option>
        <option value="active">نشط</option>
        <option value="inactive">غير نشط</option>
    </select>
</div>

<!-- Specializations Table -->
<div class="table-card">
    <div class="table-responsive">
        <table class="custom-table">
            <thead>
                <tr>
                    <th>الأيقونة</th>
                    <th>اسم التخصص</th>
                    <th>الوصف</th>
                    <th>الحالة</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var specializations = ViewBag.Specializations as List<MockSpecialization> ?? new();
                }
                @foreach (var spec in specializations)
                {
                    <tr>
                        <td><span class="emoji-display">@spec.Icon</span></td>
                        <td class="text-md-medium">@spec.Name</td>
                        <td class="text-md">@spec.Description</td>
                        <td>
                            <label class="toggle-switch">
                                <input type="checkbox" class="spec-toggle-input" @(spec.IsActive ? "checked" : "") />
                                <span class="toggle-track-sm"></span>
                            </label>
                        </td>
                        <td>
                            <div class="table-actions">
                                <button class="btn-icon btn-edit-spec" title="تعديل"
                                        data-id="@spec.Id"
                                        data-name="@spec.Name"
                                        data-description="@spec.Description"
                                        data-icon="@spec.Icon"
                                        data-active="@spec.IsActive.ToString().ToLower()">
                                    <svg viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/>
                                    </svg>
                                </button>

                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Add/Edit Modal -->
<div class="modal fade" id="specializationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-content-custom">
            <div class="modal-header-custom">
                <h5 class="modal-title" id="specializationModalTitle">إضافة تخصص جديد</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="إغلاق"></button>
            </div>
            <div class="modal-body-custom">
                <input type="hidden" id="specId" value="" />
                <div class="form-group">
                    <label class="form-label" for="specName">اسم التخصص</label>
                    <input type="text" id="specName" name="Name" class="form-input" placeholder="مثال: أمراض القلب" />
                </div>
                <div class="form-group">
                    <label class="form-label" for="specDescription">الوصف</label>
                    <textarea id="specDescription" name="Description" class="form-textarea" placeholder="وصف مختصر للتخصص..." rows="3"></textarea>
                </div>
                <div class="form-group">
                    <label class="form-label" for="specIcon">الأيقونة</label>
                    <input type="text" id="specIcon" name="Icon" class="form-input" placeholder="🫀 أو رمز إيموجي" />
                    <p class="form-hint">يمكنك استخدام إيموجي أو رمز تعبيري</p>
                </div>
                <div class="form-group">
                    <label class="form-toggle">
                        <input type="checkbox" id="specIsActive" name="IsActive" checked />
                        <span class="toggle-track"></span>
                        <span class="toggle-label">التخصص نشط</span>
                    </label>
                </div>
            </div>
            <div class="modal-footer-custom">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" class="btn btn-primary" id="saveSpecBtn" data-bs-dismiss="modal">حفظ</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function() {
            var modalEl = document.getElementById('specializationModal');
            var titleEl = document.getElementById('specializationModalTitle');
            var idInput = document.getElementById('specId');
            var nameInput = document.getElementById('specName');
            var descInput = document.getElementById('specDescription');
            var iconInput = document.getElementById('specIcon');
            var activeCheck = document.getElementById('specIsActive');

            var specializationModal = new bootstrap.Modal(modalEl);

            document.querySelectorAll('.btn-edit-spec').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    titleEl.textContent = 'تعديل التخصص';
                    idInput.value = btn.getAttribute('data-id');
                    nameInput.value = btn.getAttribute('data-name');
                    descInput.value = btn.getAttribute('data-description');
                    iconInput.value = btn.getAttribute('data-icon');
                    activeCheck.checked = btn.getAttribute('data-active') === 'true';
                    specializationModal.show();
                });
            });

            function filterTable() {
                var searchVal = document.getElementById('filterSearch').value.trim().toLowerCase();
                var statusVal = document.getElementById('filterStatus').value;
                var rows = document.querySelectorAll('.custom-table tbody tr');
                rows.forEach(function(row) {
                    var name = row.querySelector('.text-md-medium').textContent.trim().toLowerCase();
                    var isActive = row.querySelector('.spec-toggle-input').checked;
                    var matchSearch = !searchVal || name.indexOf(searchVal) !== -1;
                    var matchStatus = !statusVal || (statusVal === 'active' && isActive) || (statusVal === 'inactive' && !isActive);
                    row.style.display = matchSearch && matchStatus ? '' : 'none';
                });
            }

            document.getElementById('filterSearch').addEventListener('input', filterTable);
            document.getElementById('filterStatus').addEventListener('change', filterTable);

            document.getElementById('addSpecializationBtn').addEventListener('click', function() {
                titleEl.textContent = 'إضافة تخصص جديد';
                idInput.value = '';
                nameInput.value = '';
                descInput.value = '';
                iconInput.value = '';
                activeCheck.checked = true;
            });
        })();
    </script>
}
