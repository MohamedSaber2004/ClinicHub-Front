@{
    ViewData["Title"] = "التخصصات";
    Layout = "_DashboardLayout";
}

<div class="page-header">
    <h2 class="page-title">التخصصات الطبية</h2>
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#specializationModal">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
        </svg>
        إضافة تخصص
    </button>
</div>

<!-- Filter Bar -->
<div class="filter-bar">
    <input type="text" class="form-input" placeholder="بحث عن تخصص..." style="min-width: 250px;" />
    <select class="form-select">
        <option value="">جميع الحالات</option>
        <option value="active">نشط</option>
        <option value="inactive">غير نشط</option>
    </select>
</div>

<!-- Specializations Table -->
<div class="table-card">
    <div class="table-responsive">
        <table class="custom-table">
            <thead>
                <tr>
                    <th>الأيقونة</th>
                    <th>اسم التخصص</th>
                    <th>الوصف</th>
                    <th>الحالة</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
