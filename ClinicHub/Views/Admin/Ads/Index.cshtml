@using ClinicHub.Data
@{
    ViewData["Title"] = "الإعلانات";
    Layout = "_DashboardLayout";
    var stats = ViewBag.Stats as List<MockStat> ?? new();
    var ads = ViewBag.Ads as List<MockAd> ?? new();
}

<div class="page-header">
    <h2 class="page-title">
        <span class="page-title-icon">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M20 2.01L4 2v2h16V2.01zM4 22h16v-2H4v22zm-2-14h2v8H2V8zm18 0h2v8h-2V8zM9 6c-2.21 0-4 1.79-4 4 0 1.2.54 2.27 1.38 3H7v1c0 1.66 1.34 3 3 3s3-1.34 3-3v-1h.62c.84-.73 1.38-1.8 1.38-3 0-2.21-1.79-4-4-4z" fill="currentColor"/>
            </svg>
        </span>
        إدارة الإعلانات والباقات الدعائية
    </h2>
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#adModal">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
        </svg>
        إضافة إعلان
    </button>
</div>

<!-- KPI Stats -->
<div class="kpi-grid">
    @foreach (var s in stats)
    {
        <div class="stat-card">
            <div class="stat-icon icon-wrapper icon-wrapper--@s.IconColor">
                <svg viewBox="0 0 24 24" fill="currentColor">
                    <path d="@s.SvgPath"/>
                </svg>
            </div>
            <span class="stat-value">@s.Value</span>
            <span class="stat-label">@s.Label</span>
        </div>
    }
</div>

<!-- Filter Bar -->
<div class="filter-bar">
    <input type="text" class="form-input" placeholder="بحث عن إعلان..." style="min-width: 200px;" />
    <select class="form-select">
        <option value="">جميع الأنواع</option>
        <option value="banner">بانر إعلاني</option>
        <option value="featured_doctor">طبيب مميز</option>
        <option value="featured_clinic">عيادة مميزة</option>
    </select>
    <select class="form-select">
        <option value="">جميع الحالات</option>
        <option value="active">نشط</option>
        <option value="inactive">غير نشط</option>
        <option value="scheduled">مجدول</option>
        <option value="expired">منتهي</option>
    </select>
</div>

<!-- Ads Table -->
<div class="table-card">
    <div class="table-responsive">
        <table class="custom-table">
            <thead>
                <tr>
                    <th>معاينة</th>
                    <th>العنوان</th>
                    <th>النوع</th>
                    <th>تاريخ البدء</th>
                    <th>تاريخ الانتهاء</th>
                    <th>الترتيب</th>
                    <th>نقرات</th>
                    <th>الحالة</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ad in ads)
                {
                    <tr>
                        <td>
                            <a href="@AdminRoutes.Pages.AdsDetails(ad.Id)" title="عرض التفاصيل">
                                <div style="width: 60px; height: 40px; background: @ad.Gradient; border-radius: 4px; display: flex; align-items: center; justify-content: center;">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="white">
                                        <path d="@ad.SvgPath"/>
                                    </svg>
                                </div>
                            </a>
                        </td>
                        <td class="text-md-medium">
                            <a href="@AdminRoutes.Pages.AdsDetails(ad.Id)" class="detail-link">@ad.Title</a>
                        </td>
                        <td><span class="badge @ad.TypeClass">@ad.Type</span></td>
                        <td class="text-md">@ad.StartDate</td>
                        <td class="text-md">@ad.EndDate</td>
                        <td class="text-md">@ad.SortOrder</td>
                        <td class="text-md">@ad.Clicks.ToString("N0")</td>
                        <td><span class="badge @ad.StatusClass">@ad.Status</span></td>
                        <td>
                            <div class="ads-actions-dropdown">
                                <button class="btn-icon ads-actions-btn" title="الإجراءات" onclick="toggleAdActions(event)">
                                    <svg viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M12 8c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/>
                                    </svg>
                                </button>
                                <div class="ads-actions-menu">
                                    <a class="ads-action-item" href="@AdminRoutes.Pages.AdsDetails(ad.Id)">
                                        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></svg>
                                        عرض التفاصيل
                                    </a>
                                    <button class="ads-action-item" title="تعديل">
                                        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg>
                                        تعديل
                                    </button>
                                    @if (ad.Status == "نشط")
                                    {
                                        <button class="ads-action-item ads-action-warning" title="تعطيل">
                                            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8 0-1.85.63-3.55 1.69-4.9L16.9 18.31C15.55 19.37 13.85 20 12 20zm6.31-3.1L7.1 5.69C8.45 4.63 10.15 4 12 4c4.42 0 8 3.58 8 8 0 1.85-.63 3.55-1.69 4.9z"/></svg>
                                            تعطيل
                                        </button>
                                        <button class="ads-action-item ads-action-danger" title="إنهاء">
                                            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM8 9h8v10H8V9zm7.5-5l-1-1h-5l-1 1H5v2h14V4h-3.5z"/></svg>
                                            إنهاء
                                        </button>
                                    }
                                    else if (ad.Status == "غير نشط")
                                    {
                                        <button class="ads-action-item ads-action-success" title="تفعيل">
                                            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                                            تفعيل
                                        </button>
                                        <button class="ads-action-item ads-action-danger" title="حذف">
                                            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM8 9h8v10H8V9zm7.5-5l-1-1h-5l-1 1H5v2h14V4h-3.5z"/></svg>
                                            حذف
                                        </button>
                                    }
                                    else if (ad.Status == "مجدول")
                                    {
                                        <button class="ads-action-item ads-action-success" title="تفعيل">
                                            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                                            تفعيل الآن
                                        </button>
                                        <button class="ads-action-item ads-action-warning" title="إلغاء">
                                            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.47 2 2 6.47 2 12s4.47 10 10 10 10-4.47 10-10S17.53 2 12 2zm5 13.59L15.59 17 12 13.41 8.41 17 7 15.59 10.59 12 7 8.41 8.41 7 12 10.59 15.59 7 17 8.41 13.41 12 17 15.59z"/></svg>
                                            إلغاء
                                        </button>
                                    }
                                    else if (ad.Status == "منتهي")
                                    {
                                        <button class="ads-action-item ads-action-success" title="تجديد">
                                            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/></svg>
                                            تجديد
                                        </button>
                                        <button class="ads-action-item ads-action-danger" title="حذف">
                                            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM8 9h8v10H8V9zm7.5-5l-1-1h-5l-1 1H5v2h14V4h-3.5z"/></svg>
                                            حذف
                                        </button>
                                    }
                                    else if (ad.Status == "ملغي")
                                    {
                                        <button class="ads-action-item ads-action-success" title="إعادة تفعيل">
                                            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                                            إعادة تفعيل
                                        </button>
                                        <button class="ads-action-item ads-action-danger" title="حذف">
                                            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM8 9h8v10H8V9zm7.5-5l-1-1h-5l-1 1H5v2h14V4h-3.5z"/></svg>
                                            حذف
                                        </button>
                                    }
    </div>
</div>

<script>
function toggleAdActions(e) {
    e.stopPropagation();
    var menu = e.currentTarget.parentElement.querySelector('.ads-actions-menu');
    var isOpen = menu.classList.contains('ads-actions-open');
    closeAllAdMenus();
    if (!isOpen) menu.classList.add('ads-actions-open');
}

function closeAllAdMenus() {
    document.querySelectorAll('.ads-actions-menu.ads-actions-open').forEach(function(m) {
        m.classList.remove('ads-actions-open');
    });
}

document.addEventListener('click', function() {
    closeAllAdMenus();
});
</script>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Add/Edit Ad Modal -->
<div class="modal fade" id="adModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content modal-content-custom">
            <div class="modal-header-custom">
                <h5 class="modal-title">إضافة إعلان جديد</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="إغلاق"></button>
            </div>
            <div class="modal-body-custom">
                <div class="row">
                    <div class="col-md-8">
                        <div class="form-group">
                            <label class="form-label">عنوان الإعلان</label>
                            <input type="text" class="form-input" placeholder="مثال: عروض شهر يوليو - عيادة متكاملة" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label">النوع</label>
                            <select class="form-select">
                                <option>بانر إعلاني</option>
                                <option>طبيب مميز</option>
                                <option>عيادة مميزة</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label">تاريخ البدء</label>
                            <input type="date" class="form-input" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label">تاريخ الانتهاء</label>
                            <input type="date" class="form-input" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label">ترتيب العرض</label>
                            <input type="number" class="form-input" placeholder="1" min="1" />
                            <p class="form-hint">الأرقام الأقل تظهر أولاً</p>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">مكان الظهور</label>
                            <select class="form-select">
                                <option>الصفحة الرئيسية - أعلى</option>
                                <option>صفحة الأطباء - المميزون</option>
                                <option>صفحة العيادات - المميزة</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="form-label">التكلفة اليومية</label>
                            <input type="text" class="form-input" placeholder="0" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="form-label">الميزانية الإجمالية</label>
                            <input type="text" class="form-input" placeholder="0" />
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">صورة الإعلان</label>
                    <div style="border: 2px dashed var(--clr-border); border-radius: var(--radius-sm); padding: var(--space-8); text-align: center; cursor: pointer; transition: border-color var(--transition-base);">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="var(--clr-text-secondary)">
                            <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                        </svg>
                        <p style="color: var(--clr-text-secondary); margin-top: var(--space-2);">اسحب وأفلت الصورة هنا أو انقر لاختيار ملف</p>
                        <p class="form-hint">يفضل صورة بحجم 1200x400 بكسل بصيغة JPG أو PNG</p>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">رابط الوجهة (اختياري)</label>
                            <input type="url" class="form-input" placeholder="https://..." />
                            <p class="form-hint">عند النقر على الإعلان، إلى أين يذهب المستخدم</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">معرّف الطبيب/العيادة (اختياري)</label>
                            <input type="text" class="form-input" placeholder="معرّف إضافي للربط" />
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">ملاحظات داخلية</label>
                    <textarea class="form-input" rows="2" placeholder="ملاحظات للإدارة..."></textarea>
                </div>
                <div class="form-group">
                    <label class="form-toggle">
                        <input type="checkbox" checked />
                        <span class="toggle-track"></span>
                        <span class="toggle-label">نشط — يظهر في التطبيق</span>
                    </label>
                </div>
            </div>
            <div class="modal-footer-custom">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" class="btn btn-primary">حفظ الإعلان</button>
            </div>
        </div>
    </div>
</div>
