@using ClinicHub.Data
@using ClinicHub.Routes
@{
    ViewData["Title"] = "تفاصيل الإعلان";
    Layout = "_DashboardLayout";
    var ad = ViewBag.Detail as MockAd ?? new();
}

<div class="detail-page">
    <!-- Back Link -->
    <a href="@AdminRoutes.Pages.Ads()" class="detail-back-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/>
        </svg>
        العودة إلى قائمة الإعلانات
    </a>

    <!-- Detail Header -->
    <div class="detail-header">
        <div class="detail-header-info" style="display:flex;align-items:center;gap:var(--space-4);">
            <div style="width: 80px; height: 54px; background: @ad.Gradient; border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; flex-shrink:0;">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="white">
                    <path d="@ad.SvgPath"/>
                </svg>
            </div>
            <div>
                <h2 class="detail-title" style="margin:0;">@ad.Title</h2>
                <span class="detail-subtitle">@ad.Type &middot; @ad.StartDate إلى @ad.EndDate</span>
            </div>
        </div>
        <div class="detail-header-amount">
            <span class="badge @ad.StatusClass" style="font-size:14px;padding:4px 16px;">@ad.Status</span>
        </div>
    </div>

    <!-- Stats Row -->
    <div class="stats-row-4" style="margin-top:var(--space-5);">
        <div class="user-stat-card">
            <span class="user-stat-value">@ad.Impressions.ToString("N0")</span>
            <span class="user-stat-label">مرات الظهور</span>
        </div>
        <div class="user-stat-card">
            <span class="user-stat-value">@ad.Clicks.ToString("N0")</span>
            <span class="user-stat-label">النقرات</span>
        </div>
        <div class="user-stat-card">
            <span class="user-stat-value">@ad.CTR%</span>
            <span class="user-stat-label">نسبة النقر (CTR)</span>
        </div>
        <div class="user-stat-card">
            <span class="user-stat-value">@ad.TotalBudget</span>
            <span class="user-stat-label">الميزانية الإجمالية</span>
        </div>
    </div>

    <!-- Two-column Info Grid -->
    <div class="detail-grid">
        <!-- Basic Info -->
        <div class="detail-card">
            <h3 class="detail-card-title">
                <span class="subtitle-icon">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm16-4H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-1 9h-4v4h-2v-4H9V9h4V5h2v4h4v2z" fill="currentColor"/>
                    </svg>
                </span>
                معلومات أساسية
            </h3>
            <div class="detail-info-list">
                <div class="detail-info-row">
                    <span class="detail-info-label">العنوان</span>
                    <span class="detail-info-value">@ad.Title</span>
                </div>
                <div class="detail-info-row">
                    <span class="detail-info-label">النوع</span>
                    <span class="detail-info-value"><span class="badge @ad.TypeClass">@ad.Type</span></span>
                </div>
                <div class="detail-info-row">
                    <span class="detail-info-label">تاريخ البدء</span>
                    <span class="detail-info-value">@ad.StartDate</span>
                </div>
                <div class="detail-info-row">
                    <span class="detail-info-label">تاريخ الانتهاء</span>
                    <span class="detail-info-value">@ad.EndDate</span>
                </div>
                <div class="detail-info-row">
                    <span class="detail-info-label">ترتيب العرض</span>
                    <span class="detail-info-value">@ad.SortOrder</span>
                </div>
                <div class="detail-info-row">
                    <span class="detail-info-label">مكان الظهور</span>
                    <span class="detail-info-value">@ad.Placement</span>
                </div>
                <div class="detail-info-row">
                    <span class="detail-info-label">الحالة</span>
                    <span class="detail-info-value"><span class="badge @ad.StatusClass">@ad.Status</span></span>
                </div>
            </div>
        </div>

        <!-- Pricing -->
        <div class="detail-card">
            <h3 class="detail-card-title">
                <span class="subtitle-icon">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z" fill="currentColor"/>
                    </svg>
                </span>
                التسعير والميزانية
            </h3>
            <div class="detail-info-list">
                <div class="detail-info-row">
                    <span class="detail-info-label">التكلفة اليومية</span>
                    <span class="detail-info-value">@ad.CostPerDay @MockData.CurrencySymbol</span>
                </div>
                <div class="detail-info-row">
                    <span class="detail-info-label">الميزانية الإجمالية</span>
                    <span class="detail-info-value">@ad.TotalBudget @MockData.CurrencySymbol</span>
                </div>
                <div class="detail-info-row">
                    <span class="detail-info-label">مدة الحملة</span>
                    @{
                        var days = 0;
                        if (DateTime.TryParse(ad.StartDate, out var s) && DateTime.TryParse(ad.EndDate, out var e))
                        {
                            days = (e - s).Days;
                        }
                    }
                    <span class="detail-info-value">@days يوم</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Type-specific Info Card -->
    @if (ad.Type == "بانر إعلاني")
    {
        <div class="detail-card" style="margin-top:var(--space-5);">
            <h3 class="detail-card-title">
                <span class="subtitle-icon">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z" fill="currentColor"/>
                    </svg>
                </span>
                تفاصيل البانر الإعلاني
            </h3>
            <div class="detail-info-list">
                <div class="detail-info-row">
                    <span class="detail-info-label">صورة الإعلان</span>
                    <span class="detail-info-value">
                        @if (!string.IsNullOrEmpty(ad.ImageUrl))
                        {
                            <span>@ad.ImageUrl</span>
                        }
                        else
                        {
                            <span style="color:var(--clr-text-secondary);">—</span>
                        }
                    </span>
                </div>
                <div class="detail-info-row">
                    <span class="detail-info-label">رابط الوجهة</span>
                    <span class="detail-info-value">
                        @if (!string.IsNullOrEmpty(ad.TargetUrl))
                        {
                            <a href="@ad.TargetUrl" target="_blank" style="color:var(--clr-primary);">@ad.TargetUrl</a>
                        }
                        else
                        {
                            <span style="color:var(--clr-text-secondary);">—</span>
                        }
                    </span>
                </div>
            </div>
        </div>
    }
    else if (ad.Type == "طبيب مميز")
    {
        <div class="detail-card" style="margin-top:var(--space-5);">
            <h3 class="detail-card-title">
                <span class="subtitle-icon">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 2C9.243 2 7 4.243 7 7v2c0 2.206 1.794 4 4 4v2.184c-2.804.418-4.994 2.617-4.994 5.316V22h2v-1.5c0-2.206 1.794-4 4-4s4 1.794 4 4V22h2v-1.5c0-2.699-2.19-4.898-4.994-5.316V13c2.206 0 4-1.794 4-4V7c0-2.757-2.243-5-5-5zM9 7c0-1.654 1.346-3 3-3s3 1.346 3 3v2c0 1.654-1.346 3-3 3s-3-1.346-3-3V7z" fill="currentColor"/>
                    </svg>
                </span>
                تفاصيل الطبيب المميز
            </h3>
            <div class="detail-info-list">
                <div class="detail-info-row">
                    <span class="detail-info-label">اسم الطبيب</span>
                    <span class="detail-info-value">@ad.LinkedEntityName</span>
                </div>
                <div class="detail-info-row">
                    <span class="detail-info-label">التخصص والخبرة</span>
                    <span class="detail-info-value">@ad.LinkedEntityDetail</span>
                </div>
                <div class="detail-info-row">
                    <span class="detail-info-label">معرّف الطبيب</span>
                    <span class="detail-info-value">@ad.LinkedEntityId</span>
                </div>
            </div>
        </div>
    }
    else if (ad.Type == "عيادة مميزة")
    {
        <div class="detail-card" style="margin-top:var(--space-5);">
            <h3 class="detail-card-title">
                <span class="subtitle-icon">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zm-7-2h2v-4h4v-2h-4V7h-2v4H8v2h4z" fill="currentColor"/>
                    </svg>
                </span>
                تفاصيل العيادة المميزة
            </h3>
            <div class="detail-info-list">
                <div class="detail-info-row">
                    <span class="detail-info-label">اسم العيادة</span>
                    <span class="detail-info-value">@ad.LinkedEntityName</span>
                </div>
                <div class="detail-info-row">
                    <span class="detail-info-label">الوصف</span>
                    <span class="detail-info-value">@ad.LinkedEntityDetail</span>
                </div>
                <div class="detail-info-row">
                    <span class="detail-info-label">معرّف العيادة</span>
                    <span class="detail-info-value">@ad.LinkedEntityId</span>
                </div>
            </div>
        </div>
    }

    <!-- Analytics Card -->
    <div class="detail-card" style="margin-top:var(--space-5);">
        <h3 class="detail-card-title">
            <span class="subtitle-icon">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zM7 10h2v7H7v-7zm4-3h2v10h-2V7zm4 6h2v4h-2v-4z" fill="currentColor"/>
                </svg>
            </span>
            أداء الإعلان
        </h3>
        <div class="detail-info-list">
            <div class="detail-info-row">
                <span class="detail-info-label">إجمالي مرات الظهور</span>
                <span class="detail-info-value" style="font-weight:var(--fw-bold);">@ad.Impressions.ToString("N0")</span>
            </div>
            <div class="detail-info-row">
                <span class="detail-info-label">إجمالي النقرات</span>
                <span class="detail-info-value" style="font-weight:var(--fw-bold);">@ad.Clicks.ToString("N0")</span>
            </div>
            <div class="detail-info-row">
                <span class="detail-info-label">نسبة النقر (CTR)</span>
                <span class="detail-info-value" style="font-weight:var(--fw-bold);">
                    <span class="badge @(ad.CTR >= 2 ? "badge-success" : ad.CTR >= 1 ? "badge-warning" : "badge-danger")">
                        @ad.CTR%
                    </span>
                </span>
            </div>
        </div>
    </div>

    <!-- Status Timeline -->
    @if (ad.Timeline.Any())
    {
        <div class="detail-card" style="margin-top:var(--space-5);">
            <h3 class="detail-card-title">
                <span class="subtitle-icon">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z" fill="currentColor"/>
                    </svg>
                </span>
                الجدول الزمني
            </h3>
            <div class="timeline">
                @foreach (var entry in ad.Timeline)
                {
                    <div class="timeline-item">
                        <div class="timeline-marker timeline-marker--@entry.Marker"></div>
                        <div class="timeline-content">
                            <span class="timeline-date">@entry.Date</span>
                            <span class="timeline-text">@entry.Text</span>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Notes -->
    @if (!string.IsNullOrEmpty(ad.Notes))
    {
        <div class="detail-notes" style="margin-top:var(--space-5);">
            <h3 class="detail-card-title">
                <span class="subtitle-icon">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M21.99 4c0-1.1-.89-2-1.99-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h14l4 4-.01-18zM20 4v13.17L18.83 16H4V4h16zM6 12h12v2H6v-2zm0-3h12v2H6V9zm0-3h12v2H6V6z" fill="currentColor"/>
                    </svg>
                </span>
                ملاحظات
            </h3>
            <p style="margin:var(--space-3) 0 0; color:var(--clr-text); font-size:var(--fs-md);">@ad.Notes</p>
        </div>
    }
</div>
