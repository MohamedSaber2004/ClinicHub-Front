@{
    ViewData["Title"] = "لوحة تحكم المدير";
    Layout = "_DashboardLayout";
}

<h2 class="page-title">لوحة التحكم (المدير العام)</h2>

<!-- Statistics Grid -->
<div class="stats-grid">
    <!-- Card 1: Doctors -->
    <div class="stat-card">
        <div class="stat-info">
            <span class="stat-value">12</span>
            <span class="stat-label">الأطباء</span>
        </div>
        <div class="stat-icon-wrapper icon-wrapper icon-wrapper--primary">
            <!-- Doctor SVG -->
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2C9.243 2 7 4.243 7 7V9C7 11.206 8.794 13 11 13V15.184C8.196 15.602 6.006 17.801 6.006 20.5V22H8.006V20.5C8.006 18.294 9.799 16.5 12 16.5C14.201 16.5 15.994 18.294 15.994 20.5V22H17.994V20.5C17.994 17.801 15.804 15.602 13 15.184V13C15.206 13 17 11.206 17 9V7C17 4.243 14.757 2 12 2ZM9 7C9 5.346 10.346 4 12 4C13.654 4 15 5.346 15 7V9C15 10.654 13.654 12 12 12C10.346 12 9 10.654 9 9V7Z" fill="currentColor"/>
            </svg>
        </div>
    </div>

    <!-- Card 2: Nurses -->
    <div class="stat-card">
        <div class="stat-info">
            <span class="stat-value">32</span>
            <span class="stat-label">التمريض</span>
        </div>
        <div class="stat-icon-wrapper icon-wrapper icon-wrapper--primary">
            <!-- Nurse Cap SVG -->
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M18.994 15.626C18.423 15.18 17.712 14.887 17 14.686V13C18.665 11.602 19.5 9.771 19.5 8C19.5 6.619 18.381 5.5 17 5.5H16C16 3.514 14.486 2 12.5 2H11.5C9.514 2 8 3.514 8 5.5H7C5.619 5.5 4.5 6.619 4.5 8C4.5 9.771 5.335 11.602 7 13V14.686C6.288 14.887 5.577 15.18 5.006 15.626C3.766 16.592 3 18.067 3 19.641V22H5V19.641C5 18.729 5.485 17.871 6.257 17.371L7.545 16.533C8.426 15.961 9.479 15.663 10.536 15.663H13.464C14.521 15.663 15.574 15.961 16.455 16.533L17.743 17.371C18.515 17.871 19 18.729 19 19.641V22H21V19.641C21 18.067 20.234 16.592 18.994 15.626ZM10 5.5H14V7.5H10V5.5ZM12.5 11C11.673 11 11 10.327 11 9.5C11 8.673 11.673 8 12.5 8C13.327 8 14 8.673 14 9.5C14 10.327 13.327 11 12.5 11Z" fill="currentColor"/>
            </svg>
        </div>
    </div>

    <!-- Card 3: Patients -->
    <div class="stat-card">
        <div class="stat-info">
            <span class="stat-value">99</span>
            <span class="stat-label">المرضى</span>
        </div>
        <div class="stat-icon-wrapper icon-wrapper icon-wrapper--primary">
            <!-- Patient SVG -->
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5s-3 1.34-3 3 1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 2 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z" fill="currentColor"/>
            </svg>
        </div>
    </div>

    <!-- Card 4: Rooms -->
    <div class="stat-card">
        <div class="stat-info">
            <span class="stat-value">109</span>
            <span class="stat-label">الغرف</span>
        </div>
        <div class="stat-icon-wrapper icon-wrapper icon-wrapper--primary">
            <!-- Room SVG -->
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M19 2H5C3.9 2 3 2.9 3 4V20C3 21.1 3.9 22 5 22H19C20.1 22 21 21.1 21 20V4C21 2.9 20.1 2 19 2ZM19 20H5V4H19V20ZM11 10H13V12H11V10Z" fill="currentColor"/>
            </svg>
        </div>
    </div>
</div>

<!-- Tables Layout -->
<div class="dashboard-tables-grid">
    <!-- Left Table: Doctors on Duty -->
    <div class="table-card" id="doctors">
        <div class="table-card-header">
            <h3 class="table-card-title">الأطباء المناوبون</h3>
        </div>
        <div class="table-responsive">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>الاسم</th>
                        <th>الدور</th>
                        <th>التخصص</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>د. عمار</td>
                        <td>أستاذ</td>
                        <td>الأمراض الجلدية</td>
                    </tr>
                    <tr>
                        <td>د. خان</td>
                        <td>خبير طبي</td>
                        <td>الأمراض الجلدية</td>
                    </tr>
                    <tr>
                        <td>د. عبد الله</td>
                        <td>مسؤول اتصال</td>
                        <td>أمراض الأعصاب</td>
                    </tr>
                    <tr>
                        <td>د. علياء</td>
                        <td>متعاون</td>
                        <td>طب الأسرة</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Right Table: New Admitted Patients -->
    <div class="table-card" id="patients">
        <div class="table-card-header">
            <h3 class="table-card-title">المرضى المقبولين الجدد</h3>
        </div>
        <div class="table-responsive">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>الاسم</th>
                        <th>القسم</th>
                        <th>التاريخ</th>
                        <th>رقم الهاتف</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>عزير</td>
                        <td>القلب والأوعية الدموية</td>
                        <td>3 مارس 2025</td>
                        <td>+0123456789</td>
                    </tr>
                    <tr>
                        <td>حارس</td>
                        <td>أمراض الأعصاب</td>
                        <td>4 مارس 2025</td>
                        <td>+0123456789</td>
                    </tr>
                    <tr>
                        <td>حمزة</td>
                        <td>أمراض النساء</td>
                        <td>5 مارس 2025</td>
                        <td>+0123456789</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
