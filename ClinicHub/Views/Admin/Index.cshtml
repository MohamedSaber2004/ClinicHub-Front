@using ClinicHub.Data
@{
    ViewData["Title"] = "لوحة تحكم المدير";
    Layout = "_AdminLayout";
    var stats = ViewBag.Stats as List<MockStat> ?? new();
    var quickStatuses = ViewBag.QuickStatuses as List<MockQuickStatus> ?? new();
    var doctors = ViewBag.DoctorsOnDuty as List<MockTableRow> ?? new();
    var tickets = ViewBag.UrgentTickets as List<MockTableRow> ?? new();
    var subscribers = ViewBag.Subscribers as List<MockTableRow> ?? new();
    var activityLog = ViewBag.ActivityLog as List<MockTableRow> ?? new();
    var newPatients = ViewBag.NewPatients as List<MockTableRow> ?? new();
}

<h2 class="page-title">
    <span class="page-title-icon">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <rect x="3" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="2" fill="none"/>
            <rect x="14" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="2" fill="none"/>
            <rect x="3" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="2" fill="none"/>
            <rect x="14" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="2" fill="none"/>
        </svg>
    </span>
    لوحة التحكم - نظرة عامة
</h2>

<!-- KPI Stat Cards -->
<div class="stats-grid">
    @foreach (var stat in stats)
    {
        <div class="stat-card">
            <div class="stat-info">
                <span class="stat-value">@stat.Value</span>
                <span class="stat-label">@stat.Label</span>
            </div>
            <div class="icon-wrapper icon-wrapper--@stat.IconColor">
                <svg viewBox="0 0 24 24" fill="currentColor">
                    <path d="@stat.SvgPath"/>
                </svg>
            </div>
        </div>
    }
</div>

<!-- Quick Status Row -->
<div class="quick-status-row">
    @foreach (var qs in quickStatuses)
    {
        <div class="quick-status-item quick-status--@qs.Color">
            <span class="quick-status-dot"></span>
            <span class="quick-status-text">@qs.Text</span>
        </div>
    }
</div>

<!-- 2-Column Tables Row 1 -->
<div class="dashboard-tables-grid">
    <div class="table-card" id="doctors-on-duty">
        <div class="table-card-header">
            <h3 class="table-card-title">
    <span class="subtitle-icon">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2C9.243 2 7 4.243 7 7v2c0 2.206 1.794 4 4 4v2.184c-2.804.418-4.994 2.617-4.994 5.316V22h2v-1.5c0-2.206 1.794-4 4-4s4 1.794 4 4V22h2v-1.5c0-2.699-2.19-4.898-4.994-5.316V13c2.206 0 4-1.794 4-4V7c0-2.757-2.243-5-5-5zM9 7c0-1.654 1.346-3 3-3s3 1.346 3 3v2c0 1.654-1.346 3-3 3s-3-1.346-3-3V7z" fill="currentColor"/>
        </svg>
    </span>
    الأطباء المناوبون
</h3>
        </div>
        <div class="table-responsive">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>الاسم</th>
                        <th>الدور</th>
                        <th>التخصص</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in doctors)
                    {
                        <tr>
                            <td>@row.Cells["name"]</td>
                            <td>@row.Cells["role"]</td>
                            <td>@row.Cells["specialty"]</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="table-card" id="urgent-tickets">
        <div class="table-card-header">
            <h3 class="table-card-title">
    <span class="subtitle-icon">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" fill="currentColor"/>
        </svg>
    </span>
    تذاكر الدعم العاجلة
</h3>
        </div>
        <div class="table-responsive">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>الموضوع</th>
                        <th>المبلغ</th>
                        <th>الأولوية</th>
                        <th>التاريخ</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in tickets)
                    {
                        <tr>
                            <td class="text-md">@row.Cells["code"]</td>
                            <td class="text-md-medium">@row.Cells["subject"]</td>
                            <td class="text-md">@row.Cells["reporter"]</td>
                            <td><span class="badge @row.Cells["priorityClass"]">@row.Cells["priority"]</span></td>
                            <td class="text-md">@row.Cells["date"]</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- 2-Column Tables Row 2 -->
<div class="dashboard-tables-grid">
    <div class="table-card" id="subscriptions">
        <div class="table-card-header">
            <h3 class="table-card-title">
    <span class="subtitle-icon">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5s-3 1.34-3 3 1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05c1.16.84 1.97 2 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z" fill="currentColor"/>
        </svg>
    </span>
    المشتركون في النظام
</h3>
        </div>
        <div class="table-responsive">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>اسم العيادة</th>
                        <th>تاريخ الاشتراك</th>
                        <th>تاريخ الانتهاء</th>
                        <th>الباقة</th>
                        <th>عدد الأطباء</th>
                        <th>الحالة</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in subscribers)
                    {
                        <tr>
                            <td class="text-md-medium">@row.Cells["name"]</td>
                            <td class="text-md">@row.Cells["start"]</td>
                            <td class="text-md">@row.Cells["end"]</td>
                            <td><span class="badge @row.Cells["packageClass"]">@row.Cells["package"]</span></td>
                            <td class="text-md">@row.Cells["doctors"]</td>
                            <td><span class="badge @row.Cells["statusClass"]">@row.Cells["status"]</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="table-card" id="activity-log">
        <div class="table-card-header">
            <h3 class="table-card-title">
    <span class="subtitle-icon">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm2 18H6V4h7v5h5v11zm-4-5l-4-4 1.41-1.41L12 12.17l2.59-2.58L16 11l-4 4z" fill="currentColor"/>
        </svg>
    </span>
    سجل العمليات والنشاطات
</h3>
        </div>
        <div class="table-responsive">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>التاريخ</th>
                        <th>الإجراء</th>
                        <th>المستخدم</th>
                        <th>التفاصيل</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in activityLog)
                    {
                        <tr>
                            <td class="text-md">@row.Cells["date"]</td>
                            <td class="text-md-medium">@row.Cells["action"]</td>
                            <td class="text-md">@row.Cells["user"]</td>
                            <td class="text-md">@row.Cells["detail"]</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Full-width Patients Table -->
<div class="table-card" id="new-patients" style="margin-top: var(--space-6);">
    <div class="table-card-header">
        <h3 class="table-card-title">
    <span class="subtitle-icon">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M15 14c-2.67 0-8 1.33-8 4v2h16v-2c0-2.67-5.33-4-8-4zm-9-4V7H4v3H1v2h3v3h2v-3h3v-2H6zm9-4c-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4-1.79-4-4-4z" fill="currentColor"/>
        </svg>
    </span>
    المرضى المقبولين الجدد
</h3>
    </div>
    <div class="table-responsive">
        <table class="custom-table">
            <thead>
                <tr>
                    <th>الاسم</th>
                    <th>القسم</th>
                    <th>التاريخ</th>
                    <th>رقم الهاتف</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in newPatients)
                {
                    <tr>
                        <td>@row.Cells["name"]</td>
                        <td>@row.Cells["dept"]</td>
                        <td>@row.Cells["date"]</td>
                        <td>@row.Cells["phone"]</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
