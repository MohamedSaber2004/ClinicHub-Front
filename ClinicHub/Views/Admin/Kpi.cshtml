@{
    ViewData["Title"] = "مؤشرات الأداء";
    Layout = "_DashboardLayout";
}

<div class="page-header">
    <h2 class="page-title">مؤشرات الأداء الرئيسية</h2>
</div>

<!-- KPI Stat Cards -->
<div class="kpi-section">
    <h3 class="kpi-section-title">نظرة عامة على النظام</h3>
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-info">
                <span class="stat-value">48</span>
                <span class="stat-label">إجمالي المشتركين</span>
            </div>
            <div class="icon-wrapper icon-wrapper--primary">
                <svg viewBox="0 0 24 24" fill="currentColor">
                    <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5s-3 1.34-3 3 1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 2 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
                </svg>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <span class="stat-value">24</span>
                <span class="stat-label">العيادات النشطة</span>
            </div>
            <div class="icon-wrapper icon-wrapper--blue">
                <svg viewBox="0 0 24 24" fill="currentColor">
                    <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zm-7-2h2v-4h4v-2h-4V7h-2v4H8v2h4z"/>
                </svg>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <span class="stat-value">156</span>
                <span class="stat-label">إجمالي الأطباء</span>
            </div>
            <div class="icon-wrapper icon-wrapper--green">
                <svg viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2C9.243 2 7 4.243 7 7v2c0 2.206 1.794 4 4 4v2.184c-2.804.418-4.994 2.617-4.994 5.316V22h2v-1.5c0-2.206 1.794-4 4-4s4 1.794 4 4V22h2v-1.5c0-2.699-2.19-4.898-4.994-5.316V13c2.206 0 4-1.794 4-4V7c0-2.757-2.243-5-5-5zM9 7c0-1.654 1.346-3 3-3s3 1.346 3 3v2c0 1.654-1.346 3-3 3s-3-1.346-3-3V7z"/>
                </svg>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <span class="stat-value">2,847</span>
                <span class="stat-label">إجمالي المرضى</span>
            </div>
            <div class="icon-wrapper icon-wrapper--amber">
                <svg viewBox="0 0 24 24" fill="currentColor">
                    <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5s-3 1.34-3 3 1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 2 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
                </svg>
            </div>
        </div>
