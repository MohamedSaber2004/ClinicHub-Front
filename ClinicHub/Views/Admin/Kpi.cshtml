                        <td class="text-md">32</td>
                        <td><span class="badge badge-success">نشط</span></td>
                    </tr>
                    <tr>
                        <td class="text-md-medium">عيادات الدكتور سمير</td>
                        <td class="text-md">1 مارس 2026</td>
                        <td class="text-md">30 سبتمبر 2026</td>
                        <td class="text-md"><span class="badge badge-success">باقة أساسية</span></td>
                        <td class="text-md">5</td>
                        <td><span class="badge badge-success">نشط</span></td>
                    </tr>
                    <tr>
                        <td class="text-md-medium">مركز رعاية اليوم الواحد</td>
                        <td class="text-md">1 يناير 2025</td>
