@{
    ViewData["Title"] = "الأطباء";
    Layout = "_DashboardLayout";
}

<div class="page-header">
    <h2 class="page-title">
        <span class="page-title-icon">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2C9.243 2 7 4.243 7 7v2c0 2.206 1.794 4 4 4v2.184c-2.804.418-4.994 2.617-4.994 5.316V22h2v-1.5c0-2.206 1.794-4 4-4s4 1.794 4 4V22h2v-1.5c0-2.699-2.19-4.898-4.994-5.316V13c2.206 0 4-1.794 4-4V7c0-2.757-2.243-5-5-5zM9 7c0-1.654 1.346-3 3-3s3 1.346 3 3v2c0 1.654-1.346 3-3 3s-3-1.346-3-3V7z" fill="currentColor"/>
            </svg>
        </span>
        إدارة الأطباء
    </h2>
    <button type="button" id="addDoctorBtn" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#doctorModal">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
        </svg>
        إضافة طبيب
    </button>
</div>

<!-- Filter Bar -->
<div class="filter-bar">
    <input type="text" id="filterSearch" class="form-input" placeholder="بحث عن طبيب..." />
    <select id="filterSpecialty" class="form-select">
        <option value="">جميع التخصصات</option>
        <option value="الأمراض الجلدية">الأمراض الجلدية</option>
        <option value="أمراض القلب">أمراض القلب</option>
        <option value="جراحة العظام">جراحة العظام</option>
        <option value="الأمراض العصبية">الأمراض العصبية</option>
    </select>
    <select id="filterStatus" class="form-select">
        <option value="">جميع الحالات</option>
        <option value="active">نشط</option>
        <option value="inactive">غير نشط</option>
    </select>
</div>

<!-- Doctors Table -->
<div class="table-card">
    <div class="table-responsive">
        <table class="custom-table">
            <thead>
                <tr>
                    <th>الصورة</th>
                    <th>الاسم</th>
                    <th>التخصص</th>
                    <th>العيادة</th>
                    <th>الهاتف</th>
                    <th>البريد الإلكتروني</th>
                    <th>الحالة</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var doctors = ViewBag.Doctors as List<MockDoctor> ?? new();
                }
                @foreach (var d in doctors)
                {
                    <tr>
                        <td>
                            <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
                                <circle cx="18" cy="18" r="18" fill="#F2F5F9"/>
                                <circle cx="18" cy="14" r="6" fill="#66748C"/>
                                <path d="M6 30c0-5.523 5.373-9 12-9s12 3.477 12 9" stroke="#66748C" stroke-width="2.5" stroke-linecap="round"/>
                            </svg>
                        </td>
                        <td class="text-md-medium">@d.Name</td>
                        <td class="text-md">@d.Specialty</td>
                        <td class="text-md">@d.Clinic</td>
                        <td class="text-md">@d.Phone</td>
                        <td class="text-md">@d.Email</td>
                        <td>
                            <label class="toggle-switch">
                                <input type="checkbox" class="doctor-toggle-input" @(d.IsActive ? "checked" : "") />
                                <span class="toggle-track-sm"></span>
                            </label>
                        </td>
                        <td>
                            <div class="table-actions">
                                <button class="btn-icon btn-edit-doctor" title="تعديل"
                                        data-id="@d.Id"
                                        data-name="@d.Name"
                                        data-specialty="@d.Specialty"
                                        data-clinic="@d.Clinic"
                                        data-phone="@d.Phone"
                                        data-email="@d.Email"
                                        data-active="@d.IsActive.ToString().ToLower()">
                                    <svg viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/>
                                    </svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Add/Edit Doctor Modal -->
<div class="modal fade" id="doctorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content modal-content-custom">
            <div class="modal-header-custom">
                <h5 class="modal-title" id="doctorModalTitle">إضافة طبيب جديد</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="إغلاق"></button>
            </div>
            <div class="modal-body-custom">
                <input type="hidden" id="doctorId" value="" />
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label" for="doctorName">الاسم الكامل</label>
                            <input type="text" id="doctorName" name="Name" class="form-input" placeholder="مثال: د. عمار السيد" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label" for="doctorSpecialty">التخصص</label>
                            <select id="doctorSpecialty" name="Specialty" class="form-select">
                                <option value="">اختر التخصص</option>
                                <option>الأمراض الجلدية</option>
                                <option>أمراض القلب</option>
                                <option>جراحة العظام</option>
                                <option>الأمراض العصبية</option>
                                <option>طب الأطفال</option>
                                <option>النساء والولادة</option>
                                <option>طب العيون</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label" for="doctorClinic">العيادة</label>
                            <select id="doctorClinic" name="Clinic" class="form-select">
                                <option value="">اختر العيادة</option>
                                <option>عيادة القلب</option>
                                <option>عيادة الأعصاب</option>
                                <option>عيادة العظام</option>
                                <option>عيادة الجلدية</option>
                                <option>عيادة الأطفال</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label" for="doctorPhone">رقم الهاتف</label>
                            <input type="text" id="doctorPhone" name="Phone" class="form-input" placeholder="+966 5X XXX XXXX" />
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label" for="doctorEmail">البريد الإلكتروني</label>
                            <input type="email" id="doctorEmail" name="Email" class="form-input" placeholder="doctor@clinic.com" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">الصورة الشخصية</label>
                            <input type="file" class="form-input" accept="image/*" />
                            <p class="form-hint">صور بصيغة JPG أو PNG</p>
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-toggle">
                        <input type="checkbox" id="doctorIsActive" name="IsActive" checked />
                        <span class="toggle-track"></span>
                        <span class="toggle-label">الطبيب متاح ونشط</span>
                    </label>
                </div>
            </div>
            <div class="modal-footer-custom">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" class="btn btn-primary" id="saveDoctorBtn" data-bs-dismiss="modal">حفظ</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function() {
            var modalEl = document.getElementById('doctorModal');
            var titleEl = document.getElementById('doctorModalTitle');
            var idInput = document.getElementById('doctorId');
            var nameInput = document.getElementById('doctorName');
            var specialtyInput = document.getElementById('doctorSpecialty');
            var clinicInput = document.getElementById('doctorClinic');
            var phoneInput = document.getElementById('doctorPhone');
            var emailInput = document.getElementById('doctorEmail');
            var activeCheck = document.getElementById('doctorIsActive');

            var doctorModal = new bootstrap.Modal(modalEl);

            document.querySelectorAll('.btn-edit-doctor').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    titleEl.textContent = 'تعديل الطبيب';
                    idInput.value = btn.getAttribute('data-id');
                    nameInput.value = btn.getAttribute('data-name');
                    specialtyInput.value = btn.getAttribute('data-specialty');
                    clinicInput.value = btn.getAttribute('data-clinic');
                    phoneInput.value = btn.getAttribute('data-phone');
                    emailInput.value = btn.getAttribute('data-email');
                    activeCheck.checked = btn.getAttribute('data-active') === 'true';
                    doctorModal.show();
                });
            });

            document.getElementById('addDoctorBtn').addEventListener('click', function() {
                titleEl.textContent = 'إضافة طبيب جديد';
                idInput.value = '';
                nameInput.value = '';
                specialtyInput.value = '';
                clinicInput.value = '';
                phoneInput.value = '';
                emailInput.value = '';
                activeCheck.checked = true;
            });

            function filterTable() {
                var searchVal = document.getElementById('filterSearch').value.trim().toLowerCase();
                var specialtyVal = document.getElementById('filterSpecialty').value;
                var statusVal = document.getElementById('filterStatus').value;
                var rows = document.querySelectorAll('.custom-table tbody tr');
                rows.forEach(function(row) {
                    var name = row.cells[1].textContent.trim().toLowerCase();
                    var spec = row.cells[2].textContent.trim();
                    var isActive = row.querySelector('.doctor-toggle-input').checked;
                    var matchSearch = !searchVal || name.indexOf(searchVal) !== -1;
                    var matchSpecialty = !specialtyVal || spec === specialtyVal;
                    var matchStatus = !statusVal || (statusVal === 'active' && isActive) || (statusVal === 'inactive' && !isActive);
                    row.style.display = matchSearch && matchSpecialty && matchStatus ? '' : 'none';
                });
            }

            document.getElementById('filterSearch').addEventListener('input', filterTable);
            document.getElementById('filterSpecialty').addEventListener('change', filterTable);
            document.getElementById('filterStatus').addEventListener('change', filterTable);
        })();
    </script>
}
