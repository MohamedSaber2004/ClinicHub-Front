@using ClinicHub.Services.ReponseModels
@using ClinicHub.Services.Enums
@{
    ViewData["Title"] = "الأطباء";
    Layout = "_AdminLayout";
    var doctors = ViewBag.Doctors as IReadOnlyCollection<UserResponseDto> ?? new List<UserResponseDto>();
    var clinics = ViewBag.Clinics as List<ClinicLookupDto> ?? new();
    var selectedClinicId = ViewBag.SelectedClinicId as Guid?;
    var searchTerm = ViewBag.SearchTerm as string;
    var isUnassigned = ViewBag.IsUnassigned as bool?;
    var selectedUserTypes = ViewBag.SelectedUserTypes as string;
}

<div class="page-header">
    <h2 class="page-title">
        <span class="page-title-icon">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2C9.243 2 7 4.243 7 7v2c0 2.206 1.794 4 4 4v2.184c-2.804.418-4.994 2.617-4.994 5.316V22h2v-1.5c0-2.206 1.794-4 4-4s4 1.794 4 4V22h2v-1.5c0-2.699-2.19-4.898-4.994-5.316V13c2.206 0 4-1.794 4-4V7c0-2.757-2.243-5-5-5zM9 7c0-1.654 1.346-3 3-3s3 1.346 3 3v2c0 1.654-1.346 3-3 3s-3-1.346-3-3V7z" fill="currentColor"/>
            </svg>
        </span>
        إدارة الأطباء
    </h2>
    @* Add button removed - user creation moved to Users page *@
</div>

<!-- Filter Bar -->
<div class="filter-bar">
    <form method="get" action="/Admin/Doctors" class="filter-bar" style="display: contents;">
        <input type="text" name="searchTerm" class="form-input" placeholder="بحث عن طبيب..." value="@searchTerm" />
        <select name="clinicId" class="form-select" onchange="this.form.submit()">
            <option value="">جميع العيادات</option>
            @foreach (var c in clinics)
            {
                <option value="@c.Id" selected="@(selectedClinicId == c.Id ? true : null)">@c.Name</option>
            }
        </select>
        <select name="userTypes" class="form-select" onchange="this.form.submit()">
            <option value="">جميع الأدوار</option>
            <option value="4" selected="@(selectedUserTypes == "4" ? true : null)">طبيب</option>
            <option value="16" selected="@(selectedUserTypes == "16" ? true : null)">مالك عيادة</option>
        </select>
        <label class="filter-checkbox">
            <input type="checkbox" name="isUnassigned" value="true" onchange="this.form.submit()" @(isUnassigned == true ? "checked" : "") />
            <span class="filter-checkbox-label">غير منتسبين لعيادة</span>
        </label>
    </form>
</div>

<!-- Doctors Table -->
<div class="table-card">
    <div class="table-responsive">
        <table class="custom-table">
            <thead>
                <tr>
                    <th>الاسم</th>
                    <th>البريد الإلكتروني</th>
                    <th>الهاتف</th>
                    <th>الدور</th>
                    <th>تاريخ التسجيل</th>
                    <th>الحالة</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in doctors)
                {
                    <tr>
                        <td>
                            <div style="display: flex; align-items: center; gap: var(--space-3);">
                                <div class="sidebar-profile-avatar" style="width: 36px; height: 36px; background-color: var(--clr-primary);">
                                    <span style="color: #FFFFFF; font-size: var(--fs-md); font-weight: var(--fw-bold);">@GetInitials(d.FullName)</span>
                                </div>
                                <span class="text-md-medium">@d.FullName</span>
                            </div>
                        </td>
                        <td class="text-md">@d.Email</td>
                        <td class="text-md">@d.PhoneNumber</td>
                        <td>
                            <div class="role-list">
                            @foreach (var r in d.Roles)
                            {
                                var roleName = r switch
                                {
                                    UserType.Doctor => "طبيب",
                                    UserType.ClinicOwner => "مالك عيادة",
                                    UserType.Staff => "موظف",
                                    UserType.SuperAdmin => "مدير النظام",
                                    _ => "مريض"
                                };
                                <span class="badge badge-info">@roleName</span>
                            }
                            </div>
                        </td>
                        <td class="text-md">@d.CreatedAt.ToString("d MMMM yyyy")</td>
                        <td>
                            <span class="badge @(d.IsActive ? "badge-success" : "badge-warning")">@(d.IsActive ? "نشط" : "غير نشط")</span>
                        </td>
                        <td>
                            <div class="table-actions">
                                <button class="btn-icon btn-edit-doctor" title="تعديل"
                                        data-id="@d.Id"
                                        data-name="@d.FullName"
                                        data-email="@d.Email"
                                        data-phone="@d.PhoneNumber"
                                        data-active="@d.IsActive.ToString().ToLower()">
                                    <svg viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/>
                                    </svg>
                                </button>
                                <button class="btn-icon btn-change-password-doctor" title="تغيير كلمة المرور"
                                        data-id="@d.Id"
                                        data-name="@d.FullName">
                                    <svg viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1s3.1 1.39 3.1 3.1v2z"/>
                                    </svg>
                                </button>
                                <button class="btn-icon btn-delete-doctor" title="حذف"
                                        data-id="@d.Id"
                                        data-name="@d.FullName">
                                    <svg viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/>
                                    </svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<partial name="_Pagination" />

<form id="deleteDoctorForm" method="post" action="/Admin/Doctors/Delete">
    <input type="hidden" id="deleteDoctorId" name="id" value="" />
</form>

<form id="createDoctorForm" method="post" action="/Admin/Users/Create" style="display:none;">
    <input type="hidden" name="Role" value="4" />
</form>

<div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border: none; border-radius: var(--radius-md); box-shadow: var(--shadow-lg);">
            <div class="modal-body" style="padding: var(--space-6); text-align: center;">
                <div style="width: 56px; height: 56px; border-radius: 50%; background-color: rgba(239, 68, 68, 0.1); display: flex; align-items: center; justify-content: center; margin: 0 auto var(--space-4);">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" fill="#ef4444"/>
                    </svg>
                </div>
                <h3 style="font-family: var(--ff-primary); font-size: var(--fs-lg); font-weight: 700; color: var(--clr-text); margin: 0 0 var(--space-2);">تأكيد الحذف</h3>
                <p style="font-family: var(--ff-primary); font-size: var(--fs-md); color: var(--clr-text-secondary); margin: 0 0 var(--space-5);">
                    هل أنت متأكد من حذف الطبيب: <strong id="deleteDoctorName" style="color: var(--clr-text);"></strong>؟
                </p>
                <div style="display: flex; gap: var(--space-2); justify-content: center;">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" style="min-width: 90px; padding: 10px 24px; border-radius: var(--radius-sm); font-size: var(--fs-md); font-weight: 600;">إلغاء</button>
                    <button type="button" id="confirmDeleteBtn" class="btn" style="min-width: 90px; padding: 10px 24px; background-color: var(--clr-danger); color: #FFFFFF; border: none; border-radius: var(--radius-sm); font-size: var(--fs-md); font-weight: 600; cursor: pointer;">حذف</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="changePasswordModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border: none; border-radius: var(--radius-md); box-shadow: var(--shadow-lg);">
            <form id="changePasswordForm" method="post" action="/Admin/Doctors/ChangePassword">
                <div class="modal-body" style="padding: var(--space-6);">
                    <div style="width: 56px; height: 56px; border-radius: 50%; background-color: rgba(37, 99, 235, 0.1); display: flex; align-items: center; justify-content: center; margin: 0 auto var(--space-4);">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1s3.1 1.39 3.1 3.1v2z" fill="#2563eb"/>
                        </svg>
                    </div>
                    <h3 style="font-family: var(--ff-primary); font-size: var(--fs-lg); font-weight: 700; color: var(--clr-text); margin: 0 0 var(--space-1); text-align: center;">تغيير كلمة المرور</h3>
                    <p style="font-family: var(--ff-primary); font-size: var(--fs-sm); color: var(--clr-text-secondary); margin: 0 0 var(--space-5); text-align: center;">
                        تغيير كلمة مرور الطبيب: <strong id="changePasswordDoctorName" style="color: var(--clr-text);"></strong>
                    </p>
                    <input type="hidden" id="changePasswordDoctorId" name="id" value="" />
                    <div class="form-group" style="margin-bottom: var(--space-4);">
                        <label class="form-label" for="newPassword">كلمة المرور الجديدة</label>
                        <input type="password" id="newPassword" name="newPassword" class="form-input" placeholder="********" required minlength="6" />
                    </div>
                    <div class="form-group" style="margin-bottom: var(--space-4);">
                        <label class="form-label" for="confirmPassword">تأكيد كلمة المرور</label>
                        <input type="password" id="confirmPassword" name="confirmPassword" class="form-input" placeholder="********" required minlength="6" />
                    </div>
                    <div style="display: flex; gap: var(--space-2); justify-content: center;">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" style="min-width: 90px; padding: 10px 24px; border-radius: var(--radius-sm); font-size: var(--fs-md); font-weight: 600;">إلغاء</button>
                        <button type="submit" class="btn btn-primary" style="min-width: 90px; padding: 10px 24px; border-radius: var(--radius-sm); font-size: var(--fs-md); font-weight: 600;">حفظ</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editDoctorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border: none; border-radius: var(--radius-md); box-shadow: var(--shadow-lg);">
            <form id="editDoctorForm" method="post" action="/Admin/Doctors/Edit">
                <div class="modal-body" style="padding: var(--space-6);">
                    <div style="width: 56px; height: 56px; border-radius: 50%; background-color: rgba(37, 99, 235, 0.1); display: flex; align-items: center; justify-content: center; margin: 0 auto var(--space-4);">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" fill="#2563eb"/>
                        </svg>
                    </div>
                    <h3 style="font-family: var(--ff-primary); font-size: var(--fs-lg); font-weight: 700; color: var(--clr-text); margin: 0 0 var(--space-1); text-align: center;">تعديل بيانات الطبيب</h3>
                    <input type="hidden" id="editDoctorId" name="id" value="" />
                    <div class="form-group" style="margin-bottom: var(--space-4);">
                        <label class="form-label" for="editDoctorName">الاسم الكامل</label>
                        <input type="text" id="editDoctorName" name="fullName" class="form-input" required />
                    </div>
                    <div class="form-group" style="margin-bottom: var(--space-4);">
                        <label class="form-label" for="editDoctorPhone">رقم الهاتف</label>
                        <input type="text" id="editDoctorPhone" name="phoneNumber" class="form-input" />
                    </div>
                    <div class="form-group" style="margin-bottom: var(--space-4);">
                        <label class="form-label" for="editDoctorStatus">الحالة</label>
                        <select id="editDoctorStatus" name="isActive" class="form-select">
                            <option value="true">نشط</option>
                            <option value="false">غير نشط</option>
                        </select>
                    </div>
                    <div style="display: flex; gap: var(--space-2); justify-content: center;">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" style="min-width: 90px; padding: 10px 24px; border-radius: var(--radius-sm); font-size: var(--fs-md); font-weight: 600;">إلغاء</button>
                        <button type="submit" class="btn btn-primary" style="min-width: 90px; padding: 10px 24px; border-radius: var(--radius-sm); font-size: var(--fs-md); font-weight: 600;">حفظ التعديلات</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function() {
            var deleteForm = document.getElementById('deleteDoctorForm');
            var deleteIdInput = document.getElementById('deleteDoctorId');
            var deleteNameEl = document.getElementById('deleteDoctorName');
            var deleteModal = new bootstrap.Modal(document.getElementById('deleteConfirmModal'));

            document.querySelectorAll('.btn-delete-doctor').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    deleteIdInput.value = btn.getAttribute('data-id');
                    deleteNameEl.textContent = btn.getAttribute('data-name');
                    deleteModal.show();
                });
            });

            document.getElementById('confirmDeleteBtn').addEventListener('click', function() {
                deleteForm.submit();
            });

            var changePasswordModal = new bootstrap.Modal(document.getElementById('changePasswordModal'));
            var changePasswordDoctorId = document.getElementById('changePasswordDoctorId');
            var changePasswordDoctorName = document.getElementById('changePasswordDoctorName');

            document.querySelectorAll('.btn-change-password-doctor').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    changePasswordDoctorId.value = btn.getAttribute('data-id');
                    changePasswordDoctorName.textContent = btn.getAttribute('data-name');
                    document.getElementById('changePasswordForm').reset();
                    changePasswordModal.show();
                });
            });

            document.getElementById('changePasswordForm').addEventListener('submit', function(e) {
                var pwd = document.getElementById('newPassword').value;
                var confirm = document.getElementById('confirmPassword').value;
                if (pwd !== confirm) {
                    e.preventDefault();
                    alert('كلمة المرور غير متطابقة');
                }
            });

            var editDoctorModal = new bootstrap.Modal(document.getElementById('editDoctorModal'));
            var editDoctorId = document.getElementById('editDoctorId');
            var editDoctorName = document.getElementById('editDoctorName');
            var editDoctorPhone = document.getElementById('editDoctorPhone');
            var editDoctorStatus = document.getElementById('editDoctorStatus');

            document.querySelectorAll('.btn-edit-doctor').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    editDoctorId.value = btn.getAttribute('data-id');
                    editDoctorName.value = btn.getAttribute('data-name');
                    editDoctorPhone.value = btn.getAttribute('data-phone');
                    editDoctorStatus.value = btn.getAttribute('data-active');
                    editDoctorModal.show();
                });
            });
        })();

        var successMsg = '@(TempData["SuccessMessage"] ?? "")';
        if (successMsg) { showSuccessModal(successMsg); }
        var errorMsg = '@(TempData["ErrorMessage"] ?? "")';
        if (errorMsg) { showErrorModal(errorMsg); }
    </script>
}

@functions {
    private static string GetInitials(string fullName)
    {
        if (string.IsNullOrWhiteSpace(fullName)) return "";
        var parts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) return "";
        var first = parts[0][0].ToString();
        var second = parts.Length > 1 && parts[1].Length > 1 ? parts[1][1].ToString() : "";
        return first + second;
    }
}
