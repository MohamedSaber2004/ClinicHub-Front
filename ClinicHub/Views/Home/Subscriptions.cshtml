@using ClinicHub.Services.ReponseModels
@using System.Text.Json
@using ClinicHub.Routes
@{
    ViewData["Title"] = "الباقات والاشتراكات - Doctory";
    var plans = ViewBag.Plans as List<PlanDto> ?? new();
    var isAuthenticated = Context.Request.Cookies["AccessToken"] != null;
    var featureLabels = new Dictionary<string, string>
    {
        ["appointments"] = "إدارة المواعيد",
        ["patient_records"] = "السجلات الطبية",
        ["basic_reports"] = "تقارير أساسية",
        ["advanced_reports"] = "تقارير متقدمة",
        ["sms_notifications"] = "إشعارات SMS",
        ["marketing_tools"] = "أدوات تسويقية",
        ["priority_support"] = "دعم ذو أولوية",
    };
}

<section class="subscription-hero">
    <div class="container text-center">
        <h1 class="text-h1">اختر الباقة المناسبة لعيادتك</h1>
        <p class="subscription-hero-desc">اشترك الآن واستفد من جميع الميزات الحصرية لإدارة عيادتك بكفاءة</p>
    </div>
</section>

<section class="subscription-section">
    <div class="container">
        <div class="pricing-toggle">
            <span class="toggle-label">شهرياً</span>
            <label class="form-toggle">
                <input type="checkbox" id="periodToggle" />
                <span class="toggle-track"></span>
            </label>
            <span class="toggle-label">سنوياً</span>
        </div>

        <div class="subscription-plans" id="planCards">
            @if (plans.Count == 0)
            {
                <div class="text-center" style="padding: var(--space-8); color: var(--clr-text-secondary);">
                    <p style="font-size: var(--fs-lg);">لا توجد باقات متاحة حالياً</p>
                </div>
            }
            else
            {
                foreach (var plan in plans.OrderBy(p => p.SortOrder))
                {
                    var maxSort = plans.Where(p => p.IsActive).Max(p => p.SortOrder);
                    var isTop = plan.SortOrder >= maxSort;
                    var planClass = isTop ? "plan-premium" : "plan-free";
                    var badge = isTop ? "الأفضل" : "";
                    var featureList = JsonSerializer.Deserialize<List<string>>(plan.Features) ?? new();

                    <div class="plan-card @planClass">
                        @if (!string.IsNullOrEmpty(badge))
                        {
                            <span class="plan-badge">@badge</span>
                        }
                        <div class="plan-header">
                            <h3 class="plan-name">@plan.NameAr</h3>
                            <p class="plan-desc">@plan.DescriptionAr</p>
                            <p class="plan-price">
                                <span class="price-monthly">@plan.PriceMonthly.ToString("N0")</span>
                                <span class="price-yearly" style="display:none;">@plan.PriceYearly.ToString("N0")</span>
                                <span class="plan-currency">ج.م</span>
                            </p>
                            <p class="plan-period-label">
                                <span class="period-monthly">شهرياً</span>
                                <span class="period-yearly" style="display:none;">سنوياً</span>
                            </p>
                        </div>
                        <div class="plan-body">
                            <div class="plan-limits">
                                <span>@(plan.MaxDoctors.HasValue ? $"حتى {plan.MaxDoctors} أطباء" : "أطباء غير محدود")</span>
                                <span>@(plan.MaxStaff.HasValue ? $"حتى {plan.MaxStaff} موظف" : "موظفين غير محدود")</span>
                            </div>
                            <ul class="plan-features">
                                @foreach (var feature in featureList)
                                {
                                    <li>
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                                            <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z" fill="var(--clr-success)"/>
                                        </svg>
                                        <span>@(featureLabels.ContainsKey(feature) ? featureLabels[feature] : feature)</span>
                                    </li>
                                }
                            </ul>
                        </div>
                        <div class="plan-footer">
                            @if (isAuthenticated)
                            {
                                <button type="button" class="btn btn-primary btn-lg plan-cta-full btn-subscribe" data-plan-id="@plan.Id">اشترك الآن</button>
                            }
                            else
                            {
                                <a href="@HomeRoutes.Pages.ClinicRegister()" class="btn btn-primary btn-lg plan-cta-full">ابدأ الآن</a>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>

<section class="subscription-benefits">
    <div class="container">
        <h2 class="text-h2 text-center">مزايا الاشتراك السنوي</h2>
        <p class="benefits-subtitle">كل ما تحتاجه لإدارة عيادتك بكفاءة واحترافية</p>
        <div class="benefits-grid">
            <div class="benefit-card">
                <div class="icon-wrapper icon-wrapper--primary">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-1 10h-5v5h-2v-5H6v-2h5V6h2v5h5v2z" fill="currentColor"/></svg>
                </div>
                <h4 class="benefit-title">لوحة تحكم متكاملة</h4>
                <p class="benefit-desc">تابع جميع عمليات عيادتك من خلال لوحة تحكم ذكية وسهلة الاستخدام</p>
            </div>
            <div class="benefit-card">
                <div class="icon-wrapper icon-wrapper--primary icon-wrapper--green">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" fill="currentColor"/></svg>
                </div>
                <h4 class="benefit-title">إدارة الأطباء والمواعيد</h4>
                <p class="benefit-desc">أدر جداول الأطباء والمواعيد بسهولة مع إشعارات تلقائية</p>
            </div>
            <div class="benefit-card">
                <div class="icon-wrapper icon-wrapper--primary icon-wrapper--blue">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5s-3 1.34-3 3 1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 2 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z" fill="currentColor"/></svg>
                </div>
                <h4 class="benefit-title">تقارير وإحصائيات</h4>
                <p class="benefit-desc">تقارير مفصلة عن أداء عيادتك والإيرادات ونسبة الحجوزات</p>
            </div>
            <div class="benefit-card">
                <div class="icon-wrapper icon-wrapper--primary icon-wrapper--amber">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z" fill="currentColor"/></svg>
                </div>
                <h4 class="benefit-title">السجلات الطبية</h4>
                <p class="benefit-desc">إدارة السجلات الطبية للمرضى إلكترونياً مع وصول سريع للبيانات</p>
            </div>
            <div class="benefit-card">
                <div class="icon-wrapper icon-wrapper--primary icon-wrapper--green">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z" fill="currentColor"/></svg>
                </div>
                <h4 class="benefit-title">دعم فني على مدار الساعة</h4>
                <p class="benefit-desc">فريق الدعم الفني متاح لك 24/7 لحل أي مشكلة أو استفسار</p>
            </div>
            <div class="benefit-card">
                <div class="icon-wrapper icon-wrapper--primary icon-wrapper--blue">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H5.17L4 17.17V4h16v12z" fill="currentColor"/></svg>
                </div>
                <h4 class="benefit-title">إشعارات ذكية</h4>
                <p class="benefit-desc">إشعارات تلقائية للمرضى عبر SMS والبريد الإلكتروني لتذكيرهم بالمواعيد</p>
            </div>
        </div>
    </div>
</section>

<section class="subscription-cta-section">
    <div class="container text-center">
        <h2 class="text-h2">انضم إلى منصة Doctory</h2>
        <p class="subscription-cta-desc">أدرج عيادتك اليوم وابدأ في إدارة أعمالك بكفاءة</p>
        <a href="@HomeRoutes.Pages.ClinicRegister()" class="btn btn-primary btn-lg">ابدأ الآن</a>
    </div>
</section>

@section Scripts {
    <script>
        (function() {
            var toggle = document.getElementById('periodToggle');
            if (toggle) {
                toggle.addEventListener('change', function() {
                    var isYearly = this.checked;
                    document.querySelectorAll('.plan-card').forEach(function(card) {
                        var monthlyPrice = card.querySelector('.price-monthly');
                        var yearlyPrice = card.querySelector('.price-yearly');
                        var monthlyPeriod = card.querySelector('.period-monthly');
                        var yearlyPeriod = card.querySelector('.period-yearly');
                        if (monthlyPrice) monthlyPrice.style.display = isYearly ? 'none' : '';
                        if (yearlyPrice) yearlyPrice.style.display = isYearly ? '' : 'none';
                        if (monthlyPeriod) monthlyPeriod.style.display = isYearly ? 'none' : '';
                        if (yearlyPeriod) yearlyPeriod.style.display = isYearly ? '' : 'none';
                    });
                });
            }

            document.querySelectorAll('.btn-subscribe').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    var planId = this.getAttribute('data-plan-id');
                    if (!planId) {
                        var card = this.closest('.plan-card');
                        var select = card ? card.querySelector('.plan-hidden-id') : null;
                        planId = select ? select.value : '';
                    }
                    if (!planId) return;
                    var period = toggle && toggle.checked ? 1 : 0;
                    window.location.href = '@ClinicRoutes.Pages.Subscribe()' + '?planId=' + encodeURIComponent(planId) + '&period=' + period;
                });
            });
        })();
    </script>
}
