@{
    ViewData["Title"] = "نتيجة الدفع - Doctory";
    var success = ViewBag.PaymentSuccess as bool? ?? false;
}

<section class="payment-result-section">
    <div class="container">
        <div class="payment-result-card">
            @if (success)
            {
                <div class="result-icon-circle result-success">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none">
                        <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z" fill="white"/>
                    </svg>
                </div>
                <h1 class="text-h1">تم تفعيل الاشتراك بنجاح</h1>
                <p class="result-desc">
                    شكراً لك! تم تفعيل اشتراك عيادتك بنجاح. يمكنك الآن الاستمتاع بجميع ميزات المنصة.
                </p>
                <div class="result-redirect-notice">
                    سيتم العودة للرئيسية تلقائياً خلال <span id="countdownTimer" class="countdown-badge">5</span> ثوانٍ...
                </div>
                <div class="result-actions">
                    <a href="/" target="_top" class="btn btn-primary btn-lg">العودة للرئيسية الآن</a>
                </div>
            }
            else
            {
                <div class="result-icon-circle result-fail">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none">
                        <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12 19 6.41z" fill="white"/>
                    </svg>
                </div>
                <h1 class="text-h1">فشلت عملية الدفع</h1>
                <p class="result-desc">
                    حدث خطأ أثناء معالجة عملية الدفع. يرجى المحاولة مرة أخرى أو اختيار باقة مختلفة.
                </p>
                <div class="result-redirect-notice">
                    سيتم العودة للرئيسية تلقائياً خلال <span id="countdownTimer" class="countdown-badge">5</span> ثوانٍ...
                </div>
                <div class="result-actions" style="display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap;">
                    <a href="/" target="_top" class="btn btn-secondary btn-lg">العودة للرئيسية</a>
                    <a href="@HomeRoutes.Pages.Subscriptions()" target="_top" class="btn btn-primary btn-lg">عودة للباقات</a>
                </div>
            }
        </div>
    </div>
</section>

@section Scripts {
    <script>
        (function() {
            var seconds = 5;
            var timerEl = document.getElementById('countdownTimer');
            
            function redirectToHome() {
                // Solution 3: Dynamic multi-environment base URL resolution
                var currentOrigin = window.location.origin;
                if (!currentOrigin) {
                    currentOrigin = window.location.protocol + "//" + window.location.host;
                }
                var baseUrl = currentOrigin + '/';

                if (window.self !== window.top) {
                    try {
                        window.top.location.href = baseUrl;
                    } catch (e) {
                        window.location.href = baseUrl;
                    }
                } else {
                    window.location.href = baseUrl;
                }
            }

            if (timerEl) {
                var interval = setInterval(function() {
                    seconds--;
                    if (seconds >= 0) {
                        timerEl.textContent = seconds;
                    }
                    if (seconds <= 0) {
                        clearInterval(interval);
                        redirectToHome();
                    }
                }, 1000);
            } else {
                setTimeout(redirectToHome, 5000);
            }
        })();
    </script>
}

