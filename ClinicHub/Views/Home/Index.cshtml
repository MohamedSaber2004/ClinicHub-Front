@{
    ViewData["Title"] = "الرئيسية - مجموعة فقيه الطبية";
}

<!-- Hero Section -->
<section class="hero-section" style="background: radial-gradient(circle at 10% 20%, rgba(47, 156, 202, 0.1) 0%, rgba(255, 255, 255, 1) 90%); padding: 80px 0 60px;">
    <div class="container text-center">
        <h1 style="font-size: 46px; font-weight: 800; color: var(--text-dark); margin-bottom: 20px; line-height: 1.3;">
            رعايتكم هي غايتنا وعافيتكم هي أولويتنا
        </h1>
        <p style="font-size: 18px; color: var(--text-muted); max-width: 700px; margin: 0 auto 40px; line-height: 1.8;">
            أهلاً بكم في منصة إدارة العيادات الذكية لمجموعة فقيه الطبية. نوفر لكم أفضل خدمات الرعاية الصحية الشاملة والمتكاملة بأعلى معايير الجودة العالمية وأحدث التقنيات الطبية.
        </p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a asp-controller="Admin" asp-action="Index" class="btn btn-lg" style="background-color: var(--primary-color); color: #FFFFFF; font-weight: 600; padding: 12px 30px; border-radius: 5px; box-shadow: 0 4px 10px rgba(47, 156, 202, 0.2); transition: all 0.2s;">
                لوحة التحكم الإدارية (Admin)
            </a>
            <a asp-controller="Clinic" asp-action="Index" class="btn btn-lg" style="background-color: #FFFFFF; color: var(--primary-color); border: 2px solid var(--primary-color); font-weight: 600; padding: 12px 30px; border-radius: 5px; transition: all 0.2s;">
                إدارة تشغيل العيادات (Management)
            </a>
        </div>
    </div>
</section>

<!-- Quick Stats / Badges -->
<section style="padding: 20px 0;">
    <div class="container">
        <div class="row g-4 justify-content-center">
            <div class="col-md-3 col-6">
                <div class="stat-card" style="box-shadow: 0 4px 20px rgba(0,0,0,0.03); justify-content: center; gap: 15px; border-radius: 8px;">
                    <div style="font-size: 32px; font-weight: 800; color: var(--primary-color);">+50</div>
                    <div style="font-size: 14px; color: var(--text-dark); font-weight: 600;">طبيب استشاري</div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="stat-card" style="box-shadow: 0 4px 20px rgba(0,0,0,0.03); justify-content: center; gap: 15px; border-radius: 8px;">
                    <div style="font-size: 32px; font-weight: 800; color: var(--primary-color);">24/7</div>
                    <div style="font-size: 14px; color: var(--text-dark); font-weight: 600;">رعاية طوارئ متكاملة</div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="stat-card" style="box-shadow: 0 4px 20px rgba(0,0,0,0.03); justify-content: center; gap: 15px; border-radius: 8px;">
                    <div style="font-size: 32px; font-weight: 800; color: var(--primary-color);">+10</div>
                    <div style="font-size: 14px; color: var(--text-dark); font-weight: 600;">عيادات متخصصة</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Services Section -->
<section id="services" style="padding: 80px 0 60px;">
    <div class="container">
        <div class="text-center" style="margin-bottom: 50px;">
            <h2 style="font-size: 32px; font-weight: 700; color: var(--text-dark); margin-bottom: 15px;">العيادات التخصصية المتاحة</h2>
            <p style="font-size: 15px; color: var(--text-muted); max-width: 600px; margin: 0 auto;">نتميز بتغطية كافة التخصصات الطبية بأعلى كفاءة تشغيلية ورعاية متميزة</p>
        </div>

        <div class="row g-4">
            <!-- Cardio -->
            <div class="col-lg-3 col-md-6">
                <div class="card border-0" style="background: #FFFFFF; border: 1px solid var(--border-color) !important; border-radius: 8px; transition: all 0.3s; padding: 24px;">
                    <div style="width: 50px; height: 50px; background-color: rgba(47, 156, 202, 0.1); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: var(--primary-color); margin-bottom: 20px;">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 21.35L10.55 20.03C5.4 15.36 2 12.28 2 8.5C2 5.42 4.42 3 7.5 3C9.24 3 10.91 3.81 12 5.09C13.09 3.81 14.76 3 16.5 3C19.58 3 22 5.42 22 8.5C22 12.28 18.6 15.36 13.45 20.04L12 21.35Z" fill="currentColor"/>
                        </svg>
                    </div>
                    <h4 style="font-size: 18px; font-weight: 700; color: var(--text-dark); margin-bottom: 10px;">عيادة القلب والأوعية</h4>
                    <p style="font-size: 13px; color: var(--text-muted); line-height: 1.6; margin-bottom: 0;">تشخيص وعلاج أمراض القلب والأوعية الدموية بأحدث الأجهزة المتطورة.</p>
                </div>
            </div>

            <!-- Neuro -->
            <div class="col-lg-3 col-md-6">
                <div class="card border-0" style="background: #FFFFFF; border: 1px solid var(--border-color) !important; border-radius: 8px; transition: all 0.3s; padding: 24px;">
                    <div style="width: 50px; height: 50px; background-color: rgba(47, 156, 202, 0.1); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: var(--primary-color); margin-bottom: 20px;">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 2C6.48 2 2 6.48 2 12C2 17.52 6.48 22 12 22C17.52 22 22 17.52 22 12C22 6.48 17.52 2 12 2ZM13 16H11V14H13V16ZM13 12H11V8H13V12Z" fill="currentColor"/>
                        </svg>
                    </div>
                    <h4 style="font-size: 18px; font-weight: 700; color: var(--text-dark); margin-bottom: 10px;">عيادة طب وجراحة الأعصاب</h4>
                    <p style="font-size: 13px; color: var(--text-muted); line-height: 1.6; margin-bottom: 0;">رعاية متقدمة لمرضى الجهاز العصبي المركزي والطرفي تحت إشراف نخبة من الأطباء.</p>
                </div>
            </div>

            <!-- Derm -->
            <div class="col-lg-3 col-md-6">
                <div class="card border-0" style="background: #FFFFFF; border: 1px solid var(--border-color) !important; border-radius: 8px; transition: all 0.3s; padding: 24px;">
                    <div style="width: 50px; height: 50px; background-color: rgba(47, 156, 202, 0.1); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: var(--primary-color); margin-bottom: 20px;">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 12C14.21 12 16 10.21 16 8C16 5.79 14.21 4 12 4C9.79 4 8 5.79 8 8C8 10.21 9.79 12 12 12ZM12 14C9.33 14 4 15.34 4 18V20H20V18C20 15.34 14.67 14 12 14Z" fill="currentColor"/>
                        </svg>
                    </div>
                    <h4 style="font-size: 18px; font-weight: 700; color: var(--text-dark); margin-bottom: 10px;">عيادة الجلدية والتجميل</h4>
                    <p style="font-size: 13px; color: var(--text-muted); line-height: 1.6; margin-bottom: 0;">علاجات متكاملة للمشاكل الجلدية والحلول التجميلية والعناية الفائقة بالبشرة.</p>
                </div>
            </div>

            <!-- Gyn -->
            <div class="col-lg-3 col-md-6">
                <div class="card border-0" style="background: #FFFFFF; border: 1px solid var(--border-color) !important; border-radius: 8px; transition: all 0.3s; padding: 24px;">
                    <div style="width: 50px; height: 50px; background-color: rgba(47, 156, 202, 0.1); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: var(--primary-color); margin-bottom: 20px;">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 2C6.48 2 2 6.48 2 12C2 17.52 6.48 22 12 22C17.52 22 22 17.52 22 12C22 6.48 17.52 2 12 2ZM12 20C7.59 20 4 16.41 4 12C4 7.59 7.59 4 12 4C16.41 4 20 7.59 20 12C20 16.41 16.41 20 12 20Z" fill="currentColor"/>
                        </svg>
                    </div>
                    <h4 style="font-size: 18px; font-weight: 700; color: var(--text-dark); margin-bottom: 10px;">عيادة النساء والولادة</h4>
                    <p style="font-size: 13px; color: var(--text-muted); line-height: 1.6; margin-bottom: 0;">متابعة الحمل والرعاية الصحية الشاملة للمرأة بأحدث الأساليب الطبية.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- About Section -->
<section id="about" style="background-color: #FFFFFF; padding: 80px 0; border-top: 1px solid var(--border-color);">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <h2 style="font-size: 32px; font-weight: 700; color: var(--text-dark); margin-bottom: 20px;">لماذا تختار منصة مجموعة فقيه الطبية؟</h2>
                <p style="font-size: 15px; color: var(--text-muted); line-height: 1.8; margin-bottom: 30px;">
                    منصتنا مصممة خصيصاً لتيسير العمل الطبي والإداري داخل العيادات بكفاءة لا مثيل لها. نسهل إدارة الأطباء، المرضى، الممرضين، وتوزيع الغرف لضمان سرعة التشغيل وتحقيق أفضل تجربة علاجية للمريض.
                </p>
                <div class="d-flex flex-column gap-3">
                    <div class="d-flex align-items-center gap-3">
                        <div style="color: var(--primary-color);">✓</div>
                        <div style="font-weight: 600; font-size: 15px; color: var(--text-dark);">إدارة شاملة لملفات وتفاصيل الأطباء والممرضين.</div>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <div style="color: var(--primary-color);">✓</div>
                        <div style="font-weight: 600; font-size: 15px; color: var(--text-dark);">متابعة لحظية لحالة العيادات والغرف والانتظار.</div>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <div style="color: var(--primary-color);">✓</div>
                        <div style="font-weight: 600; font-size: 15px; color: var(--text-dark);">واجهة تشغيل ذكية وسلسة باللغة العربية.</div>
                    </div>
                </div>
            </div>
            <!-- Interactive Visual Card -->
            <div class="col-lg-6">
                <div style="background-color: var(--bg-color); border: 1px solid var(--border-color); border-radius: 8px; padding: 40px; box-shadow: 0 10px 30px rgba(0,0,0,0.02);">
                    <h3 style="font-size: 20px; font-weight: 700; color: var(--text-dark); margin-bottom: 20px; border-bottom: 1px solid var(--border-color); padding-bottom: 10px;">بوابة الإدارة الرقمية</h3>
                    <p style="font-size: 14px; color: var(--text-muted); line-height: 1.6; margin-bottom: 24px;">يمكنك الدخول مباشرة إلى لوحة التحكم الخاصة بك للبدء في إدارة تشغيل العيادات والموظفين فوراً.</p>
                    <div class="d-grid gap-3">
                        <a asp-controller="Admin" asp-action="Index" class="btn" style="background-color: var(--primary-color); color: white; padding: 10px; font-weight: 600; font-size: 14px; border-radius: 5px;">الدخول للوحة المدير (Admin Portal)</a>
                        <a asp-controller="Clinic" asp-action="Index" class="btn" style="background-color: #384152; color: white; padding: 10px; font-weight: 600; font-size: 14px; border-radius: 5px;">الدخول لإدارة العيادات (Clinic Portal)</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
