@{
    ViewData["Title"] = "من نحن - Doctory";
}

<!-- About Section -->
<section style="background: radial-gradient(circle at 10% 20%, rgba(74, 144, 226, 0.05) 0%, rgba(255, 255, 255, 1) 90%); padding: 60px 0;">
    <div class="container">
        <div class="text-center" style="margin-bottom: 50px;">
            <h1 style="font-size: 38px; font-weight: 800; color: var(--text-dark); margin-bottom: 20px;">من نحن - منصة Doctory</h1>
            <p style="font-size: 16px; color: var(--text-muted); max-width: 800px; margin: 0 auto; line-height: 1.8;">
                نحن نقدم الحل الوسيط الذكي الذي يربط بين المشرف العام للنظام وملاك العيادات الفردية لتسهيل الإشراف، المتابعة، والتشغيل الرقمي المتكامل.
            </p>
        </div>

        <div class="row align-items-center g-5" style="margin-bottom: 60px;">
            <div class="col-lg-6">
                <h2 style="font-size: 26px; font-weight: 700; color: var(--text-dark); margin-bottom: 20px;">رؤيتنا في إدارة الرعاية الطبية</h2>
                <p style="font-size: 15px; color: var(--text-muted); line-height: 1.8; margin-bottom: 24px;">
                    منصة <strong>Doctory</strong> ليست موقعاً للمرضى لحجز المواعيد الفردية، بل هي نظام وسيط متقدم (Clinic Management SaaS System) يتيح لمدير النظام (Admin) وملاك العيادات المشتركين (Clinic Owners) التحكم الكامل والإشراف المتبادل على الأنشطة الطبية والتشغيلية اليومية.
                </p>
                <div class="d-flex flex-column gap-3">
                    <div class="d-flex align-items-start gap-3">
                        <div style="color: var(--primary-color); font-weight: 700; font-size: 18px;">✓</div>
                        <div>
                            <h4 style="font-size: 16px; font-weight: 700; color: var(--text-dark); margin-bottom: 5px;">تمكين ملاك العيادات</h4>
                            <p style="font-size: 13px; color: var(--text-muted); margin-bottom: 0;">توفير لوحات تحكم متطورة ومخصصة لكل عيادة لمتابعة الأطباء والمرضى والانتظار والجدولة بشكل مستقل وسهل.</p>
                        </div>
                    </div>
                    <div class="d-flex align-items-start gap-3">
                        <div style="color: var(--primary-color); font-weight: 700; font-size: 18px;">✓</div>
                        <div>
                            <h4 style="font-size: 16px; font-weight: 700; color: var(--text-dark); margin-bottom: 5px;">تسهيل إشراف الإدارة</h4>
                            <p style="font-size: 13px; color: var(--text-muted); margin-bottom: 0;">تمكين المشرفين العامين من مراقبة كفاءة العيادات وتراخيصها وحركتها الإجمالية من بوابة مركزية موحدة.</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-6">
                <div style="background-color: #FFFFFF; border: 1px solid var(--border-color); border-radius: 8px; padding: 40px; box-shadow: 0 10px 30px rgba(0,0,0,0.02);">
                    <h3 style="font-size: 20px; font-weight: 700; color: var(--text-dark); margin-bottom: 20px; border-bottom: 1px solid var(--border-color); padding-bottom: 10px; text-align: center;">النظام البيئي لمنصتنا</h3>
                    
                    <div style="display: flex; flex-direction: column; gap: 20px; margin-top: 20px;">
                        <div style="display: flex; align-items: center; gap: 15px; background: var(--bg-color); padding: 15px; border-radius: 6px;">
                            <div style="font-size: 24px; font-weight: 800; color: var(--primary-color);">01</div>
                            <div>
                                <h5 style="font-size: 14px; font-weight: 700; margin-bottom: 2px;">مدير النظام (System Admin)</h5>
                                <p style="font-size: 12px; color: var(--text-muted); margin-bottom: 0;">يملك الصلاحية الكاملة لإعداد المنصة، إنشاء العيادات، وتعيين ملاك العيادات المشرفين.</p>
                            </div>
                        </div>

                        <div style="display: flex; align-items: center; gap: 15px; background: var(--bg-color); padding: 15px; border-radius: 6px;">
                            <div style="font-size: 24px; font-weight: 800; color: var(--primary-color);">02</div>
                            <div>
                                <h5 style="font-size: 14px; font-weight: 700; margin-bottom: 2px;">مالك العيادة (Clinic Owner)</h5>
                                <p style="font-size: 12px; color: var(--text-muted); margin-bottom: 0;">يدير شؤون عيادته الداخلية، مثل الأطباء، توزيع الغرف، وقوائم المرضى اليومية.</p>
                            </div>
                        </div>

                        <div style="display: flex; align-items: center; gap: 15px; background: var(--bg-color); padding: 15px; border-radius: 6px;">
                            <div style="font-size: 24px; font-weight: 800; color: var(--primary-color);">03</div>
                            <div>
                                <h5 style="font-size: 14px; font-weight: 700; margin-bottom: 2px;">تشغيل العيادات (Staff / Doctors)</h5>
                                <p style="font-size: 12px; color: var(--text-muted); margin-bottom: 0;">تفاعل مباشر مع النظام لإتمام الكشوفات وإرسال التنبيهات.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="row text-center g-4" style="margin-top: 20px;">
            <div class="col-md-4">
                <div style="padding: 30px; border: 1px solid var(--border-color); border-radius: 8px; background: #FFFFFF;">
                    <div style="font-size: 36px; margin-bottom: 15px; color: var(--primary-color);">📊</div>
                    <h4 style="font-size: 18px; font-weight: 700;">تقارير موحدة</h4>
                    <p style="font-size: 13px; color: var(--text-muted);">تحليلات ذكية وسريعة توضح أداء وتطور وسرعة الاستجابة لجميع العيادات المسجلة في النظام.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div style="padding: 30px; border: 1px solid var(--border-color); border-radius: 8px; background: #FFFFFF;">
                    <div style="font-size: 36px; margin-bottom: 15px; color: var(--primary-color);">⚙️</div>
                    <h4 style="font-size: 18px; font-weight: 700;">تحكم مرن</h4>
                    <p style="font-size: 13px; color: var(--text-muted);">قدرة عالية على تفعيل أو تعطيل الاشتراكات، تعيين غرف الكشف، وإعداد الموظفين بسهولة.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div style="padding: 30px; border: 1px solid var(--border-color); border-radius: 8px; background: #FFFFFF;">
                    <div style="font-size: 36px; margin-bottom: 15px; color: var(--primary-color);">🔒</div>
                    <h4 style="font-size: 18px; font-weight: 700;">خصوصية وأمان</h4>
                    <p style="font-size: 13px; color: var(--text-muted);">فصل كامل بين بيانات العيادات المختلفة لضمان سرية معلومات المرضى وملاك العيادات.</p>
                </div>
            </div>
        </div>
    </div>
</section>
