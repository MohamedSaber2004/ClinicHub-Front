@using ClinicHub.Routes
@{
    var userId = ViewBag.UserId as int? ?? ViewBag.User?.Id as int? ?? 1;
    var currentSection = ViewBag.SubSidebarSection as string ?? "overview";
    bool IsActive(string section) => currentSection == section;
}

<div class="sub-sidebar">
    <div class="sub-sidebar-header">
        <a href="@AdminRoutes.Pages.Users()" class="sub-sidebar-back">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/>
            </svg>
            المستخدمين
        </a>
    </div>
    <a class="sub-sidebar-item @(IsActive("overview") ? "active" : "")" href="@AdminRoutes.Pages.UsersOverview(userId)">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/>
        </svg>
        نظرة عامة
    </a>
    <a class="sub-sidebar-item @(IsActive("visits") ? "active" : "")" href="@AdminRoutes.Pages.UsersVisits(userId)">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M19 3h-4.18C14.4 1.84 13.3 1 12 1c-1.3 0-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm-2 14l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/>
        </svg>
        الزيارات والتقييمات
    </a>
    <a class="sub-sidebar-item @(IsActive("requests") ? "active" : "")" href="@AdminRoutes.Pages.UsersRequests(userId)">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm16-4H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-1 9h-4v4h-2v-4H9V9h4V5h2v4h4v2z"/>
        </svg>
        الطلبات
    </a>
    <a class="sub-sidebar-item @(IsActive("payments") ? "active" : "")" href="@AdminRoutes.Pages.UsersPayments(userId)">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M20 4H4c-1.11 0-1.99.89-1.99 2L2 18c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V6c0-1.11-.89-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z"/>
            <circle cx="15.5" cy="13.5" r="2.5"/>
        </svg>
        المدفوعات
    </a>
</div>
