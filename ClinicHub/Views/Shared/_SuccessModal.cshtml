<div class="modal fade" id="globalSuccessModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border: none; border-radius: var(--radius-md); box-shadow: var(--shadow-lg);">
            <div class="modal-body" style="padding: var(--space-8); text-align: center;">
                <div style="width: 56px; height: 56px; border-radius: 50%; background-color: var(--clr-success); display: flex; align-items: center; justify-content: center; margin: 0 auto var(--space-4);">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z" fill="white"/>
                    </svg>
                </div>
                <h3 style="font-family: var(--ff-primary); font-size: var(--fs-lg); font-weight: 700; color: var(--clr-text); margin: 0 0 var(--space-2);">تم بنجاح</h3>
                <div id="globalSuccessMsg" style="font-family: var(--ff-primary); font-size: var(--fs-md); color: var(--clr-text-secondary); margin-bottom: var(--space-5);"></div>
                <button type="button" class="btn" style="min-width: 100px; padding: 10px 24px; background-color: var(--clr-primary); color: #FFFFFF; border: none; border-radius: var(--radius-sm); font-family: var(--ff-primary); font-size: var(--fs-md); font-weight: 600; cursor: pointer;" data-bs-dismiss="modal">حسناً</button>
            </div>
        </div>
    </div>
</div>

